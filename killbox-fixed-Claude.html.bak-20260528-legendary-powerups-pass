.breachCard {
  position: relative;
  overflow: hidden;
  text-align: center;
  width: min(560px, calc(100vw - 28px));
  min-height: 0;
  max-height: none;
  padding: 18px 18px 16px;
  background:
    radial-gradient(circle at 50% 20%, rgba(255,219,145,.22) 0 12%, transparent 32%),
    radial-gradient(circle at 50% 56%, rgba(255,122,38,.12) 0 10%, transparent 42%),
    linear-gradient(180deg, #351912 0%, #160906 64%, #090403 100%);
  border-color: #df7b2a;
  box-shadow: 0 0 30px #ff7b1f33, 0 20px 60px #000;
}
.breachCard::before {
  content: "";
  position: absolute; inset: -12%;
  background:
    radial-gradient(circle at 50% 50%, transparent 0 60%, rgba(255,223,154,.16) 61% 62%, transparent 63%),
    linear-gradient(130deg, transparent 0 46%, rgba(255,241,211,.28) 46.3% 47%, transparent 47.3% 51%, rgba(255,121,40,.24) 51.3% 52%, transparent 52.3% 100%),
    linear-gradient(42deg, transparent 0 55%, rgba(255,241,211,.2) 55.2% 56%, transparent 56.2% 100%),
    radial-gradient(circle at 48% 44%, rgba(255,255,255,.08) 0 2%, transparent 3%);
  background-size: 100% 100%, 100% 100%, 100% 100%, 28px 28px;
  opacity: .78;
  animation: breachPulse 1.3s ease-in-out infinite alternate;
  pointer-events: none;
}
.breachCard::after {
  content: "";
  position: absolute; inset: 14% 17%;
  background:
    radial-gradient(circle at 50% 45%, transparent 0 60%, rgba(255,138,31,.12) 61% 63%, transparent 64%),
    linear-gradient(135deg, transparent 0 47%, rgba(255,231,181,.1) 47% 48%, transparent 48% 51%, rgba(255,79,31,.14) 51% 52%, transparent 52% 100%);
  mix-blend-mode: screen;
  pointer-events: none;
}
.breachCard > * { position: relative; z-index: 1; }
.breachCard .breachSeal {
  width: 96px;
  height: 96px;
  margin: 0 auto 8px;
  border-radius: 50%;
  position: relative;
  background:
    radial-gradient(circle at 50% 50%, rgba(255,243,210,.18) 0 16%, transparent 17%),
    radial-gradient(circle at 50% 50%, rgba(255,138,31,.14) 0 34%, transparent 35%),
    radial-gradient(circle at 50% 50%, rgba(255,79,31,.2) 0 48%, transparent 49%),
    #2a0d08;
  border: 2px solid rgba(255,210,122,.7);
  box-shadow: 0 0 0 3px rgba(255,138,31,.09) inset, 0 0 24px rgba(255,122,38,.2);
  overflow: hidden;
}
.breachCard .breachSeal::before,
.breachCard .breachSeal::after {
  content: "";
  position: absolute;
  inset: 18%;
  border-radius: 50%;
  border: 3px solid rgba(255,231,181,.5);
  transform: rotate(0deg);
}
.breachCard .breachSeal::before {
  inset: 14%;
  clip-path: polygon(0 44%, 24% 40%, 39% 14%, 49% 32%, 61% 9%, 73% 37%, 100% 44%, 74% 52%, 63% 84%, 50% 60%, 36% 89%, 25% 55%);
  border-width: 2px;
  animation: breachSpin 3.8s linear infinite;
}
.breachCard .breachSeal::after {
  inset: 38%;
  border-width: 2px;
  box-shadow:
    0 -24px 0 -22px rgba(255,231,181,.8),
    0 24px 0 -22px rgba(255,231,181,.8),
    -24px 0 0 -22px rgba(255,231,181,.8),
    24px 0 0 -22px rgba(255,231,181,.8);
  animation: breachPulse 1.3s ease-in-out infinite alternate;
}
.breachCard h1 {
  color: #fff2cb;
  text-shadow: 0 0 18px #ff8a1f44, 0 4px 0 #2b0a07;
  letter-spacing: .18em;
  text-transform: uppercase;
  margin: 0 0 6px;
  font-size: 38px;
}
.breachCard p {
  color: #f4ddba;
  font-size: 16px;
  line-height: 1.28;
  max-width: 430px;
  margin: 0 auto 12px;
}
.breachCard .breachCopy {
  margin: 0 auto 12px;
  display: grid;
  gap: 6px;
}
.breachCard .breachCopy .breachLine {
  color: #f7e0be;
  font-size: 15px;
  font-weight: 700;
}
.breachCard .breachCopy .breachLife {
  color: #ffd57b;
  font-size: 15px;
  font-weight: 900;
  letter-spacing: .04em;
  text-transform: uppercase;
}
.breachCard .deathButtons {
  margin-top: 4px;
  grid-template-columns: minmax(0, 220px);
  justify-content: center;
}
