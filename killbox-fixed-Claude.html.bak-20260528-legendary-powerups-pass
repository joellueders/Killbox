// ── Enemy AI ──────────────────────────────────────────────────────

// Main enemy update dispatcher
function enemyStep(e, dt) {
  e.flash = Math.max(0, e.flash - dt);
  e.heroPressure = Math.max(0, (e.heroPressure || 0) - dt * 0.55);
  e.freeze = Math.max(0, (e.freeze || 0) - dt);
  e.chill = Math.max(0, (e.chill || 0) - dt * 0.6);

  // DoT effects
  if (e.burn   > 0) { e.burn   -= dt; hit(e, e.burnD   * dt, null); }
  if (e.poison > 0) { e.poison -= dt; hit(e, e.poisonD * dt, null); }
  if (e.dead) return;

  if (e.stun > 0) {
    e.stun -= dt;
    e.x += (e.kx || 0) * dt;
    e.y += (e.ky || 0) * dt;
    e.kx = (e.kx || 0) * Math.max(0, 1 - dt * 4);
    e.ky = (e.ky || 0) * Math.max(0, 1 - dt * 4);
    if (e.air > 0) e.air = Math.max(0, e.air - dt);
    return;
  }

  // Type-specific AI
  if (e.type === 'healer')    healerPulse(e, dt);
  if (e.type === 'slimeking') { slimeKingStep(e, dt); return; }
  if (e.dead) return;
  if (e.type === 'siege')     { siegeStep(e, dt);   return; }
  if (e.type === 'bomber')    { bomberStep(e, dt);   return; }
  if (e.type === 'hunter' && S.towers.length) { hunterStep(e, dt); return; }

  // Ranged enemies: shoot hero when close enough
  if (e.range && dist(e.x, e.y, S.hero.x, S.hero.y) < e.range) {
    e.shoot -= dt;
    if (e.shoot <= 0) {
      const a  = Math.atan2(S.hero.y - e.y, S.hero.x - e.x);
      const sp = 320;
      S.enemyShots.push({
        x: e.x, y: e.y,
        vx: Math.cos(a) * sp, vy: Math.sin(a) * sp,
        life: 1.25,
        dmg:  e.type === 'ogre' ? 14 : 8 + S.wave * .45,
      });
      e.shoot = e.type === 'ogre' ? 2.6 : e.type === 'slinger' ? (0.7 + Math.random() * 0.35) : (1.2 + Math.random() * 0.7);
    }
  }

  // Oil patch slow
  let slow = e.slow > 0 ? .55 : 1;
  if (e.freeze > 0 && e.type !== 'slimeking') slow = Math.min(slow, .18);
  else if (e.chill > 0) slow = Math.min(slow, 1 - Math.min(.45, e.chill * .12));
  e.slow -= dt;
  for (const o of S.oilPatches) {
    if (dist(e.x, e.y, o.x, o.y) < o.r) {
      slow = Math.min(slow, .5);
      e.slow = Math.max(e.slow, .25);
    }
  }
  for (const f of S.firePatches) {
    if (dist(e.x, e.y, f.x, f.y) < f.r) {
      const bossResist = e.type === 'slimeking' ? 0.01 : 1;
      hit(e, f.dps * bossResist * dt, f.t || null);
      if (e.dead) return;
    }
  }

  if (S.hero.lastStandBeaconActive) {
    const gx = cx(GOAL.c) + 30, gy = cy(GOAL.r);
    const exitD = dist(e.x, e.y, gx, gy);
    if (exitD < 122) {
      e.stun = Math.max(e.stun || 0, .18);
      hit(e, (e.type === 'slimeking' ? 2 : 5) * dt, null);
      boom(e.x, e.y, '#8edcff22', 2);
    }
  }

  // Melee contact with hero only — engineer is not a valid melee target
  if (dist(e.x, e.y, S.hero.x, S.hero.y) < e.rad + 14) {
    hurtHero(e.type === 'ogre' ? 18 : 8);
    e.slow = Math.max(e.slow, .2);
  }

  handleCollisions(e, dt);
  if ((e.kx || e.ky) && e.stun <= 0) {
    e.x += (e.kx || 0) * dt * .35;
    e.y += (e.ky || 0) * dt * .35;
    e.kx = (e.kx || 0) * Math.max(0, 1 - dt * 3.2);
    e.ky = (e.ky || 0) * Math.max(0, 1 - dt * 3.2);
  }
  followPath(e, dt, slow);
}

// Healer: pulse HP to nearby allies
function healerPulse(e, dt) {
  e.healCool -= dt;
  if (e.healCool > 0) return;
  e.healCool = 1.3;
  for (const o of S.enemies) {
    if (o !== e && !o.dead && dist(e.x, e.y, o.x, o.y) < 95) {
      o.hp = Math.min(o.max, o.hp + 10 + S.wave * 2);
      boom(o.x, o.y, '#eee4b2', 4);
    }
  }
}

// Siege ram: hunts barriers
function siegeStep(e, dt) {
  const closestBarrier = S.barriers
    .filter(b => !b.dead)
    .sort((a, b) => dist(e.x, e.y, a.x, a.y) - dist(e.x, e.y, b.x, b.y))[0];

  if (closestBarrier && dist(e.x, e.y, closestBarrier.x, closestBarrier.y) < 280) {
    const bd = dist(e.x, e.y, closestBarrier.x, closestBarrier.y);
    if (bd < e.rad + 28) {
      attackBarrier(e, closestBarrier, dt * 4.5);
    } else {
      e.x += (closestBarrier.x - e.x) / (bd || 1) * e.spd * G * dt;
      e.y += (closestBarrier.y - e.y) / (bd || 1) * e.spd * G * dt;
    }
    return;
  }
  followPath(e, dt, 1);
}

// Bomber: rush hero only (not engineer — she'd sponge them), enter panic phase before detonating
function bomberStep(e, dt) {
  const target = S.hero;

  const td = dist(e.x, e.y, target.x, target.y);

  // Panic phase: within detonation range, start countdown before blast
  if (td < e.rad + 28) {
    if (!e.panicTimer) {
      e.panicTimer = 0.55; // 0.55s warning window
      // Screech burst — rapid outward sparks signal danger
      burst(e.x, e.y, '#ffcf3d', 10, 'spark', 160);
    }
    e.panicTimer -= dt;

    if (e.panicTimer <= 0) {
      e.dead = true;
      boom(e.x, e.y, '#ffcf3d', 55);
      boom(e.x, e.y, '#c01818', 40);
      shockwave(e.x, e.y, '#ffcf3d', 110, .4);
      // Damage scales with proximity, max 1/3 hp at ground zero, less at edge
      const heroD = dist(e.x, e.y, S.hero.x, S.hero.y);
      if (heroD < 110) hurtHero(Math.ceil(S.hero.max / 3 * Math.max(0.35, 1 - heroD / 110)));
      if (S.engineer.active && S.engineer.hp > 0) {
        const engD = dist(e.x, e.y, S.engineer.x, S.engineer.y);
        if (engD < 110) hurtEngineer(Math.ceil(S.engineer.max / 3 * Math.max(0.35, 1 - engD / 110)));
      }
      floatText('BOOM!', e.x - 20, e.y - 22, '#ffcf3d');
      shake(9, .35);
    }
    // Freeze in place during panic — gives player a reaction window
    return;
  }

  // Reset panic if target moves away
  e.panicTimer = 0;
  e.x += (target.x - e.x) / (td || 1) * e.spd * G * dt;
  e.y += (target.y - e.y) / (td || 1) * e.spd * G * dt;
}

// Tower hunter: navigates toward towers; is blocked / attacks barriers
function hunterStep(e, dt) {
  const now = performance.now() / 1000;
  const blocker = S.barriers
    .filter(b => !b.dead)
    .sort((a, b) => dist(e.x, e.y, a.x, a.y) - dist(e.x, e.y, b.x, b.y))[0];
  const coreTower = S.towers
    .filter(t => !t.dead && isCoreTowerType(t.type))
    .sort((a, b) => dist(e.x, e.y, a.x, a.y) - dist(e.x, e.y, b.x, b.y))[0];
  const tgt = blocker || coreTower;
  if (!tgt) return followPath(e, dt, 1);

  const slow = e.slow > 0 ? .55 : 1;
  e.slow -= dt;

  const td = dist(e.x, e.y, tgt.x, tgt.y);
  const nx = e.x + (tgt.x - e.x) / (td || 1) * e.spd * G * dt * slow;
  const ny = e.y + (tgt.y - e.y) / (td || 1) * e.spd * G * dt * slow;

  if (blocker && segDist(blocker.x, blocker.y, e.x, e.y, nx, ny) < e.rad + 28) {
    attackBarrier(e, blocker, dt * 1.4);
    return;
  }

  if (coreTower) {
    if (td > e.rad + 34) {
      e.x = nx; e.y = ny;
      return;
    }
    coreTower.disabledUntil = Math.max(coreTower.disabledUntil || 0, now + 7.5);
    coreTower.disablePulse = 1.2;
    coreTower.disableFx = 1.2;
    e.stun = Math.max(e.stun || 0, .18);
    boom(coreTower.x, coreTower.y, '#69d3ff', 8);
    shockwave(coreTower.x, coreTower.y, '#69d3ff', 36, .18);
    floatText('JAMMED', coreTower.x - 20, coreTower.y - 38, '#69d3ff');
    toast(`${TOWERS[coreTower.type].n} jammed!`);
    return;
  }

  if (td > e.rad + 25) {
    e.x = nx; e.y = ny;
  }
}

// Shared barrier attack logic
function attackBarrier(e, b, dt) {
  const bd  = dist(e.x, e.y, b.x, b.y) || 1;
  const ax  = (e.x - b.x) / bd;
  const ay  = (e.y - b.y) / bd;
  e.x = b.x + ax * (e.rad + 27);
  e.y = b.y + ay * (e.rad + 27);
  e.slow = Math.max(e.slow, .35);
  b.hp  -= dt * 10;
  if (b.hp <= 0) {
    b.dead = true;
    destroyStructure(b.x, b.y, 'barrier');
    toast('A barrier broke!');
  }
}

// Push enemies away from solid objects (barriers and on-road towers)
function handleCollisions(e, dt) {
  for (const b of S.barriers) {
    const bd  = dist(e.x, e.y, b.x, b.y);
    const min = e.rad + 25;
    if (bd < min) {
      const ax = (e.x - b.x) / (bd || 1);
      const ay = (e.y - b.y) / (bd || 1);
      e.x = b.x + ax * min;
      e.y = b.y + ay * min;
      e.slow = Math.max(e.slow, .45);
      b.hp -= dt * (e.type === 'ogre' ? 56 : e.type === 'brute' ? 34 : 17);
      if (b.hp <= 0) { b.dead = true; destroyStructure(b.x, b.y, 'barrier'); toast('A barrier broke!'); }
    }
  }
  for (const tw of S.towers) {
    if (TOWERS[tw.type].trap) continue;
    const td  = dist(e.x, e.y, tw.x, tw.y);
    const min = e.rad + 24;
    if (td < min) {
      const ax = (e.x - tw.x) / (td || 1);
      const ay = (e.y - tw.y) / (td || 1);
      e.x = tw.x + ax * min;
      e.y = tw.y + ay * min;
      e.slow = Math.max(e.slow, .35);
      if (towerHasDurability(tw)) {
        tw.hp -= dt * (e.type === 'ogre' ? 44 : e.type === 'brute' ? 28 : 14);
        if (tw.hp <= 0) { tw.dead = true; destroyStructure(tw.x, tw.y, 'tower'); toast('A tower was destroyed!'); }
      }
    }
  }
}

// Wild enemy: pick a new movement deviation goal
function chooseWildMove(e) {
  const path = enemyPath(e);
  const n    = path[Math.min(path.length - 1, e.node + 1)];
  const roll = Math.random();

  e.wildProgress = 1.1 + Math.random() * 1.3;

  if (roll < .30) {
    // Feint toward hero
    e.wildMode  = 'hero-feint';
    e.wildX     = S.hero.x + (Math.random() - .5) * 110;
    e.wildY     = S.hero.y + (Math.random() - .5) * 110;
    e.wildBlend = .28;
  } else if (roll < .58) {
    // Lateral offset
    e.wildMode = 'wide';
    e.off      = clamp(e.off + (Math.random() - .5) * 120, -90, 90);
    e.wildBlend = .18;
  } else if (roll < .84) {
    // Cut ahead on path
    e.wildMode = 'cut';
    const look = Math.min(path.length - 1, e.node + 2 + Math.floor(Math.random() * 4));
    const p    = path[look];
    e.wildX     = p.x + (Math.random() - .5) * 75;
    e.wildY     = p.y + (Math.random() - .5) * 75;
    e.wildBlend = .42;
  } else {
    // Dodge sideways
    e.wildMode  = 'dodge';
    const side  = Math.random() < .5 ? -1 : 1;
    e.wildX     = n.x + side * (50 + Math.random() * 65);
    e.wildY     = n.y + (Math.random() - .5) * 70;
    e.wildBlend = .32;
  }
  e.wildTimer = .3 + Math.random() * .6;
}

// Follow the BFS path, with optional wild deviation
function followPath(e, dt, slow) {
  const path = enemyPath(e);
  const next = path[e.node + 1];
  if (!next) {
    // Reached the keep
    e.dead  = true;
    const leak = e.type === 'slimeking' ? 5 : e.type === 'ogre' ? 5 : e.type === 'brute' ? 2 : 1;
    const riftShieldActive = (S.mods.riftShieldUntil || 0) > performance.now() / 1000;
    const lifeLoss = riftShieldActive ? 0 : Math.max(1, Math.floor(leak * (S.hero.lastStandBeacon ? .9 : 1)));
    S.lives -= lifeLoss;
    if (S.waveStats) S.waveStats.leaked += lifeLoss;
    if (S.runStats) S.runStats.leaked += lifeLoss;
    if (lifeLoss > 0) floatText('-' + lifeLoss + ' life', e.x, e.y, '#ffb0a0');
    else floatText('RIFT SHIELD', e.x - 26, e.y - 20, '#8edcff');
    shake(6, .3);
    if (S.lives <= 0) offerRestart('The Village Falls');
    ui();
    return;
  }

  // Base target: next path node + lateral offset
  let forwardIndex = e.node + 1;
  let base = next;
  if (e.wild && e.wildProgress) {
    forwardIndex = Math.min(path.length - 1, Math.floor(e.node + e.wildProgress));
    base = path[forwardIndex] || next;
  }

  let tx = base.x, ty = base.y + e.off;
  let rx = 0, ry = 0;

  // Wild: apply mode-based deviation
  if (e.wild) {
    e.wildTimer -= dt;
    if (e.wildTimer <= 0) chooseWildMove(e);

    if (e.wildMode === 'hero-feint' || e.wildMode === 'cut' || e.wildMode === 'dodge') {
      const b = e.wildBlend;
      tx = tx * (1 - b) + e.wildX * b;
      ty = ty * (1 - b) + e.wildY * b;
      if (dist(e.x, e.y, e.wildX, e.wildY) < 30) e.wildMode = 'path';
    }

    // Separation from other enemies
    for (const o of S.enemies) {
      if (o !== e && !o.dead) {
        const od = dist(e.x, e.y, o.x, o.y);
        if (od > 0 && od < 56) {
          rx += (e.x - o.x) / od * (56 - od);
          ry += (e.y - o.y) / od * (56 - od);
        }
      }
    }

    // Slight hero avoidance
    const hd = dist(e.x, e.y, S.hero.x, S.hero.y);
    if (hd < 100 && e.type !== 'bomber') {
      rx += (e.x - S.hero.x) / (hd || 1) * 18;
      ry += (e.y - S.hero.y) / (hd || 1) * 18;
    }
  }

  // Sustained hero focus triggers strafe/retreat behavior so packs do not face-tank forever.
  if ((e.heroPressure || 0) > 0.35 && e.type !== 'slimeking' && e.type !== 'siege') {
    const ha = Math.atan2(e.y - S.hero.y, e.x - S.hero.x);
    const side = Math.sin((e.x * .07 + e.y * .03 + performance.now() * .002)) >= 0 ? 1 : -1;
    const strength = Math.min(42, 18 + (e.heroPressure || 0) * 14);
    rx += -Math.sin(ha) * side * strength;
    ry +=  Math.cos(ha) * side * strength;
    const hd = dist(e.x, e.y, S.hero.x, S.hero.y);
    if (hd < 170) {
      rx += Math.cos(ha) * 12;
      ry += Math.sin(ha) * 12;
    }
  }

  // Move
  const l = dist(e.x, e.y, tx, ty) || 1;
  e.x += (tx - e.x) / l * e.spd * G * dt * slow + rx * dt * .4;
  e.y += (ty - e.y) / l * e.spd * G * dt * slow + ry * dt * .4;

  // Advance node
  if (dist(e.x, e.y, next.x, next.y + e.off) < 24 ||
      dist(e.x, e.y, base.x, base.y + e.off) < 18) {
    e.node = Math.max(e.node + 1, Math.min(forwardIndex, path.length - 1));
  }
}

// ── Projectile step ───────────────────────────────────────────────
function projectiles(dt) {
  // Tower shots
  for (const s of S.shots) {
    s.life -= dt;
    const l = dist(s.x, s.y, s.tx.x, s.tx.y) || 1;
    s.x += (s.tx.x - s.x) / l * s.spd * dt;
    s.y += (s.tx.y - s.y) / l * s.spd * dt;
    if (l < 12 || s.life <= 0) {
      if (s.d.splash) {
        const splashTargets = S.enemies
          .filter(e => dist(s.tx.x, s.tx.y, e.x, e.y) < s.d.splash)
          .sort((a, b) => dist(s.tx.x, s.tx.y, a.x, a.y) - dist(s.tx.x, s.tx.y, b.x, b.y))
          .slice(0, s.d.maxTargets || 999);

        for (const e of splashTargets) {
          const dd = dist(s.tx.x, s.tx.y, e.x, e.y);
          hit(e, s.dmg * (1 - dd / (s.d.splash * 1.7)), s.t);
        }
      } else {
        hit(s.tx, s.dmg, s.t);
      }
      if (s.d.firePatch) {
        S.firePatches.push({ x: s.tx.x, y: s.tx.y, r: 26, life: 2.8, maxLife: 2.8, dps: 2.2 * (1 + .10 * ((s.t?.level || 1) - 1)), t: s.t });
        impactFx(s.x, s.y, 'fire');
      } else if (s.t && s.t.type === 'cannon') {
        impactFx(s.x, s.y, 'explosion');
        shake(5, .18);
      } else if (s.t && s.t.type === 'spire') {
        impactFx(s.x, s.y, 'lightning');
      }
      // Generic tower hit effects removed for visibility.
      s.dead = true;
    }
  }
  S.shots = S.shots.filter(s => !s.dead);

  // Hero shots
  for (const s of S.heroShots) {
    const oldX = s.x, oldY = s.y;
    s.life -= dt;
    s.x += s.vx * dt;
    s.y += s.vy * dt;
    s.travel += dist(oldX, oldY, s.x, s.y);

    // Barrel detonation
    for (const b of S.barrels) {
      if (!b.dead && dist(s.x, s.y, b.x, b.y) < b.rad + 6) {
        explodeBarrel(b); s.dead = true; break;
      }
    }
    // Friendly-fire towers. P2 engineer bolts are tuned as support fire and do not damage friendly structures.
    if (!s.dead && !s.p2) {
      for (const tw of S.towers) {
        if (segDist(tw.x, tw.y, oldX, oldY, s.x, s.y) < 27) {
          tw.hp -= s.dmg * .35;
          if (tw.hp <= 0) { tw.dead = true; destroyStructure(tw.x, tw.y, 'tower'); toast('Friendly fire destroyed a tower!'); }
          s.dead = true; boom(s.x, s.y, '#18a8ff', 4); break;
        }
      }
    }
    // Hit enemies
    if (!s.dead) {
      for (const e of S.enemies) {
        if (!e.dead && dist(s.x, s.y, e.x, e.y) < e.rad + 5) {
          let dmg = s.dmg;
          if (s.weapon === 'ranger' && ['runner','slinger','healer','bomber'].includes(e.type)) dmg *= 1.35;
          if (s.weapon === 'storm' && (e.type === 'slimeking' || e.type === 'ogre' || e.type === 'siege')) dmg *= .55;
          if (s.weapon === 'crossbow' && e.type === 'shield') dmg *= 1.25;
          if (s.weapon === 'freeze') {
            e.chill = (e.chill || 0) + (s.chill || 1);
            if (e.type !== 'slimeking' && e.chill >= 3) {
              e.chill = 0;
              e.freeze = 1.5 * (S.hero.freezeDurationMult || 1);
            }
          }
          hit(e, dmg, null, true);
          if (e.freeze > 0) {
            e.slow = Math.max(e.slow || 0, .88);
          }
          if (s.pin && !['brute','siege','slimeking','ogre'].includes(e.type)) e.stun = Math.max(e.stun || 0, .56 * (S.hero.crossbowStunMult || 1));
          if (s.stunBolt) e.stun = Math.max(e.stun || 0, (e.type === 'slimeking' ? .32 : 1.5) * (S.hero.crossbowStunMult || 1));
          if (s.p2) impactFx(s.x, s.y, 'lightning');
          else if (s.thunk) impactFx(s.x, s.y, 'thunk');
          if (e.hp <= 0) kill(e, null, true);
          if (s.pierce) {
            s.hits = (s.hits || 1) - 1;
            if (s.hits <= 0) { s.dead = true; break; }
          } else {
            s.dead = true; break;
          }
        }
      }
    }
    const bounds = getWorldBounds();
    const pad = 160;
    if (s.life <= 0 || s.travel > s.range || s.x < bounds.x - pad || s.y < bounds.y - pad || s.x > bounds.x + bounds.w + pad || s.y > bounds.y + bounds.h + pad)
      s.dead = true;
  }
  S.heroShots = S.heroShots.filter(s => !s.dead);
  S.barrels   = S.barrels.filter(b => !b.dead);

  // Enemy shots
  for (const s of S.enemyShots) {
    s.life -= dt;
    s.x += s.vx * dt;
    s.y += s.vy * dt;
    if (dist(s.x, s.y, S.hero.x, S.hero.y) < 17) {
      hurtHero(s.dmg); s.dead = true;
      boom(s.x, s.y, s.slime ? '#7cff4f' : '#ff1f1f', 5);
    } else if (S.engineer.active && S.engineer.hp > 0 && !S.aiEngineerOwned
               && dist(s.x, s.y, S.engineer.x, S.engineer.y) < 17) {
      // Only co-op P2 takes ranged fire — AI engineer is not a valid projectile target
      hurtEngineer(s.dmg); s.dead = true;
      boom(s.x, s.y, s.slime ? '#7cff4f' : '#8edcff', 5);
    }
    if (s.life <= 0) s.dead = true;
  }
  S.enemyShots = S.enemyShots.filter(s => !s.dead);
}

// ── Particles / floating text ─────────────────────────────────────
function boom(x, y, c, n = 12) {
  for (let i = 0; i < n; i++) {
    S.parts.push({ x, y, vx: (Math.random() - .5) * 200, vy: (Math.random() - .5) * 200, life: .45 + Math.random() * .35, c });
  }
}

function burst(x, y, c, n = 18, kind = 'spark', power = 220) {
  for (let i = 0; i < n; i++) {
    const a = Math.random() * Math.PI * 2;
    const sp = power * (.25 + Math.random() * .85);
    S.parts.push({ kind, x, y, vx: Math.cos(a) * sp, vy: Math.sin(a) * sp, life: .35 + Math.random() * .65, c, r: 2 + Math.random() * 4 });
  }
}

function shockwave(x, y, c, r = 70, life = .45) {
  S.parts.push({ kind: 'shockwave', x, y, r: 6, maxR: r, life, maxLife: life, c });
}

function impactFx(x, y, type = 'arrow') {
  if (type === 'poison') { burst(x, y, '#9bd34f', 5, 'bubble', 38); return; }
  if (type === 'fire')   { burst(x, y, '#f2a13a', 6, 'ember', 48); burst(x, y, '#4a3529', 2, 'smoke', 26); return; }
  if (type === 'ice')    { shockwave(x, y, '#bfefff', 30, .22); burst(x, y, '#e9fbff', 8, 'spark', 150); burst(x, y, '#8edcff', 4, 'bubble', 44); return; }
  if (type === 'lightning') { shockwave(x, y, '#b8a8ff', 42, .22); burst(x, y, '#d7c8ff', 10, 'spark', 180); return; }
  if (type === 'thunk') { shockwave(x, y, '#d7c8ff', 24, .18); burst(x, y, '#f6e7cf', 6, 'spark', 80); burst(x, y, '#8a6a43', 4, 'debris', 70); return; }
  if (type === 'explosion') { shockwave(x, y, '#ffcf6a', 150, .5); burst(x, y, '#c07a32', 42, 'debris', 260); burst(x, y, '#3a2a20', 18, 'smoke', 120); return; }
  if (type === 'slime')  { shockwave(x, y, '#5fd45a', 125, .55); burst(x, y, '#46b83b', 60, 'goo', 230); return; }
  burst(x, y, '#f7d38a', 8, 'spark', 140); burst(x, y, '#8a6a43', 5, 'debris', 100);
}

function destroyStructure(x, y, label = 'tower') {
  burst(x, y, label === 'barrier' ? '#9b6b37' : '#77706a', label === 'barrier' ? 26 : 30, 'debris', 210);
  burst(x, y, '#3a2514', 10, 'smoke', 85);
  shockwave(x, y, '#d0a35d', label === 'barrier' ? 44 : 52, .32);
}

function floatText(s, x, y, c) {
  S.texts.push({ s, x, y, c, life: 1 });
}

function announceWave(text, kind = 'normal', duration = 1) {
  S.waveBanner = text;
  S.waveBannerKind = kind;
  S.waveBannerTime = duration;
  const b = $('waveBanner');
  if (b) {
    b.textContent = text;
    b.className = `waveBanner show ${kind === 'boss' ? 'boss' : kind === 'danger' ? 'danger' : kind === 'resting' ? 'resting' : ''}`;
  }
}

function cleanParticles(dt) {
  for (const p of S.parts) {
    p.life -= dt; p.x += (p.vx || 0) * dt; p.y += (p.vy || 0) * dt;
  }
  S.parts = S.parts.filter(p => p.life > 0);
  for (const t of S.texts) {
    t.life -= dt; t.y -= 35 * dt;
  }
  S.texts = S.texts.filter(t => t.life > 0);
}

// ── Main game step ────────────────────────────────────────────────
function step(dt) {
  for (const fx of S.spawningActors) {
    fx.t = Math.max(0, fx.t - dt);
    fx.actor.inv = Math.max(fx.actor.inv || 0, fx.t);
    if (fx.t <= 0) finishPlayerSpawnIntro(fx.actor);
  }
  S.spawningActors = S.spawningActors.filter(fx => fx.t > 0);
  updateActiveTrinketEffects(dt);
  heroStep(dt);
  engineerStep(dt);
  if (S.bossIntro > 0) S.bossIntro = Math.max(0, S.bossIntro - dt);

  // Spawn from queue
  if (S.waveActive && S.queue.length) {
    S.timer -= dt;
    if (S.timer <= 0) {
      spawn(S.queue.shift());
      S.spawnCount++;
      S.timer = nextSpawnDelay();
    }
  }

  // Update towers
  for (const t of S.towers) towerTick(t, dt);

  // Update enemies
  for (const e of S.enemies) enemyStep(e, dt);

  // Clean destroyed entities; rebuild path if road changed
  const prevBarrierCount = S.barriers.length;
  const roadTowerDied    = S.towers.some(t => t.dead && t.onRoad);
  S.barriers = S.barriers.filter(b => !b.dead);
  S.towers   = S.towers.filter(t => !t.dead);
  if (prevBarrierCount !== S.barriers.length || roadTowerDied) rebuildPath();
  S.enemies  = S.enemies.filter(e => !e.dead);

  projectiles(dt);
  collectHealthOrbs(dt);

  // Decay oil patches
  S.oilPatches.forEach(o => o.life -= dt);
  S.oilPatches = S.oilPatches.filter(o => o.life > 0);
  const slimeBossAlive = S.enemies.some(e => e.type === 'slimeking' && !e.dead);
  S.firePatches.forEach(f => {
    if (f.slime && slimeBossAlive && S.bossActive) return;
    f.life -= dt;
  });
  S.firePatches = S.firePatches.filter(f => f.life > 0);

  cleanParticles(dt);

  if (S.waveBannerTime > 0) {
    S.waveBannerTime = Math.max(0, S.waveBannerTime - dt);
    if (S.waveBannerTime <= 0) {
      S.waveBanner = '';
      const b = $('waveBanner');
      if (b) b.className = 'waveBanner hidden';
    }
  }

  // Screen shake decay
  if (S.shakeTime > 0) { S.shakeTime -= dt; if (S.shakeTime < 0) { S.shakeTime = 0; S.shakeAmt = 0; } }

  // Boss spawn: after wave queue clears, if wave is multiple of 3
  if (S.waveActive && !S.queue.length && !S.enemies.length && S.wave % 3 === 0 && !S.bossSpawned) {
    spawnSlimeKing();
  }

  // Do not use paused=true for upgrade selection. It can block modal rendering.
  // This wave-end gate owns the between-wave upgrade flow and must show the modal before any new wave starts.
  // Harvest complete check
  if (S.waveActive && !S.queue.length && !S.enemies.length) {
    finishWave();
    return; // ui() already called above for wave-clear
  }

  // Batch UI update once per step (handles gold/score from kills this frame)
  syncDevGold();
  ui();
}

// ── Draw routines ──────────────────────────────────────────────────
function draw(t) {
  // Hotbar status and weapon secondary labels need per-frame updates for smooth cooldown animation.
  renderBuildButtons();
  renderAbilityButtons();
  renderWaveBanner();
  ctx.clearRect(0, 0, W, H);
  updateCamera();

  // Screen shake
  if (S.shakeTime > 0) {
    const s = S.shakeAmt * (S.shakeTime / .5);
    ctx.save();
    ctx.translate((Math.random() - .5) * s, (Math.random() - .5) * s);
  }

  ctx.save();
  ctx.translate(-CAMERA.x, -CAMERA.y);
  drawMap(t);
  if (S.hero.lastStandBeaconActive) {
    const gx = cx(GOAL.c) + 30, gy = cy(GOAL.r);
    ctx.save();
    ctx.globalAlpha = .45 + Math.sin(t * 8) * .12;
    ctx.strokeStyle = '#8edcff';
    ctx.lineWidth = 5;
    ctx.beginPath(); ctx.arc(gx, gy, 86 + Math.sin(t * 5) * 4, 0, 7); ctx.stroke();
    ctx.globalAlpha = .16;
    ctx.fillStyle = '#f0c96b';
    ctx.beginPath(); ctx.arc(gx, gy, 42 + Math.sin(t * 4) * 2, 0, 7); ctx.fill();
    ctx.restore();
  }
  if ((S.mods.riftShieldUntil || 0) > performance.now() / 1000) {
    const gx = cx(GOAL.c) + 30, gy = cy(GOAL.r);
    ctx.save();
    ctx.globalCompositeOperation = 'screen';
    ctx.globalAlpha = .48 + Math.sin(t * 9) * .1;
    ctx.strokeStyle = '#8edcff';
    ctx.lineWidth = 6;
    ctx.beginPath(); ctx.arc(gx, gy, 92 + Math.sin(t * 6) * 4, 0, 7); ctx.stroke();
    ctx.globalAlpha = .22;
    ctx.fillStyle = '#8edcff';
    ctx.beginPath(); ctx.arc(gx, gy, 54 + Math.sin(t * 4) * 2, 0, 7); ctx.fill();
    ctx.restore();
  }

  // Oil patches
  for (const o of S.oilPatches) {
    ctx.globalAlpha = Math.max(0, o.life / 7) * .38;
    ctx.fillStyle   = '#1e1710';
    ctx.beginPath(); ctx.arc(o.x, o.y, o.r, 0, 7); ctx.fill();
    ctx.globalAlpha = 1;
  }
  for (const f of S.firePatches) {
    const a = Math.max(0, f.life / (f.maxLife || 5.5));
    if (f.slime) {
      ctx.globalAlpha = a * .38;
      ctx.fillStyle   = '#3fd948';
      ctx.beginPath(); ctx.arc(f.x, f.y, f.r, 0, 7); ctx.fill();
      ctx.globalAlpha = a * .72;
      ctx.strokeStyle = '#b8ff7a';
      ctx.lineWidth   = 3;
      ctx.beginPath(); ctx.arc(f.x, f.y, f.r * (.88 + Math.sin(t * 8 + f.x) * .04), 0, 7); ctx.stroke();
      continue;
    }
    ctx.globalAlpha = a * .34;
    ctx.fillStyle   = '#c01818';
    ctx.beginPath(); ctx.arc(f.x, f.y, f.r, 0, 7); ctx.fill();
    ctx.globalAlpha = a * .62;
    ctx.strokeStyle = '#ff8a2a';
    ctx.lineWidth   = 3;
    ctx.beginPath(); ctx.arc(f.x, f.y, f.r * (.86 + Math.sin(t * 8 + f.x) * .04), 0, 7); ctx.stroke();
    ctx.globalAlpha = 1;
  }

  S.healthOrbs.forEach(o => drawHealthOrb(o, t));
  S.barriers.forEach(drawBarrier);
  S.barrels.forEach((b, _) => drawBarrel(b, t));
  S.towers.forEach(tw => drawTower(tw, t));
  S.shots.forEach(s => drawTowerShot(s, s.d.fill));
  S.heroShots.forEach(s => {
    const frenzyActive = S.mods.frenzyUntil > t;
    const c = s.p2 ? '#8edcff'
      : frenzyActive ? '#ffe56b'
      : s.type === 'arrow' ? '#bfe7ff'
      : s.type === 'chargedArrow' ? '#7fd0ff'
      : s.type === 'bolt' ? '#ffad66'
      : s.type === 'stunBolt' ? '#ffd07a'
      : s.type === 'iceShard' ? '#d8f2ff'
      : s.blunder ? '#fff3b2'
      : s.weapon === 'storm' ? '#ffe56b'
      : '#18a8ff';
    drawArrow(s, c, !!s.electric || s.type === 'stunBolt' || s.type === 'chargedArrow' || s.blunder);
  });
  S.enemyShots.forEach(s => drawArrow(s, s.slime ? '#7cff4f' : '#ff3030', s.slime));
  S.enemies.forEach(drawEnemy);
  drawSpawnIntros(t);
  drawEngineer(t);
  drawHero(t);
  S.parts.forEach(drawParticle);

  // Floating text
  for (const q of S.texts) {
    ctx.globalAlpha = q.life;
    ctx.fillStyle   = q.c;
    ctx.font        = 'bold 15px Georgia';
    ctx.fillText(q.s, q.x, q.y);
    ctx.globalAlpha = 1;
  }

  // Build placement preview
  if (S.phase === 'build' && S.selected && !S.sel) {
    const m = getMouseWorldPosition();
    const snap = getSnappedBuildTile(m.x, m.y);
    const ok = canBuild(m.x, m.y);
    const d  = TOWERS[S.selected];
    ctx.globalAlpha = .32;
    ctx.fillStyle   = ok ? '#18a8ff' : '#9c2f22';
    ctx.beginPath();
    ctx.arc(snap.x, snap.y, S.selected === 'barrier' || S.selected === 'barrel' ? 26 : d.r, 0, 7);
    ctx.fill();
    if (d && (d.directional || S.selected === 'tar')) {
      const ang = DIR_ANGLES[S.placeDir ?? 0];
      const ax = snap.x + Math.cos(ang) * 30;
      const ay = snap.y + Math.sin(ang) * 30;
      ctx.globalAlpha = 1;
      ctx.strokeStyle = '#ffe09c'; ctx.lineWidth = 5;
      ctx.beginPath(); ctx.moveTo(snap.x, snap.y); ctx.lineTo(ax, ay); ctx.stroke();
      ctx.fillStyle = '#ffe09c';
      ctx.beginPath();
      ctx.moveTo(ax, ay);
      ctx.lineTo(ax - Math.cos(ang - .55) * 13, ay - Math.sin(ang - .55) * 13);
      ctx.lineTo(ax - Math.cos(ang + .55) * 13, ay - Math.sin(ang + .55) * 13);
      ctx.closePath(); ctx.fill();
      ctx.fillStyle = '#fff4d0';
      ctx.font = 'bold 11px Georgia';
      ctx.fillText(`Facing ${DIR_LABELS[S.placeDir ?? 0]}`, snap.x - 28, snap.y - 28);
    } else if (S.selected === 'tar') {
      ctx.globalAlpha = 1;
      ctx.fillStyle = '#4a3724';
      ctx.fillRect(snap.x - 18, snap.y - 12, 36, 24);
      ctx.strokeStyle = '#ffe09c'; ctx.lineWidth = 3;
      ctx.strokeRect(snap.x - 18, snap.y - 12, 36, 24);
      ctx.fillStyle = '#16110c';
      ctx.beginPath(); ctx.arc(snap.x, snap.y, 8, 0, 7); ctx.fill();
      ctx.fillStyle = '#ffe09c';
      ctx.font = 'bold 11px Georgia';
      ctx.fillText('Push Wall', snap.x - 20, snap.y - 28);
    }
    ctx.globalAlpha = 1;
  }

  ctx.restore();
  drawAtmosphere(t);

  // Pause overlay
  if (S.paused && $('clear').classList.contains('hidden')) {
    ctx.fillStyle = '#0009';
    ctx.fillRect(0, 0, W, H);
    ctx.fillStyle = '#ffe19b';
    ctx.font      = 'bold 54px Georgia';
    ctx.textAlign = 'center';
    ctx.fillText('PAUSED', W / 2, H / 2);
    ctx.textAlign = 'left';
  }

  if (S.shakeTime > 0) ctx.restore();
}


function drawAtmosphere(t) {
  // Portal glow
  ctx.save();
  ctx.globalCompositeOperation = 'lighter';
  for (const sp of SPAWN_POINTS) {
    const sx = cx(sp.c) - 27 - CAMERA.x, sy = cy(sp.r) - CAMERA.y;
    const pg = ctx.createRadialGradient(sx, sy, 4, sx, sy, 85 + Math.sin(t * 4 + sp.r) * 8);
    pg.addColorStop(0, 'rgba(107,182,216,0.28)');
    pg.addColorStop(1, 'rgba(107,182,216,0)');
    ctx.fillStyle = pg; ctx.beginPath(); ctx.arc(sx, sy, 92, 0, 7); ctx.fill();
  }
  // Torch glow near keep
  const glows = [{x:cx(GOAL.c)-12-CAMERA.x,y:cy(GOAL.r)-39-CAMERA.y},{x:cx(GOAL.c)+62-CAMERA.x,y:cy(GOAL.r)-39-CAMERA.y}];
  for (const g of glows) {
    const tg = ctx.createRadialGradient(g.x, g.y, 2, g.x, g.y, 78 + Math.sin(t * 7 + g.x) * 6);
    tg.addColorStop(0, 'rgba(255,210,120,0.42)');
    tg.addColorStop(1, 'rgba(255,120,20,0)');
    ctx.fillStyle = tg; ctx.beginPath(); ctx.arc(g.x, g.y, 82, 0, 7); ctx.fill();
  }
  ctx.restore();

  // Dust motes, intentionally subtle
  ctx.globalAlpha = .16;
  ctx.fillStyle = '#ead7aa';
  for (let i = 0; i < 22; i++) {
    const x = (i * 137 + t * 18) % W;
    const y = (i * 73 + Math.sin(t + i) * 18) % H;
    ctx.beginPath(); ctx.arc(x, y, 1.2, 0, 7); ctx.fill();
  }
  ctx.globalAlpha = 1;

  // Escalation ash: later waves look harsher without reducing readability
  const pressure = Math.min(.22, S.wave * .012);
  if (pressure > 0) {
    ctx.fillStyle = `rgba(70,32,18,${pressure})`;
    ctx.fillRect(0, 0, W, H);
  }

  // Low-health warning, subtle heartbeat edge pulse
  const hpPct = S.hero.hp / S.hero.max;
  if (hpPct > 0 && hpPct < .25 && S.phase === 'combat') {
    const pulse = .12 + Math.sin(t * 9) * .05;
    const vg = ctx.createRadialGradient(W/2, H/2, Math.min(W,H)*.25, W/2, H/2, Math.max(W,H)*.62);
    vg.addColorStop(0, 'rgba(0,0,0,0)');
    vg.addColorStop(1, `rgba(145,18,12,${pulse})`);
    ctx.fillStyle = vg;
    ctx.fillRect(0, 0, W, H);
  }

  // Wave-clear warmth pulse
  if (S.clearFlash > 0) {
    ctx.fillStyle = `rgba(255,177,72,${Math.min(.22, S.clearFlash * .22)})`;
    ctx.fillRect(0, 0, W, H);
  }

  // Boss intro tint and title card
  if (S.bossIntro > 0) {
    const a = Math.min(.50, S.bossIntro / 1.35 * .50);
    ctx.fillStyle = `rgba(22,55,18,${a})`;
    ctx.fillRect(0, 0, W, H);
    ctx.globalAlpha = .55;
    ctx.fillStyle = '#4fa34f33';
    ctx.beginPath(); ctx.arc(W/2, H*.28, 92 + Math.sin(t*8)*8, 0, 7); ctx.fill();
    ctx.globalAlpha = 1;
    ctx.fillStyle = '#f0c96b';
    ctx.font = 'bold 46px Georgia';
    ctx.textAlign = 'center';
    ctx.fillText('THE SLIME KING STIRS', W / 2, H * .28);
    ctx.font = 'bold 30px Georgia';
    ctx.fillText('♛', W / 2, H * .28 - 48);
    ctx.textAlign = 'left';
  }

  // Vignette, not too dark
  const grad = ctx.createRadialGradient(W/2, H/2, 140, W/2, H/2, Math.max(W, H) * .72);
  grad.addColorStop(0, 'rgba(0,0,0,0)');
  grad.addColorStop(1, 'rgba(21,12,7,0.42)');
  ctx.fillStyle = grad;
  ctx.fillRect(0, 0, W, H);
}

function drawMap(t) {
  // Fortress board background
  ctx.fillStyle = '#0f1820';
  ctx.fillRect(OX - 18, OY - 18, COLS * G + 36, ROWS * G + 36);

  const frameX = OX - 18, frameY = OY - 18;
  const frameW = COLS * G + 36, frameH = ROWS * G + 36;
  ctx.fillStyle = '#1c2630';
  ctx.fillRect(frameX, frameY, frameW, frameH);
  ctx.strokeStyle = '#9d7643'; ctx.lineWidth = 4;
  ctx.strokeRect(frameX + 1, frameY + 1, frameW - 2, frameH - 2);
  ctx.strokeStyle = '#2b3844'; ctx.lineWidth = 2;
  ctx.strokeRect(frameX + 8, frameY + 8, frameW - 16, frameH - 16);

  // Stone floor outside the grid
  const dirt = ctx.createLinearGradient(0, OY, 0, OY + ROWS * G);
  dirt.addColorStop(0, '#586571');
  dirt.addColorStop(1, '#3a444d');
  ctx.fillStyle = dirt;
  ctx.fillRect(OX - 12, OY - 12, COLS * G + 24, ROWS * G + 24);

  for (let c = 0; c < COLS; c++) {
    for (let r = 0; r < ROWS; r++) {
      const x = OX + c * G, y = OY + r * G;
      const n = Math.sin(c * 12.989 + r * 78.233) * 43758.5453;
      const v = n - Math.floor(n);
      if (isRoad(c, r)) {
        // Warm bridge / worn stone path
        ctx.fillStyle = v > .66 ? '#e1d6be' : v > .33 ? '#d2c4a8' : '#c0b08f';
        ctx.fillRect(x, y, G, G);
        ctx.strokeStyle = '#9a8c70';
        ctx.lineWidth = 1;
        ctx.strokeRect(x + .5, y + .5, G - 1, G - 1);
        // Cobble seams
        ctx.strokeStyle = '#6f624bcc';
        ctx.beginPath();
        ctx.moveTo(x + 6, y + G * .48); ctx.lineTo(x + G - 6, y + G * .44);
        ctx.moveTo(x + G * .48, y + 5); ctx.lineTo(x + G * .52, y + G - 5);
        ctx.stroke();
        // Cracks and moss
        if (v > .72) {
          ctx.strokeStyle = '#907f62aa';
          ctx.beginPath();
          ctx.moveTo(x + 9, y + 12); ctx.lineTo(x + 18, y + 17); ctx.lineTo(x + 23, y + 31);
          ctx.stroke();
        }
        if (v < .12) {
          ctx.fillStyle = '#7fb0ad88';
          ctx.fillRect(x + 3, y + G - 7, 14, 3);
          ctx.fillRect(x + G - 14, y + 4, 9, 2);
        }
        // Dirt wear down middle
        ctx.globalAlpha = .18;
        ctx.fillStyle = '#b29c71';
        ctx.beginPath(); ctx.ellipse(x + G / 2, y + G / 2, 18, 10, .15, 0, 7); ctx.fill();
        ctx.globalAlpha = 1;
      } else if (isBlockedTerrain(c, r)) {
        // Impassable machinery / void
        ctx.fillStyle = v > .55 ? '#14181d' : '#0a0d11';
        ctx.fillRect(x, y, G, G);
        ctx.strokeStyle = '#030405';
        ctx.strokeRect(x + .5, y + .5, G - 1, G - 1);
        ctx.fillStyle = '#222933';
        ctx.fillRect(x + 4, y + 4, G - 8, G - 8);
        ctx.strokeStyle = '#56616a';
        ctx.strokeRect(x + 7, y + 7, G - 14, G - 14);
        ctx.fillStyle = '#090b0e';
        ctx.beginPath(); ctx.moveTo(x + 6, y + 6); ctx.lineTo(x + G - 6, y + G - 6); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(x + G - 6, y + 6); ctx.lineTo(x + 6, y + G - 6); ctx.stroke();
      } else {
        // Cool neutral floor / platform
        ctx.fillStyle = v > .55 ? '#4b545d' : '#3b434b';
        ctx.fillRect(x, y, G, G);
        ctx.strokeStyle = '#212931';
        ctx.strokeRect(x + .5, y + .5, G - 1, G - 1);
        if (v < .18) {
          ctx.fillStyle = '#86a6b366';
          ctx.beginPath(); ctx.arc(x + 12, y + 30, 5, 0, 7); ctx.fill();
        }
      }
    }
  }

  // Fortress gate / village keep
  const gx = cx(GOAL.c) + 30, gy = cy(GOAL.r);
  ctx.fillStyle = '#161e25';
  ctx.fillRect(gx - 58, gy - 64, 104, 128);
  ctx.fillStyle = '#d4c4a1';
  ctx.fillRect(gx - 52, gy - 58, 92, 116);
  ctx.strokeStyle = '#3a2c20'; ctx.lineWidth = 4;
  ctx.strokeRect(gx - 52, gy - 58, 92, 116);
  // Door
  ctx.fillStyle = '#5b3d22';
  ctx.fillRect(gx - 24, gy - 36, 42, 76);
  ctx.strokeStyle = '#1d120b'; ctx.lineWidth = 3;
  ctx.strokeRect(gx - 24, gy - 36, 42, 76);
  ctx.strokeStyle = '#1d120b';
  for (let i = -16; i <= 10; i += 13) { ctx.beginPath(); ctx.moveTo(gx + i, gy - 34); ctx.lineTo(gx + i, gy + 38); ctx.stroke(); }
  ctx.fillStyle = '#948a7b';
  ctx.fillRect(gx - 28, gy - 22, 50, 7);
  ctx.fillRect(gx - 28, gy + 13, 50, 7);
  // Battlements
  ctx.fillStyle = '#847c73';
  for (let i = -52; i <= 28; i += 20) ctx.fillRect(gx + i, gy - 72, 14, 18);
  // Torches
  for (const tx of [gx - 42, gx + 32]) {
    ctx.fillStyle = '#2a160d'; ctx.fillRect(tx - 3, gy - 33, 6, 24);
    ctx.fillStyle = '#f2a13a';
    ctx.beginPath(); ctx.ellipse(tx, gy - 39, 6 + Math.sin(t * 9 + tx) * 1.2, 12, 0, 0, 7); ctx.fill();
    ctx.fillStyle = '#ffe4a0'; ctx.beginPath(); ctx.arc(tx, gy - 42, 3, 0, 7); ctx.fill();
  }

  // Spawn portals as occult summoning circles
  for (const sp of SPAWN_POINTS) {
    const sx = cx(sp.c) - 27, sy = cy(sp.r);
    ctx.save(); ctx.translate(sx, sy); ctx.rotate(t * .35 + sp.r);
    ctx.strokeStyle = '#7ac6e8'; ctx.lineWidth = 2;
    ctx.beginPath(); ctx.arc(0, 0, 18, 0, 7); ctx.stroke();
    ctx.beginPath();
    for (let i = 0; i < 6; i++) {
      const a = i * Math.PI / 3;
      ctx.lineTo(Math.cos(a) * 15, Math.sin(a) * 15);
    }
    ctx.closePath(); ctx.stroke();
    ctx.fillStyle = '#6bb6d855';
    ctx.beginPath(); ctx.arc(0, 0, 8 + Math.sin(t * 5 + sp.r) * 2, 0, 7); ctx.fill();
    ctx.restore();
  }

  drawFortressDressing(t);

}

function drawFortressDressing(t) {
  ctx.save();
  const frameX = OX - 18, frameY = OY - 18;
  const frameW = COLS * G + 36, frameH = ROWS * G + 36;

  // Outer wall blocks and crenellations.
  ctx.fillStyle = '#263039';
  ctx.strokeStyle = '#0d1115';
  ctx.lineWidth = 2;
  for (let x = frameX + 16; x < frameX + frameW - 12; x += 38) {
    ctx.fillRect(x, frameY - 12, 24, 14);
    ctx.strokeRect(x, frameY - 12, 24, 14);
    ctx.fillRect(x, frameY + frameH - 2, 24, 14);
    ctx.strokeRect(x, frameY + frameH - 2, 24, 14);
  }
  for (let y = frameY + 18; y < frameY + frameH - 12; y += 42) {
    ctx.fillRect(frameX - 12, y, 14, 24);
    ctx.strokeRect(frameX - 12, y, 14, 24);
    ctx.fillRect(frameX + frameW - 2, y, 14, 24);
    ctx.strokeRect(frameX + frameW - 2, y, 14, 24);
  }

  // Red fortress banners.
  const banners = [
    [frameX + 58, frameY + 4, 1],
    [frameX + frameW - 70, frameY + 4, -1],
    [frameX + 42, frameY + frameH - 52, 1],
    [frameX + frameW - 54, frameY + frameH - 52, -1],
  ];
  for (const [x, y, dir] of banners) {
    ctx.fillStyle = '#35110c';
    ctx.fillRect(x - 3, y - 4, 6, 54);
    ctx.fillStyle = '#8f2419';
    ctx.beginPath();
    ctx.moveTo(x, y);
    ctx.lineTo(x + dir * 30, y + 7);
    ctx.lineTo(x + dir * 24, y + 26);
    ctx.lineTo(x + dir * 30, y + 43);
    ctx.lineTo(x, y + 36);
    ctx.closePath();
    ctx.fill();
    ctx.strokeStyle = '#d0a35d';
    ctx.lineWidth = 2;
    ctx.stroke();
  }

  // Braziers around the killbox edges.
  const braziers = [
    [frameX + 24, frameY + 24], [frameX + frameW - 24, frameY + 24],
    [frameX + 24, frameY + frameH - 24], [frameX + frameW - 24, frameY + frameH - 24],
  ];
  for (const [x, y] of braziers) {
    ctx.fillStyle = '#1a100a';
    ctx.fillRect(x - 8, y + 6, 16, 8);
    ctx.fillStyle = '#6c4b2c';
    ctx.fillRect(x - 10, y + 2, 20, 8);
    ctx.fillStyle = '#f07b25';
    ctx.beginPath(); ctx.ellipse(x, y, 6 + Math.sin(t * 10 + x) * 1.2, 13, 0, 0, 7); ctx.fill();
    ctx.fillStyle = '#ffe4a0';
    ctx.beginPath(); ctx.arc(x, y - 3, 3, 0, 7); ctx.fill();
  }

  // Cyan ward runes along the road.
  ctx.strokeStyle = '#74dcff88';
  ctx.lineWidth = 2;
  const runeCells = Array.from(road).map(v => {
    const [c, r] = v.split(',').map(Number);
    return { c, r };
  }).filter((_, i) => i % 9 === 3);
  for (const cell of runeCells) {
    const x = cx(cell.c), y = cy(cell.r);
    ctx.save();
    ctx.translate(x, y);
    ctx.rotate(t * .35 + cell.c);
    ctx.globalAlpha = .38 + Math.sin(t * 4 + cell.r) * .08;
    ctx.strokeRect(-7, -7, 14, 14);
    ctx.beginPath(); ctx.moveTo(-10, 0); ctx.lineTo(10, 0); ctx.moveTo(0, -10); ctx.lineTo(0, 10); ctx.stroke();
    ctx.restore();
  }
  ctx.globalAlpha = 1;
  ctx.restore();
}

function drawBarrier(b) {
  ctx.fillStyle = '#0006';
  ctx.fillRect(b.x - 21, b.y - 16, 44, 36);
  ctx.fillStyle = '#5a3a22';
  ctx.fillRect(b.x - 22, b.y - 18, 44, 36);
  ctx.strokeStyle = '#1c120b'; ctx.lineWidth = 3;
  ctx.strokeRect(b.x - 22, b.y - 18, 44, 36);
  // stone blocks
  ctx.fillStyle = '#77706a';
  ctx.fillRect(b.x - 20, b.y + 2, 18, 14);
  ctx.fillRect(b.x + 2, b.y + 2, 18, 14);
  // crossed timber
  ctx.strokeStyle = '#2b160b'; ctx.lineWidth = 5;
  ctx.beginPath(); ctx.moveTo(b.x - 19, b.y + 14); ctx.lineTo(b.x + 19, b.y - 14); ctx.moveTo(b.x - 19, b.y - 11); ctx.lineTo(b.x + 19, b.y + 11); ctx.stroke();
