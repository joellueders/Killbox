      break;
    case 'rift':
      playSfx('pickupShield');
      shockwave(x, y, '#8edcff', 130, .38);
      burst(x, y, '#8edcff', 18, 'spark', 170);
      break;
  }
}

function collectHealthOrbs(dt) {
  for (const o of S.healthOrbs) {
    if (!o.full) o.life -= dt;
    if (dist(o.x, o.y, S.hero.x, S.hero.y) < o.r + (o.full ? 34 : 18)) {
      const type = o.full ? 'health' : (o.type || 'health');
      if (type === 'gold') {
        const gold = o.gold || 120;
        S.gold += gold;
        if (S.waveStats) S.waveStats.goldEarned += gold;
        if (S.runStats) S.runStats.goldEarned += gold;
        floatText('GOLD CACHE', o.x - 30, o.y - 26, '#f4c24f');
        floatText('+' + gold + 'g', o.x - 20, o.y - 8, '#fff0b8');
      } else if (type === 'frenzy') {
        const now = performance.now() / 1000;
        S.mods.frenzyUntil = Math.max(S.mods.frenzyUntil || 0, now + (o.frenzy || 8));
        floatText('FRENZY', o.x - 26, o.y - 14, '#ff6d3a');
      } else if (type === 'haste') {
        const now = performance.now() / 1000;
        S.mods.hasteUntil = Math.max(S.mods.hasteUntil || 0, now + (o.haste || 8));
        floatText('HASTE', o.x - 22, o.y - 14, '#6ad6ff');
      } else if (type === 'freeze') {
        const radius = 200;
        for (const e of S.enemies) {
          if (e.dead) continue;
          const d = dist(o.x, o.y, e.x, e.y);
          if (d > radius) continue;
          e.chill = Math.max(e.chill || 0, 10);
          if (e.type !== 'slimeking') e.freeze = Math.max(e.freeze || 0, 3.4);
          e.slow = Math.max(e.slow || 0, .45);
        }
        floatText('FREEZE BURST', o.x - 36, o.y - 14, '#9fe8ff');
      } else if (type === 'bomb') {
        const radius = 180;
        for (const e of S.enemies) {
          if (e.dead) continue;
          const d = dist(o.x, o.y, e.x, e.y);
          if (d > radius) continue;
          hit(e, Math.max(80, (o.bomb || 300) * (1 - d / radius)), null);
        }
        floatText('BOMB!', o.x - 18, o.y - 14, '#ff9b32');
        impactFx(o.x, o.y, 'explosion');
      } else if (type === 'reset') {
        const now = performance.now() / 1000;
        for (const tr of Object.values(TRINKETS)) tr.lastUsed = -99999;
        floatText('TRINKETS READY!', o.x - 48, o.y - 18, '#ead4ff');
        floatText('RESET!', o.x - 18, o.y + 2, '#c78cff');
      } else if (type === 'rift') {
        const now = performance.now() / 1000;
        S.mods.riftShieldUntil = Math.max(S.mods.riftShieldUntil || 0, now + (o.rift || 8));
        floatText('RIFT SHIELD', o.x - 34, o.y - 14, '#8edcff');
      } else {
        const amt = o.full ? S.hero.max : (o.hp || Math.floor(S.hero.max * .45));
        S.hero.hp = o.full ? S.hero.max : Math.min(S.hero.max, S.hero.hp + amt);
        floatText(o.full ? 'FULL HEAL' : 'HEALTH FLASK', o.x - (o.full ? 28 : 34), o.y - 28, o.full ? '#ffe09c33' : '#b9d84f');
        floatText('+' + (o.full ? S.hero.max : amt) + ' HP', o.x - 22, o.y - 10, '#d5ef7d');
      }
      playPickupFeedback(type, o.x, o.y);
      o.dead = true;
      if (S.waveStats) S.waveStats.powerups++;
      if (S.runStats) S.runStats.powerups++;
      boom(o.x, o.y, powerupColor(type, o.full), o.full ? 30 : 14);
      ui();
    }
  }
  S.healthOrbs = S.healthOrbs.filter(o => !o.dead && o.life > 0);
}

function renderWaveSummary(bonus, interest) {
  const s = S.waveStats || {};
  s.bonusGold = bonus;
