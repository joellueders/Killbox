.gameSpeedToggle:hover, .legendToggle:hover { filter: brightness(1.12); }
.inlineSpeed { width: 100%; justify-content: center; text-align: center; }
.enemyCard {
  background: linear-gradient(#2b1c13dd, #100b08ee); border: 1px solid #9d6a35; border-radius: 9px;
  padding: 6px; font-size: 11px; line-height: 1.2;
  display: grid; grid-template-columns: 34px 1fr; gap: 5px; align-items: center;
  box-shadow: inset 0 0 0 1px #0008, 0 4px 12px #0008;
}
.enemyIcon {
  width: 30px; height: 30px; border-radius: 50%;
  border: 2px solid #1e1008; box-sizing: border-box;
  position: relative; margin: auto;
  background: #6d3f2a;
  box-shadow: inset -5px -6px 0 #0003;
}
.enemyIcon::before, .enemyIcon::after { content: ""; position: absolute; box-sizing: border-box; }
/* Raider / peasant marauder: hood, face, pitchfork */
.enemyIcon.grunt { background: #8a5630; border-radius: 45% 45% 52% 52%; }
.enemyIcon.grunt::before { left: 6px; top: 4px; width: 14px; height: 12px; background: #3c2417; clip-path: polygon(50% 0,100% 72%,0 72%); }
.enemyIcon.grunt::after { right: -6px; top: 5px; width: 12px; height: 20px; border-right: 2px solid #d8b26b; border-top: 2px solid #d8b26b; border-bottom: 2px solid #d8b26b; }
/* Runner: small scarecrow freak with long legs */
.enemyIcon.runner { background: #b8862e; width: 24px; height: 24px; border-radius: 45% 45% 40% 40%; transform: translateY(-2px); }
.enemyIcon.runner::before { left: 4px; top: -5px; width: 16px; height: 8px; background: #3a2418; clip-path: polygon(0 70%,50% 0,100% 70%); }
.enemyIcon.runner::after { left: 3px; bottom: -10px; width: 18px; height: 12px; border-left: 3px solid #2b1a10; border-right: 3px solid #2b1a10; }
/* Slinger: skirmisher with raised throwing arm */
.enemyIcon.slinger { background: #5d7344; border-radius: 45%; }
.enemyIcon.slinger::before { right: -9px; top: 1px; width: 15px; height: 15px; border: 3px solid #d6b475; border-left: 0; border-bottom: 0; border-radius: 50%; transform: rotate(-20deg); }
.enemyIcon.slinger::after { right: -11px; top: -2px; width: 7px; height: 7px; background: #9c8c75; border-radius: 50%; }
/* Brute: butcher apron and cleaver */
.enemyIcon.brute { background: #7a382a; width: 34px; height: 34px; border-radius: 40%; }
.enemyIcon.brute::before { left: 9px; top: 7px; width: 15px; height: 20px; background: #d8c9aa; border-radius: 2px 2px 8px 8px; opacity: .9; }
.enemyIcon.brute::after { right: -8px; top: 4px; width: 10px; height: 17px; background: #c7c0b0; clip-path: polygon(30% 0,100% 15%,75% 100%,0 85%); }
/* Ogre: hulking ranged crusher */
.enemyIcon.ogre { background: #4e3628; width: 38px; height: 38px; border-radius: 42%; }
.enemyIcon.ogre::before { left: 7px; top: 7px; width: 24px; height: 7px; border-left: 7px solid #d8c9aa; border-right: 7px solid #d8c9aa; }
.enemyIcon.ogre::after { right: -8px; top: 15px; width: 20px; height: 6px; background: #8a6a44; transform: rotate(12deg); }
/* Saboteur / stalker: dark hood and red knife */
.enemyIcon.hunter { background: #211512; box-shadow: 0 0 0 3px #9d2d27, inset -5px -6px 0 #0005; }
.enemyIcon.hunter::before { left: 7px; top: 4px; width: 16px; height: 17px; background: #050303; clip-path: polygon(50% 0,100% 55%,75% 100%,25% 100%,0 55%); }
.enemyIcon.hunter::after { right: -7px; top: 10px; width: 14px; height: 4px; background: #dc513d; transform: rotate(-30deg); }
/* Bomber: powder lunatic with explosive payload */
.enemyIcon.bomber { background: #d8a73a; box-shadow: 0 0 0 3px #9e1f1f, inset -5px -6px 0 #0003; }
.enemyIcon.bomber::before { left: 8px; top: 8px; width: 15px; height: 15px; background: #4b2a19; border-radius: 50%; border: 2px solid #c44; }
.enemyIcon.bomber::after { left: 21px; top: 0; width: 10px; height: 10px; border-top: 2px solid #ffe09c33; border-right: 2px solid #ffe09c33; border-radius: 50%; }
/* Shield bearer: blue shield silhouette */
.enemyIcon.shield { background: #2f4f74; border-radius: 44%; }
.enemyIcon.shield::before { left: 5px; top: 4px; width: 19px; height: 22px; background: #9fc0c8; clip-path: polygon(50% 0,95% 18%,80% 82%,50% 100%,20% 82%,5% 18%); }
.enemyIcon.shield::after { left: 14px; top: 6px; width: 3px; height: 19px; background: #2f4f74aa; }
/* Plague monk / cult healer */
.enemyIcon.healer { background: #e3d8a7; box-shadow: 0 0 0 3px #5f8f45, inset -5px -6px 0 #0002; }
.enemyIcon.healer::before { left: 6px; top: 2px; width: 18px; height: 23px; background: #6f5b35; clip-path: polygon(50% 0,100% 42%,75% 100%,25% 100%,0 42%); }
.enemyIcon.healer::after { left: 13px; top: 9px; width: 4px; height: 13px; background: #b9d84f; box-shadow: -5px 5px 0 -1px #b9d84f, 5px 5px 0 -1px #b9d84f; }
/* Siege ram beast */
.enemyIcon.siege { background: #3b2a20; width: 40px; height: 32px; border-radius: 10px; }
.enemyIcon.siege::before { left: 4px; top: 10px; width: 31px; height: 8px; background: #77706a; border-radius: 999px; }
.enemyIcon.siege::after { right: -6px; top: 8px; width: 12px; height: 12px; border-top: 4px solid #d8c9aa; border-right: 4px solid #d8c9aa; transform: rotate(45deg); }
/* Grotesque crowned slime */
.enemyIcon.slimeking { background: #4fa34f33; width: 42px; height: 35px; border-radius: 45% 45% 55% 55%; box-shadow: 0 0 0 3px #b9d84f, inset -6px -8px 0 #1c5d28aa; }
.enemyIcon.slimeking::before { left: 8px; top: -8px; width: 24px; height: 12px; background: #d9c44a; clip-path: polygon(0 100%,12% 25%,30% 100%,50% 0,70% 100%,88% 25%,100% 100%); }
.enemyIcon.slimeking::after { left: 9px; top: 12px; width: 24px; height: 6px; border-left: 5px solid #183b18; border-right: 5px solid #183b18; border-radius: 50%; }
.enemyText b    { display: block; color: var(--gold); font-size: 12px; }
.enemyText span { display: block; color: #f0ddba; }


/* 3.7.1 legend pass: larger fantasy silhouettes, collapsed by default */
.enemyIcon { width: 32px; height: 32px; overflow: visible; }
