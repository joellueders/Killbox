  ctx.fillStyle = '#8edcff'; ctx.font = 'bold 11px Georgia'; ctx.fillText('P2', e.x - 9, e.y - 38);
}

function drawHero(t) {
  const h = S.hero;
  if (h.spawnState === 'spawning') return;
  const m = getMouseWorldPosition();
  const a = Math.atan2(m.y - h.y, m.x - h.x);
  const w = WEAPONS[h.weapon] || WEAPONS.blunderbuss;
  const now = performance.now() / 1000;
  const blunderShieldActive = h.weapon === 'blunderbuss' && (h.blunderShieldUntil || 0) > now;
  const slimeActive = (h.slimeDebuffUntil || 0) > now;
  const recoil = (h.weapon === 'blunderbuss' ? (h.weaponRecoil || 0) : 0);

  ctx.save();
  ctx.translate(h.x - Math.cos(a) * recoil * 10, h.y - Math.sin(a) * recoil * 10);
  ctx.rotate(a);
  ctx.globalAlpha = h.inv > 0 && Math.floor(t * 18) % 2 ? .45 : 1;
  const slimeTint = slimeActive
    ? { cloak: '#335a1f', body: '#7cff4f', face: '#d7ff7f', accent: '#bfffb0', gun: '#4db533', gunHi: '#d4ff8a' }
    : null;
  // cloak shadow
  ctx.fillStyle = slimeActive ? slimeTint.cloak : '#1d1711';
  ctx.beginPath(); ctx.ellipse(-3, 3, 17, 14, 0, 0, 7); ctx.fill();
  // body
  ctx.fillStyle = slimeActive ? slimeTint.body : '#31543b';
  ctx.beginPath(); ctx.moveTo(16, 0); ctx.lineTo(-11, -12); ctx.lineTo(-8, 14); ctx.closePath(); ctx.fill();
  ctx.fillStyle = slimeActive ? slimeTint.face : '#6b4a2b';
  ctx.beginPath(); ctx.arc(0, 0, 11, 0, 7); ctx.fill();
  ctx.fillStyle = slimeActive ? slimeTint.accent : '#20231b';
  ctx.beginPath(); ctx.arc(5, -1, 7, -1.2, 1.2); ctx.fill();
  if (h.weapon === 'ranger') {
    ctx.strokeStyle = slimeActive ? slimeTint.gun : '#7bb04a'; ctx.lineWidth = 3;
    ctx.beginPath(); ctx.arc(18, 0, 8, -1.3, 1.3); ctx.stroke();
    ctx.strokeStyle = slimeActive ? slimeTint.gunHi : '#d6e9ff'; ctx.lineWidth = 1; ctx.beginPath(); ctx.moveTo(16, -8); ctx.lineTo(16, 8); ctx.stroke();
  } else if (h.weapon === 'crossbow') {
    ctx.fillStyle = slimeActive ? slimeTint.gun : '#5e4631'; ctx.fillRect(8, -5, 22, 10);
    ctx.strokeStyle = slimeActive ? slimeTint.gunHi : '#c9b79d'; ctx.lineWidth = 2; ctx.beginPath(); ctx.moveTo(10, -9); ctx.lineTo(28, 0); ctx.lineTo(10, 9); ctx.stroke();
  } else if (h.weapon === 'storm') {
    ctx.fillStyle = slimeActive ? slimeTint.gun : '#5a438c'; ctx.fillRect(8, -6, 16, 12);
    ctx.strokeStyle = slimeActive ? slimeTint.gunHi : '#8edcff'; ctx.lineWidth = 2; ctx.beginPath(); ctx.moveTo(22, -8); ctx.lineTo(29, 0); ctx.lineTo(22, 8); ctx.stroke();
  } else if (h.weapon === 'freeze') {
    ctx.fillStyle = slimeActive ? slimeTint.gun : '#8fb6c8'; ctx.beginPath(); ctx.moveTo(10,-9); ctx.lineTo(26,0); ctx.lineTo(10,9); ctx.closePath(); ctx.fill();
    ctx.strokeStyle = slimeActive ? slimeTint.gunHi : '#dff4ff'; ctx.lineWidth = 2; ctx.stroke();
  } else if (h.weapon === 'blunderbuss') {
    ctx.fillStyle = slimeActive ? slimeTint.gun : '#9c6a33'; ctx.beginPath(); ctx.moveTo(10, -10); ctx.lineTo(30, -4); ctx.lineTo(33, 0); ctx.lineTo(30, 4); ctx.lineTo(10, 10); ctx.closePath(); ctx.fill();
    ctx.fillStyle = slimeActive ? slimeTint.gunHi : '#ffd27a'; ctx.fillRect(18, -6, 10, 12);
    ctx.strokeStyle = slimeActive ? slimeTint.gunHi : '#fff0cc'; ctx.lineWidth = 3;
    ctx.beginPath(); ctx.moveTo(28, 0); ctx.lineTo(38, 0); ctx.stroke();
    if (h.weaponRecoil > 0) {
      ctx.save();
      ctx.globalAlpha = 0.8;
      ctx.fillStyle = '#ffd27a';
      ctx.beginPath();
      ctx.moveTo(16, -12);
      ctx.lineTo(34, -6);
      ctx.lineTo(42, 0);
      ctx.lineTo(34, 6);
      ctx.lineTo(16, 12);
      ctx.closePath();
      ctx.fill();
      ctx.restore();
    }
  } else {
    ctx.fillStyle = slimeActive ? slimeTint.gun : '#c6b08c';
    ctx.beginPath(); ctx.moveTo(9, -4); ctx.lineTo(28, -4); ctx.lineTo(31, 0); ctx.lineTo(28, 4); ctx.lineTo(9, 4); ctx.closePath(); ctx.fill();
    ctx.fillStyle = slimeActive ? slimeTint.gunHi : '#f0c96b';
    ctx.fillRect(18, -3, 8, 6);
    ctx.strokeStyle = slimeActive ? slimeTint.gunHi : '#f7e2aa'; ctx.lineWidth = 2;
    ctx.beginPath(); ctx.moveTo(25, 0); ctx.lineTo(33, 0); ctx.stroke();
  }
  ctx.strokeStyle = slimeActive ? slimeTint.gunHi : '#d8c59a'; ctx.lineWidth = 1;
