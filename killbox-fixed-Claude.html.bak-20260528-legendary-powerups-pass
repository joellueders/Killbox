    case 'frost':
      ctx.fillStyle = '#82c4de'; ctx.beginPath(); ctx.moveTo(0, -34); ctx.lineTo(16, -6); ctx.lineTo(0, 27); ctx.lineTo(-16, -6); ctx.closePath(); ctx.fill(); ctx.stroke();
