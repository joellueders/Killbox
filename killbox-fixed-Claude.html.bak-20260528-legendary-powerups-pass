function sellSelected() {
  if (!S.sel || S.phase !== 'build') return toast('Sell between waves.');
  if (S.sel.type) {
    const wasRoad = S.sel.onRoad;
    S.gold += Math.floor(S.sel.sold);
    S.towers = S.towers.filter(t => t !== S.sel);
    if (wasRoad) rebuildPath();
  } else if (S.sel.max) {
    S.gold += Math.floor(S.sel.sold);
    S.barriers = S.barriers.filter(b => b !== S.sel);
    rebuildPath();
  } else {
    S.barrels = S.barrels.filter(b => b !== S.sel);
  }
  S.sel = null;
  S.selected = null;
  $('info').textContent = 'Sold.'; ui();
}

function sellEntity(entity) {
  if (!entity) return false;
  const isTower = !!entity.type;
  const isBarrier = !isTower && !!entity.max;
  const isBarrel = !isTower && !isBarrier;
  const label = isTower ? (TOWERS[entity.type]?.n || 'Tower') : isBarrier ? 'Barrier' : 'Barrel';
  const value = Math.floor(entity.sold || 0);
  if (isTower) {
    const wasRoad = entity.onRoad;
    S.gold += value;
    S.towers = S.towers.filter(t => t !== entity);
    if (wasRoad && !TOWERS[entity.type]?.trap) rebuildPath();
  } else if (isBarrier) {
    S.gold += value;
    S.barriers = S.barriers.filter(b => b !== entity);
    rebuildPath();
  } else if (isBarrel) {
    S.gold += value;
    S.barrels = S.barrels.filter(b => b !== entity);
  }
  playSfx('sell');
  if (S.sel === entity) S.sel = null;
  if (S.selected && typeof S.selected === 'string') {
    const d = TOWERS[S.selected];
    if (d && d.directional) {
      const stillPresent = S.towers.some(t => t.type === S.selected && t.dir === S.placeDir);
      if (!stillPresent) S.selected = null;
    }
  }
  S.selected = null;
  $('info').textContent = `Sold ${label} for ${value}g.`;
  toast(`Sold ${label} for ${value}g.`);
  ui();
  return true;
}

// ── Harvest snapshot (for restart) ───────────────────────────────────
function deepCopyEntity(obj) {
  // Shallow copy is fine for flat entity objects — no nested arrays/objects in towers/barriers/barrels
  return Object.assign({}, obj);
}

function makeWaveSnapshot() {
  S.waveSnapshot = JSON.stringify({
    levelId: S.levelId,
    lives: S.lives, gold: S.gold, wave: S.wave, score: S.score,
    aiEngineerOwned: S.aiEngineerOwned,
    mods: { ...S.mods },
    hero: Object.assign({}, S.hero),
    towers:     S.towers.map(deepCopyEntity),
    barriers:   S.barriers.map(deepCopyEntity),
    barrels:    S.barrels.map(deepCopyEntity),
    oilPatches: S.oilPatches.map(deepCopyEntity),
    firePatches: S.firePatches.map(({ t, ...patch }) => ({ ...patch })),
    healthOrbs: S.healthOrbs.map(deepCopyEntity),
    waveStats: S.waveStats ? Object.assign({}, S.waveStats) : null,
    runStats: Object.assign({}, S.runStats),
    bossActive: S.bossActive, bossSpawned: S.bossSpawned, bossAppearance: S.bossAppearance || 0, slimeKingAppearances: S.slimeKingAppearances || 0,
    queue: [...S.queue], timer: .35, spawnCount: 0,
  });
}

function restoreWaveSnapshot() {
  if (!S.waveSnapshot) return false;
  const o = JSON.parse(S.waveSnapshot);
  if (o.levelId) applyLevel(o.levelId, { silent: true });
  S.sel = null;
  S.selected = null;
  S.mutationPending = false;
  S.pendingUpgrade = false;
  S.gameState = 'combat';
  S.paused = false;
  S.lives = o.lives; S.gold = o.gold; S.wave = o.wave; S.score = o.score;
  S.aiEngineerOwned = !!o.aiEngineerOwned;
  S.mods = { gold: 1.14, dmg: 1, overclockUntil: 0, frenzyUntil: 0, hasteUntil: 0, coinPurseUntil: 0, lastStandUntil: 0, riftShieldUntil: 0, ...(o.mods || {}) };
  S.hero  = { ...S.hero, ...o.hero, cool: 0, inv: 0, dash: 0, dashCd: 0 };
  S.towers     = o.towers.map(t   => ({ ...t, cool: 0 }));
  S.barriers   = o.barriers.map(b  => ({ ...b }));
  S.barrels    = o.barrels.map(b   => ({ ...b }));
  S.oilPatches = (o.oilPatches || []).map(x => ({ ...x }));
  S.firePatches = (o.firePatches || []).map(x => ({ ...x }));
  S.healthOrbs = (o.healthOrbs || []).map(x => ({ ...x }));
  S.waveStats = o.waveStats ? Object.assign({}, o.waveStats) : null;
  S.runStats = o.runStats ? Object.assign({}, o.runStats) : S.runStats;
  S.bossActive = !!o.bossActive; S.bossSpawned = !!o.bossSpawned; S.bossIntro = 0;
  S.bossAppearance = o.bossAppearance || 0;
  S.slimeKingAppearances = o.slimeKingAppearances || 0;
  S.queue      = [...o.queue]; S.timer = o.timer; S.spawnCount = o.spawnCount || 0;
  S.enemies = []; S.shots = []; S.heroShots = []; S.enemyShots = [];
  S.parts = []; S.texts = []; S.shakeTime = 0;
  S.phase = 'combat'; S.waveActive = true;
  S.gameOver = false;
  rebuildPath(); ui();
  return true;
}

