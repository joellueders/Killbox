// ── Toast notifications ───────────────────────────────────────────
function toast(msg) {
  const host = $('toast');
  if (!host) return;
  const existing = [...host.children].find(n => n.textContent === msg);
  if (existing) {
    clearTimeout(existing._toastTimer);
    existing.remove();
  }
  while (host.children.length >= 3) {
    const oldest = host.firstElementChild;
    if (!oldest) break;
    clearTimeout(oldest._toastTimer);
    oldest.remove();
  }
  const d = document.createElement('div');
  d.className   = 'msg';
  d.textContent = msg;
  host.appendChild(d);
  d._toastTimer = setTimeout(() => d.remove(), 4100);
}
function threatToast(type) {
  const host = $('toast');
  if (!host) return;
  const info = {
    grunt:   ['GRUNT',   'Basic fodder'],
    runner:  ['RUNNER',  'Fast leak'],
    slinger: ['SLINGER', 'Ranged harasser'],
    brute:   ['BRUTE',   'Heavy frontline'],
    ogre:    ['OGRE',    'Boss brute'],
    hunter:  ['HUNTER',  'Targets your defenses'],
    bomber:  ['BOMBER',  'Explodes in crowds'],
    shield:  ['SHIELD',  'Blocks frontal fire'],
    healer:  ['HEALER',  'Keeps enemies alive'],
    siege:   ['SIEGE',   'Breaks barricades'],
  }[type] || [String(type || '').toUpperCase(), 'New threat'];
  S.threatPopupQueue = S.threatPopupQueue || [];
  S.threatPopupQueue.push(info);
  const pump = () => {
    let visibleThreats = [...host.children].filter(n => n.classList && n.classList.contains('threat')).length;
    while (visibleThreats < 2 && S.threatPopupQueue.length) {
      const next = S.threatPopupQueue.shift();
      const d = document.createElement('div');
      d.className = 'msg threat';
      d.innerHTML = `<span class="threatTag">⚠ NEW THREAT</span><span class="threatName">${next[0]}</span><span class="threatDesc">${next[1]}</span>`;
      host.appendChild(d);
      visibleThreats++;
      d._toastTimer = setTimeout(() => { d.remove(); pump(); }, 5800);
    }
  };
  pump();
}

