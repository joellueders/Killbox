<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Killbox 7.3.9-loadout-hotbar-layout</title>
<style>
/* ── Design tokens ─────────────────────────────────────────────── */
:root {
  --red:    #6c2f21;
  --red2:   #2a1410;
  --dark:   #17110d;
  --panel:  #d7c6a0;
  --gold:   #f0c96b;
  --blue:   #7ac6e8;
  --green:  #88a85a;
  --warn:   #df7b2a;
  --wood:   #57361f;
  --parch:  #efe1bc;
}

/* ── Base ──────────────────────────────────────────────────────── */
html, body {
  margin: 0; height: 100%; overflow: hidden;
  background: radial-gradient(circle at 50% 8%, #3f382d 0, #221a13 46%, #15100c 100%);
  color: #f8efd7;
  font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  line-height: 1.35;
  user-select: none;
}
canvas { display: block; width: 100vw; height: 100vh; background: linear-gradient(#5a4630, #2d2117 50%, #1a130d); cursor: crosshair; }
#c { touch-action: none; }

/* ── Layout ────────────────────────────────────────────────────── */
.gamePlayArea {
  position: fixed;
  left: 10px;
  top: 10px;
  bottom: 10px;
  right: 10px;
  display: block;
  pointer-events: none;
  z-index: 1;
  overflow: hidden;
}
.gameHudToggle {
  position: absolute;
  top: 4px;
  right: 6px;
  z-index: 50;
  pointer-events: auto;
  display: grid;
  place-items: center;
  width: 38px;
  height: 38px;
  padding: 0;
}
.menuOpen .gamePlayArea { right: 338px; }
.menuClosed .gamePlayArea { right: 10px; }
.gamePlayArea canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: auto;
}
.ui {
  position: fixed; inset: 10px;
  display: grid; grid-template-columns: 1fr 320px; gap: 10px;
  pointer-events: none;
}
.ui.combat { grid-template-columns: 1fr 320px; }
.ui.panelHidden { grid-template-columns: 1fr 0; }
.stats { display: none; }

.buildDock {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  z-index: 5; width: auto; pointer-events: none;
  overflow: hidden;
  display: flex;
  align-items: stretch;
  gap: 8px;
  padding: 4px 8px 5px;
  background:
    linear-gradient(90deg, rgba(88, 14, 10, .34), transparent 18%, transparent 82%, rgba(88, 14, 10, .34)),
    linear-gradient(180deg, rgba(31, 35, 38, .88), rgba(10, 8, 6, .94));
  border: 2px solid #b18445;
  border-radius: 8px;
  box-shadow: 0 8px 24px #0008, inset 0 0 0 1px rgba(232, 199, 131, .14), inset 0 9px 0 rgba(255,255,255,.03);
}
.buildDock, .buildRail, .buildCard { pointer-events: auto; }
.buildRail {
  display: flex; flex-wrap: nowrap; gap: 9px; pointer-events: auto;
  align-items: flex-start;
  justify-content: flex-start;
  flex: 1 1 auto;
  min-width: 0;
}
.buildCard {
  min-height: 96px; width: 94px; flex: 0 0 94px; padding: 5px 6px 6px; text-align: center;
  border: 2px solid rgba(177, 132, 69, .82); border-radius: 8px;
  background:
    radial-gradient(circle at 50% 28%, rgba(92, 110, 116, .35), transparent 58%),
    linear-gradient(180deg, rgba(44, 48, 48, .98), rgba(18, 13, 9, .98));
  box-shadow: inset 0 0 0 1px rgba(255, 235, 170, .08), 0 4px 0 #100a06, 0 9px 18px #0006;
  filter: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  overflow: hidden;
  position: relative;
}
.buildCard:hover { border-color: #c89b57; background: linear-gradient(180deg, rgba(38, 29, 21, .98), rgba(20, 13, 8, .98)); }
.buildCard.sel { border-color: #7ac6e8; box-shadow: 0 0 0 1px rgba(122,198,232,.35) inset, 0 0 0 2px rgba(122,198,232,.95), 0 0 18px #7ac6e855, 0 2px 0 #120c08; }
.buildCard.equipped { border-color: #d8b36e; box-shadow: 0 0 0 1px rgba(240,201,107,.2) inset, 0 0 0 1px rgba(240,201,107,.55), 0 0 10px #f0c96b22, 0 2px 0 #120c08; }
.buildCard.activeBuild { border-color: #7ac6e8; box-shadow: 0 0 0 1px rgba(122,198,232,.25) inset, 0 0 0 2px rgba(122,198,232,.95), 0 0 18px #7ac6e855, 0 2px 0 #120c08; }
.buildCard.activeHotbar { border-color: #7ac6e8; box-shadow: 0 0 0 1px rgba(122,198,232,.35) inset, 0 0 0 2px rgba(122,198,232,1), 0 0 24px #7ac6e8aa, 0 2px 0 #120c08; }
.buildCard.cooldown { filter: grayscale(.82) brightness(.76); opacity: .8; }
.buildCard.emptySlot {
  opacity: .42;
  filter: grayscale(.8) brightness(.76);
  border-style: dashed;
  background: linear-gradient(180deg, rgba(18, 14, 10, .9), rgba(11, 8, 6, .92));
}
.buildCard.emptySlot .buildIcon {
  font-size: 18px;
  color: rgba(240, 201, 107, .6);
  opacity: .72;
}
.buildCard.emptySlot .buildName,
.buildCard.emptySlot .buildPrice,
.buildCard.emptySlot .hotkey {
  color: rgba(255, 224, 156, .62);
}
.buildCard .buildIcon {
  width: 42px; height: 42px;
  margin: 1px auto 3px;
  display: grid; place-items: center;
  border-radius: 0;
  background: transparent;
  border: 0;
  box-shadow: none;
  font-size: 32px; line-height: 1;
  color: #fff4d0;
  overflow: hidden;
  position: relative;
  z-index: 0;
}
.buildCard .buildIcon svg,
.pickerTile .icon svg,
.towerCard .buildIcon svg,
.buildCard .buildIcon img,
.pickerTile .icon img,
.towerCard .buildIcon img {
  width: 100%;
  height: 100%;
  display: block;
  overflow: visible;
}
.buildCard .buildIcon img,
.pickerTile .icon img,
.towerCard .buildIcon img {
  object-fit: contain;
}
.buildCard .buildName {
  display: -webkit-box; min-width: 0;
  -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  font-size: 12px; color: #fff4d0; line-height: 1.06;
  overflow: hidden;
  text-overflow: ellipsis;
  min-height: 22px;
  max-height: 22px;
  padding: 0 1px;
  position: relative;
  z-index: 1;
}
.buildCard .buildPrice {
  display: block; margin-top: 2px; font-size: 11px; color: #f0c96b; font-weight: 900;
  font-variant-numeric: tabular-nums;
  line-height: 1.05;
  min-height: 12px;
  position: relative;
  z-index: 1;
}
.buildCard .hotkey { position: absolute; left: 5px; top: 5px; margin: 0; font-size: 11px; padding: 1px 5px; min-width: 16px; z-index: 2; border-radius: 4px; }
.buildCard .buildHint { display: block; margin-top: 1px; color: #8fd3f8; font-size: 8px; font-weight: 800; line-height: 1; text-transform: uppercase; letter-spacing: .06em; }

/* ── Stat bar ──────────────────────────────────────────────────── */
.stats {
  display: flex;
  gap: 8px;
  flex-wrap: nowrap;
  align-items: center;
  align-self: start;
  overflow: visible;
  padding: 4px 6px;
  border: 1px solid #8f6434;
  border-radius: 14px;
  background: linear-gradient(180deg, rgba(15, 11, 8, .88), rgba(9, 7, 5, .92));
  box-shadow: 0 10px 24px #0007, inset 0 0 0 1px rgba(232, 199, 131, .06);
}
.stat, .panel {
  background: linear-gradient(180deg, rgba(39, 28, 19, .96), rgba(18, 12, 9, .95));
  border: 1px solid #8f6434; border-radius: 12px;
  box-shadow: 0 10px 24px #0007, inset 0 0 0 1px rgba(232, 199, 131, .10);
}
.stat {
  height: 44px; min-width: 84px; padding: 3px 8px 3px;
  text-align: center; box-sizing: border-box;
  display: flex; flex-direction: column; justify-content: center; gap: 1px;
}
.stat small { display: block; color: #d4c39b; font-size: 10px; text-transform: uppercase; letter-spacing: .06em; line-height: 1; }
.stat b     { font-size: 18px; font-variant-numeric: tabular-nums; line-height: 1; }
.stat .statIcon {
  display: inline-block;
  margin-right: 5px;
  font-size: 17px;
  vertical-align: middle;
}
.stat .statValueRow {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 4px;
}
.stat .statValueRow b { font-size: 20px; }
.stat .statValueRow .smallValue { font-size: 12px; color: #f0c96b; font-weight: 700; }
.stat .statLabel { display: block; }
.stat.danger-flash b { color: #ff6060; }
.waveStatus {
  min-width: 142px; max-width: none;
  flex: 1 1 auto;
  display: flex; flex-direction: column; justify-content: center;
  text-align: left;
}
.waveStatus small { color: #f0c96b; font-size: 11px; }
.waveStatus b { font-size: 14px; line-height: 1.15; font-variant-numeric: tabular-nums; }
.waveStatus.resting b { color: #b9d84f; }
.waveStatus.danger b { color: #ffb36b; }
.hudActions { display: none; }
.stat.heroHp, .stat.waveStatus, .stat.statusStat { display: none; }
.stat.compactStat {
  min-width: 96px;
}
.stat.compactStat .statValueRow b { font-size: 19px; }
.stat.compactStat .statLabel { font-size: 10px; letter-spacing: .08em; }
.speedWrap {
  min-width: 86px;
}
.speedSelect {
  width: 100%;
  background: rgba(8, 6, 4, .9);
  color: #fff3cf;
  border: 1px solid #8f6434;
  border-radius: 8px;
  font: inherit;
  font-size: 13px;
  font-weight: 700;
  padding: 4px 6px;
  box-shadow: inset 0 1px 0 rgba(255,255,255,.05);
}

/* ── Side panel ────────────────────────────────────────────────── */
.panel {
  grid-column: 2; padding: 10px 11px 11px; pointer-events: auto;
  max-height: calc(100vh - 24px); overflow: auto;
  transition: transform .25s ease, opacity .25s ease;
  background:
    linear-gradient(90deg, rgba(115, 22, 14, .18), transparent 18%),
    linear-gradient(180deg, rgba(36, 40, 42, .95), rgba(13, 10, 8, .98));
  border-color: rgba(177, 132, 69, .85);
}
.ui.starting .panel {
  opacity: .55;
  filter: saturate(.72) brightness(.78);
}
.ui.panelHidden .panel { transform: translateX(390px); opacity: 0; pointer-events: none; }
.panel .buildSection { display: none; }
.panel details.codex { margin-top: 10px; border: 1px solid #4f371d; border-radius: 10px; background: linear-gradient(180deg, rgba(18,16,12,.95), rgba(11,9,7,.98)); }
.panel details.codex > summary {
  list-style: none; cursor: pointer; padding: 9px 12px; color: #f0c96b; font-weight: bold;
  text-transform: uppercase; letter-spacing: .08em;
  font-family: Georgia, 'Times New Roman', serif;
}
.panel details.codex > summary::-webkit-details-marker { display: none; }
.panel details.codex[open] > summary { border-bottom: 1px solid #4f371d; }
.panel .codexBody { padding: 10px 10px 12px; }
.panel .enemyList, .panel .towerList {
  display: grid;
  gap: 8px;
}
.panel .enemyCard, .panel .towerCard {
  display: grid;
  grid-template-columns: 34px 1fr;
  align-items: center;
  gap: 10px;
  border-radius: 10px;
  padding: 8px 10px;
  background: linear-gradient(180deg, rgba(26, 20, 15, .95), rgba(15, 11, 8, .98));
  border: 1px solid rgba(143, 100, 52, .65);
}
.panel .enemyCard .enemyText b, .panel .towerCard .enemyText b { font-size: 12px; }
.panel .enemyCard .enemyText span, .panel .towerCard .enemyText span { font-size: 12px; color: #cfbb96; line-height: 1.2; }
.panel .codexPill { display: inline-block; margin-left: 6px; padding: 0 5px; border: 1px solid #7ac6e8; border-radius: 999px; color: #b8e6ff; font-size: 10px; }
.inspectorSticky { display: grid; gap: 8px; }
.selectedInfoCard {
  border: 1px solid #8f6434;
  border-radius: 12px;
  padding: 12px 14px 14px;
  background: linear-gradient(180deg, rgba(24, 18, 13, .96), rgba(12, 9, 6, .98));
  box-shadow: inset 0 0 0 1px rgba(232, 199, 131, .06);
}
.selectedInfoCard .selGrid {
  display: grid;
  grid-template-columns: 116px 1fr;
  gap: 14px;
  align-items: start;
}
.selectedInfoCard .selIcon {
  width: 116px;
  height: 116px;
  border-radius: 14px;
  border: 1px solid rgba(240, 201, 107, .48);
  background: linear-gradient(180deg, rgba(52, 34, 19, .98), rgba(18, 11, 7, .98));
  box-shadow: inset 0 0 0 1px rgba(255,255,255,.03), 0 4px 0 #120c08;
  display: grid;
  place-items: center;
  overflow: hidden;
}
.selectedInfoCard .selIcon .icon {
  width: 94px;
  height: 94px;
  display: grid;
  place-items: center;
}
.selectedInfoCard .selIcon .icon svg,
.selectedInfoCard .selIcon .icon img {
  width: 100%;
  height: 100%;
}
.selectedInfoCard .selTitle {
  font-size: 20px;
  color: #fff4d0;
  font-weight: 800;
  letter-spacing: .015em;
  line-height: 1.06;
}
.selectedInfoCard .selRole {
  margin-top: 6px;
  font-size: 15px;
  color: #ffe08f;
  font-weight: 800;
  line-height: 1.15;
  text-transform: uppercase;
  letter-spacing: .08em;
}
.selectedInfoCard .selDesc {
  margin-top: 10px;
  font-size: 15px;
  color: #f4e6bf;
  line-height: 1.28;
}
.selectedInfoCard .selMeta,
.selectedInfoCard .selWeak {
  margin-top: 6px;
  font-size: 13px;
  color: #d9c79f;
  line-height: 1.2;
}
.selectedInfoCard .selWeak { color: #c7a57f; }
.selectedInfoCard .selFlavor {
  margin-top: 7px;
  font-size: 13px;
  color: #f0c96b;
  line-height: 1.2;
}

/* ── Typography ────────────────────────────────────────────────── */
h1 { font-size: 25px; margin: 0; color: #f0c96b; text-shadow: 0 2px 0 #2a1208; }
h2 {
  font-size: 14px; margin: 12px 0 6px; color: #f0c96b;
  text-transform: uppercase; letter-spacing: .08em;
  font-family: Georgia, 'Times New Roman', serif;
}
p  { font-size: 13px; line-height: 1.45; color: #ddd; }
#start h1 { font-size: 38px; }
#start p { margin: 4px 0 2px; }
#start h2 { margin: 8px 0 4px; }

/* ── Buttons ───────────────────────────────────────────────────── */
.grid    { display: grid; grid-template-columns: 1fr 1fr; gap: 7px; }
.controlRow { display: flex; gap: 7px; grid-column: 1 / 3; }
.controlRow > button { flex: 1 1 0; }
button, textarea, input { font: inherit; }
button {
  border: 1px solid #9b6a35; border-radius: 10px;
  background: linear-gradient(180deg, rgba(119, 76, 40, .96), rgba(41, 26, 16, .98));
  color: #fff; font-weight: 700; padding: 8px;
  cursor: pointer; text-align: left;
  box-shadow: 0 3px 0 #111;
}
button:hover  { filter: brightness(1.1); }
button:active { transform: translateY(2px); box-shadow: 0 1px 0 #111; }
button.sel    { outline: 2px solid var(--blue); outline-offset: 1px; }
button:disabled { opacity: .42; cursor: not-allowed; filter: grayscale(.45) brightness(.82); }
.primary { background: linear-gradient(180deg, rgba(145, 84, 38, .98), rgba(63, 27, 16, .98)); }
.danger  { background: linear-gradient(180deg, rgba(84, 35, 24, .98), rgba(25, 14, 10, .98)); }
.wide    { text-align: center; grid-column: 1/3; }
.row     { display: flex; justify-content: space-between; gap: 6px; }
.pickerGrid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
  gap: 12px;
  margin: 8px 0 10px;
}
#start .pickerGrid {
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 8px;
  margin: 4px 0 6px;
}
.pickerTile {
  border: 1px solid #8f6434;
  border-radius: 12px;
  background: linear-gradient(180deg, rgba(118, 79, 48, .98), rgba(46, 28, 17, .99));
  padding: 14px 12px 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 4px;
  text-align: center;
  opacity: .72;
  filter: saturate(.92) brightness(.9);
  transition: opacity .15s ease, filter .15s ease, outline-color .15s ease;
  position: relative;
  overflow: hidden;
}
.pickerTile:hover { filter: saturate(1) brightness(.98); border-color: #c59b58; }
.pickerTile.sel { outline: 2px solid #7ac6e8; outline-offset: 1px; opacity: 1; filter: saturate(1.1) brightness(1.1); box-shadow: 0 0 0 1px rgba(122,198,232,.9) inset, 0 0 0 2px rgba(122,198,232,1), 0 0 18px rgba(122,198,232,.28), 0 2px 0 #120c08; }
.pickerTile .slotBadge {
  position: absolute;
  top: 8px;
  right: 8px;
  min-width: 24px;
  height: 24px;
  padding: 0 7px;
  border-radius: 999px;
  border: 1px solid #c79a4b;
  background: linear-gradient(180deg, rgba(108, 73, 30, .98), rgba(55, 34, 12, .98));
  color: #fff0c7;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  line-height: 1;
  font-weight: 900;
  font-variant-numeric: tabular-nums;
  letter-spacing: .02em;
  box-shadow: 0 1px 0 #140d08, 0 0 0 1px rgba(0,0,0,.35) inset, 0 0 10px rgba(0,0,0,.2);
  pointer-events: none;
}
.pickerTile .icon {
  width: 72px;
  height: 72px;
  margin: 0 auto 4px;
  display: grid;
  place-items: center;
  color: #fff4d0;
  position: relative;
  z-index: 2;
  overflow: hidden;
  isolation: isolate;
}
.iconImg {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
  position: relative;
  z-index: 10;
  opacity: 1;
  visibility: visible;
  image-rendering: auto;
}
.pickerTile .icon .iconImg,
.selectedInfoCard .selIcon .icon .iconImg,
.towerCard .buildIcon .iconImg,
.buildCard .buildIcon .iconImg {
  width: 100%;
  height: 100%;
}
.pickerTile .name { display: block; font-size: 13px; color: #fff8df; line-height: 1.06; font-weight: 800; text-shadow: 0 1px 0 #120b07; }
.pickerTile .meta { display: block; font-size: 11px; color: #ffe2a0; margin-top: 3px; line-height: 1.1; font-variant-numeric: tabular-nums; font-weight: 700; letter-spacing: .04em; }
.pickerTile .note { display: block; font-size: 11px; color: #d4c39b; margin-top: 3px; line-height: 1.2; }
.pickerTile .name,
.pickerTile .meta,
.pickerTile .note {
  position: relative;
  z-index: 1;
}
.pickerTile.trinket .note { font-size: 11px; color: #d4c39b; }
.pickerTile.small { padding: 12px 10px 10px; min-height: 168px; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; gap: 2px; }
.pickerTile.small .icon { width: 70px; height: 70px; font-size: 44px; margin-bottom: 3px; }
.pickerTile.small .name { font-size: 12px; line-height: 1.05; -webkit-line-clamp: 2; min-height: 24px; max-height: 24px; overflow: hidden; }
.pickerTile.small .meta { font-size: 11px; margin-top: 2px; }
.pickerTile.small .note { font-size: 11px; margin-top: 2px; }
.loadoutHelp { font-size: 12px; color: #d4c39b; margin-top: -4px; line-height: 1.25; }
.loadoutHeader {
  margin-top: 5px;
  padding: 11px 12px 10px;
  border-color: rgba(240, 201, 107, .8);
  background: linear-gradient(180deg, rgba(78, 50, 24, .99), rgba(28, 17, 10, .99));
  box-shadow: inset 0 0 0 1px rgba(255,255,255,.05), 0 3px 0 #120c08;
}
.loadoutHeader .name {
  font-size: 15px;
  color: #fff9db;
  letter-spacing: .1em;
  text-transform: uppercase;
  text-align: left;
  text-shadow: 0 1px 0 #120b07;
}
.cost    {
  background: #5d1515; border-radius: 999px;
  padding: 1px 6px; white-space: nowrap;
}
.desc { font-weight: normal; font-size: 12px; color: #fff; line-height: 1.3; margin-top: 4px; }
.hotkey {
  min-width: 20px; margin-right: 6px; padding: 1px 5px;
  border: 1px solid #d0a35d; border-radius: 999px;
  color: #ffe09c; background: #120b07cc;
  text-align: center; font-size: 11px;
  font-variant-numeric: tabular-nums;
}

/* ── Textarea / info box ────────────────────────────────────────── */
textarea {
  width: 100%; height: 64px; box-sizing: border-box;
  border-radius: 8px; border: 1px solid var(--red);
  background: #ead7aa; color: #2f2418;
  padding: 8px; font-size: 12px; line-height: 1.35;
}
.testControls {
  display: grid; grid-template-columns: 1fr 1fr; gap: 7px;
}
.testControls input {
  min-width: 0; box-sizing: border-box;
  border-radius: 10px; border: 2px solid #9b6a35;
  background: #ead7aa; color: #2f2418;
  padding: 8px; font-weight: bold;
}
.deathCard {
  position: relative;
  overflow: hidden;
  text-align: center;
  background:
    radial-gradient(circle at 18% 88%, #ff8a1f44 0 7%, transparent 21%),
    radial-gradient(circle at 82% 88%, #ff4a1f3338 0 8%, transparent 24%),
    linear-gradient(#4b160f, #140604 64%, #050202);
  border-color: #d86b29;
  box-shadow: 0 0 50px #ff4a1f3355, 0 20px 80px #000;
}
.deathCard::before {
  content: "";
  position: absolute; inset: -30%;
  background:
    radial-gradient(circle at 30% 90%, transparent 0 58%, #ff9a2c33 59% 61%, transparent 62%),
    radial-gradient(circle at 50% 92%, transparent 0 54%, #ff4d1f44 55% 57%, transparent 58%),
    radial-gradient(circle at 70% 90%, transparent 0 58%, #ffbc4a33 59% 61%, transparent 62%);
  animation: deathFlames 1.15s ease-in-out infinite alternate;
  pointer-events: none;
}
.deathCard::after {
  content: "☠";
  position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);
  font-size: 210px; line-height: 1;
  color: #ffffff0f;
  text-shadow: 0 0 30px #ff6a1f33;
