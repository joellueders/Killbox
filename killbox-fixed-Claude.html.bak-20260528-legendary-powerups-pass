/* ── Boss warning banner ─────────────────────────────────────────── */
#bossWarning {
  position: fixed; top: 70px; left: 50%; transform: translateX(-50%);
  z-index: 6; pointer-events: none;
  background: linear-gradient(180deg, #68180fee, #190706ee);
  border: 3px solid #f0c96b; border-radius: 6px;
  padding: 12px 28px; text-align: center;
  font-size: 22px; font-weight: 900; color: #ffd27a;
  letter-spacing: .06em; opacity: 0;
  transition: opacity .35s ease;
  box-shadow: 0 0 32px #ff4a1f88, 0 8px 0 #080403;
}
#bossWarning.visible { opacity: 1; }
.waveBanner {
  position: fixed;
  left: 50%;
  top: 64px;
  transform: translateX(-50%) translateY(-10px) scale(.98);
  z-index: 9;
  pointer-events: none;
  padding: 10px 20px;
  border-radius: 6px;
  border: 3px solid #f0c96b;
  background:
    linear-gradient(90deg, rgba(118, 20, 13, .85), rgba(31, 26, 20, .96) 25%, rgba(31, 26, 20, .96) 75%, rgba(118, 20, 13, .85)),
    linear-gradient(180deg, #30383cf0, #120905f0);
  color: #fff4d0;
  text-transform: uppercase;
  letter-spacing: .12em;
  font-size: 34px;
  font-weight: 900;
  text-shadow: 0 2px 0 #120905, 0 0 16px #ffcf6a99;
  opacity: 0;
  transition: opacity .28s ease, transform .28s ease;
  box-shadow: 0 12px 32px #0009, 0 0 30px #f0a43a66, inset 0 0 0 1px rgba(255,255,255,.08);
}
.waveBanner.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0) scale(1);
}
.waveBanner.resting { color: #b9d84f; border-color: #b9d84f; text-shadow: 0 2px 0 #120905, 0 0 16px #b9d84f88; }
.waveBanner.danger { color: #ffb36b; border-color: #ff8a2a; text-shadow: 0 2px 0 #120905, 0 0 18px #ff8a2a88; }
.waveBanner.boss { color: #ff7967; border-color: #ff7967; text-shadow: 0 2px 0 #120905, 0 0 20px #ff4a1f99; }

/* ── Toast ───────────────────────────────────────────────────────── */
.toast { position: fixed; left: 50%; top: 18px; transform: translateX(-50%); display: flex; flex-direction: column; gap: 6px; pointer-events: none; z-index: 7; align-items: center; max-width: min(92vw, 420px); }
.msg   { background: linear-gradient(180deg, #30383dee, #100d0dee); border: 1px solid #b18445; border-radius: 6px; padding: 8px 12px; animation: fade 4s forwards; box-shadow: 0 4px 0 #090604, 0 10px 24px #0007; color: #fff0c7; }
.msg.threat {
  border-color: #f0c96b;
  background: linear-gradient(180deg, rgba(44, 28, 10, .98), rgba(14, 10, 6, .98));
  box-shadow: 0 0 0 1px rgba(240, 201, 107, .32) inset, 0 0 22px rgba(0, 0, 0, .45);
  border-radius: 16px;
  padding: 10px 12px 9px;
  min-width: 250px;
  max-width: 420px;
  animation-duration: 5.8s;
}
.msg.threat b,
.msg.threat .threatName,
.msg.threat .threatDesc { display: block; }
.msg.threat .threatTag {
  color: #ffd57b;
  font-size: 11px;
  font-weight: 900;
  letter-spacing: .14em;
  text-transform: uppercase;
}
.msg.threat .threatName {
  margin-top: 2px;
  color: #fff3c9;
  font-size: 17px;
  font-weight: 900;
  line-height: 1.04;
  letter-spacing: .03em;
}
