  // Full-heal glow ring
  if (o.full) {
    ctx.strokeStyle = '#ffe09c33'; ctx.globalAlpha = .45;
    ctx.beginPath(); ctx.arc(o.x, o.y, o.r + 12 + Math.sin(t * 5) * 4, 0, 7); ctx.stroke();
  }
  ctx.restore();
}

function drawEnemy(e) {
  const tNow = performance.now() / 1000;
  const eSeed = (e.id != null ? e.id : (e.spawnT || 0) + e.x * .13 + e.y * .07);
  ctx.save();
  const airLift = (e.air || 0) > 0 ? Math.sin(Math.min(1, e.air / .26) * Math.PI) * 18 : 0;
