      ctx.strokeStyle = '#a8a39c'; ctx.lineWidth = 4;
      ctx.beginPath(); ctx.moveTo(-6,0); ctx.lineTo(18,0); ctx.stroke();
      ctx.fillStyle = '#8f8a84'; ctx.beginPath(); ctx.arc(21,0,10,0,7); ctx.fill(); ctx.stroke();
      ctx.strokeStyle = '#ffe09c'; ctx.lineWidth = 3;
      ctx.beginPath(); ctx.arc(2, 0, 24, -0.55, 0.55); ctx.stroke();
      break;
    case 'archer':
      ctx.fillStyle = '#6b3f22'; ctx.fillRect(-18, -10, 36, 26); ctx.strokeRect(-18, -10, 36, 26);
      ctx.fillStyle = '#8c5d32'; ctx.fillRect(-23, -20, 46, 10); ctx.strokeRect(-23, -20, 46, 10);
