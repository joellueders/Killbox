function drawPlagueMonk(e, base) { drawHumanoidBase(e, '#5f8f45', '#a6b768'); ctx.fillStyle='#6f8d3b'; ctx.fillRect(-2,-18,4,20); ctx.fillRect(-10,-10,20,4); ctx.strokeStyle='#6f8d3b'; ctx.lineWidth=3; ctx.beginPath(); ctx.arc(0,0,e.rad+7,0,7); ctx.stroke(); }
function drawRamBeast(e, base) { ctx.fillStyle = '#3b2a20'; ctx.fillRect(-e.rad, -e.rad * .55, e.rad * 2, e.rad * 1.2); ctx.strokeRect(-e.rad, -e.rad * .55, e.rad * 2, e.rad * 1.2); ctx.fillStyle='#77706a'; ctx.fillRect(-e.rad*.75,-4,e.rad*1.5,10); ctx.fillStyle='#5a4633'; ctx.fillRect(e.rad*.2,-e.rad*.3,e.rad*.7,e.rad*.6); }
function drawSlimeKing(e, base) {
  const appearance = e.appearance || 1;
