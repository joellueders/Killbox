function rotateSelectedDirectionalTrap() {
  if (S.phase !== 'build' || !S.selected) return false;
  const d = TOWERS[S.selected];
  if (!d || !d.directional) return false;
  S.placeDir = ((S.placeDir ?? 0) + 1) % 4;
  const label = DIR_LABELS[S.placeDir];
  toast(`Facing ${label}`);
  ui();
  return true;
}


function drawEngineer(t) {
  const e = S.engineer;
  if (!e.active) return;
  const a = Math.atan2(e.aimY - e.y, e.aimX - e.x);
  ctx.save();
  ctx.translate(e.x, e.y);
  ctx.rotate(a);
