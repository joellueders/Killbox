  ctx.fillStyle = '#0005'; ctx.beginPath(); ctx.ellipse(2, 7, 18, 12, 0, 0, 7); ctx.fill();
  ctx.fillStyle = '#2b4e5f'; ctx.beginPath(); ctx.arc(0, 0, 14, 0, 7); ctx.fill();
