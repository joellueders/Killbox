  else if (e.type === 'slinger') { rot = Math.sin(tNow * 7 + eSeed * .08) * .06; }
  else if (e.type === 'bomber') { rot = Math.sin(tNow * 15 + eSeed * .12) * .09; }
  else if (e.type === 'healer') { bobY = Math.sin(tNow * 4 + eSeed * .09) * 2.8; }
  else if (e.type === 'slimeking') { sx = 1 + Math.sin(tNow * 7 + eSeed * .04) * .09; sy = 1 / sx; bobY = Math.sin(tNow * 5 + eSeed * .04) * 1.2; }
  ctx.translate(e.x, e.y - airLift + bobY);
  if (rot) ctx.rotate(rot);
  const blink = e.type === 'bomber' && Math.floor(performance.now() / 160) % 2;
  ctx.scale(sx, sy);
  if (e.hitPulse) {
    const hp = Math.max(0, e.hitPulse);
    ctx.scale(1 + hp * .08, 1 - hp * .045);
    e.hitPulse = Math.max(0, e.hitPulse - 0.12);
  }

  ctx.fillStyle = '#0005';
  ctx.beginPath(); ctx.ellipse(3, e.rad * .65, e.rad * 1.1, e.rad * .45, 0, 0, 7); ctx.fill();

  let base = e.flash ? '#fff1c0' :
    blink ? '#c01818' :
    e.type === 'bomber'    ? '#ffcf3d' :
    e.type === 'shield'    ? '#2f4f74' :
    e.type === 'healer'    ? '#d8d0a8' :
    e.type === 'siege'     ? '#3b2a20' :
    e.type === 'slimeking' ? '#4fa34f33' :
    e.type === 'hunter'    ? '#241717' :
    e.type === 'runner'    ? '#a87932' :
    e.type === 'slinger'   ? '#5d7344' :
    e.type === 'brute'     ? '#7a382a' :
    e.type === 'ogre'      ? '#4e3628' : '#6d3f2a';
  if ((e.freeze || 0) > 0) base = '#8edcff';

  ctx.strokeStyle = '#1e1008'; ctx.lineWidth = 2;

  if (enemySpritesReady && ENEMY_SPRITES[e.type]) {
    drawEnemySprite(e, base);
  } else {
    drawEnemyBody(e, base, blink);
  }

  if (e.stun > 0 && (e.freeze || 0) <= 0) {
    ctx.strokeStyle = '#7ac6e8';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.arc(0, 0, e.rad + 7, 0, 7);
    ctx.stroke();
  }
  if (e.wild) { ctx.strokeStyle = '#ffcf3d'; ctx.lineWidth = 3; ctx.beginPath(); ctx.arc(0, 0, e.rad + 4, 0, 7); ctx.stroke(); }
  if (e.range && e.type !== 'slinger') { ctx.strokeStyle = '#e8c783'; ctx.lineWidth = 2; ctx.beginPath(); ctx.arc(8, 0, 14, -1, 1); ctx.stroke(); }
  if ((e.freeze || 0) > 0 || (e.chill || 0) > 0) {
    ctx.save();
    ctx.globalAlpha = .7;
    ctx.fillStyle = '#bfefff';
    ctx.beginPath();
    ctx.arc(0, 0, e.rad + 9, 0, 7);
    ctx.fill();
    ctx.globalAlpha = .4;
    ctx.strokeStyle = '#f4fbff';
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.arc(0, 0, e.rad + 12, 0, 7);
    ctx.stroke();
    ctx.restore();
  }

  ctx.restore();

  const w = e.rad * 2.2;
  ctx.fillStyle = '#2b120b'; ctx.fillRect(e.x - w / 2, e.y - e.rad - 13, w, 5);
  ctx.fillStyle = e.hp / e.max > .5 ? '#4f8d3b' : '#a83b28';
  ctx.fillRect(e.x - w / 2, e.y - e.rad - 13, w * (e.hp / e.max), 5);
}

function drawEnemySprite(e, base) {
  const img = ENEMY_SPRITES[e.type];
  const pad = e.type === 'slimeking' ? 2.8 : e.type === 'siege' ? 2.45 : e.type === 'ogre' || e.type === 'brute' ? 2.35 : 2.15;
  const size = e.rad * pad;
  ctx.drawImage(img, -size, -size, size * 2, size * 2);
  if ((e.freeze || 0) > 0) {
    ctx.globalAlpha = .72;
    ctx.fillStyle = '#9fdfff';
    ctx.fillRect(-size, -size, size * 2, size * 2);
    ctx.globalAlpha = .34;
    ctx.strokeStyle = '#d8f4ff';
    ctx.lineWidth = 3;
    ctx.strokeRect(-size + 2, -size + 2, size * 2 - 4, size * 2 - 4);
    ctx.globalAlpha = 1;
    ctx.save();
    ctx.globalAlpha = .22;
    ctx.fillStyle = '#e9fbff';
    ctx.beginPath();
    ctx.arc(0, 0, e.rad * 1.02, 0, 7);
    ctx.fill();
    ctx.restore();
  } else if (e.flash && e.type !== 'slimeking') {
    ctx.globalAlpha = .22;
    ctx.fillStyle = '#fffbe0';
    ctx.fillRect(-size, -size, size * 2, size * 2);
    ctx.globalAlpha = .42;
    ctx.strokeStyle = '#fff7df';
    ctx.lineWidth = 2.5;
    ctx.strokeRect(-size + 1, -size + 1, size * 2 - 2, size * 2 - 2);
    ctx.globalAlpha = 1;
  }
  if (e.type === 'slimeking') {
    const pal = [
      { tint:'#4fa34f', glow:'#93de74' }, // green
      { tint:'#8f57c9', glow:'#d0a7ff' }, // purple
      { tint:'#3b8fd8', glow:'#9fd9ff' }, // blue
      { tint:'#cf7a2d', glow:'#ffcb7f' }, // amber
      { tint:'#c43d5f', glow:'#ff97b0' }, // crimson-pink
    ][Math.max(0, ((e.appearance || 1) - 1) % 5)];
    ctx.globalAlpha = .18;
    ctx.strokeStyle = pal.glow;
    ctx.lineWidth = 4;
    ctx.beginPath();
    ctx.arc(0, 2, e.rad * 1.14, 0, 7);
    ctx.stroke();
    ctx.globalAlpha = 1;
  }
  if (e.type === 'bomber') {
    const blink = Math.floor(performance.now() / 160) % 2;
    ctx.globalAlpha = 0.42;
    ctx.fillStyle = blink ? '#ffcf3d' : '#c01818';
    ctx.beginPath();
    ctx.arc(0, 0, e.rad + 10, 0, 7);
    ctx.fill();
    ctx.globalAlpha = 1;
  }
}

function drawEnemyBody(e, base, blink) {
  if (e.type === 'slimeking') return drawSlimeKing(e, base);
  if (e.type === 'siege') return drawRamBeast(e, base);
  if (e.type === 'runner') return drawFeralRunner(e, base);
  if (e.type === 'slinger') return drawStoneSlinger(e, base);
  if (e.type === 'brute') return drawButcherBrute(e, base);
  if (e.type === 'ogre') return drawGateOgre(e, base);
  if (e.type === 'hunter') return drawSaboteur(e, base);
  if (e.type === 'bomber') return drawPowderLunatic(e, base, blink);
  if (e.type === 'shield') return drawShieldBearer(e, base);
  if (e.type === 'healer') return drawPlagueMonk(e, base);
  return drawRaiderGrunt(e, base);
}

function drawHumanoidBase(e, base, skin = '#6f8d3b') {
  ctx.fillStyle = base; ctx.beginPath(); ctx.ellipse(0, 3, e.rad * .95, e.rad * 1.05, 0, 0, 7); ctx.fill(); ctx.stroke();
