function useTrinket(id) {
  const tr = TRINKETS[id];
  if (!tr || !S.started || S.gameOver) return false;
  const remaining = trinketCooldownRemaining(id);
  if (remaining > 0) { toast(`${tr.name} still chewing.`); return false; }
  const now = performance.now() / 1000;
  let used = false;
  if (id === 'healingFlask') {
    const heal = Math.floor(S.hero.max * 0.4);
    S.hero.hp = Math.min(S.hero.max, S.hero.hp + heal);
    shockwave(S.hero.x, S.hero.y, '#7bd45e', 84, .32);
    boom(S.hero.x, S.hero.y, '#b8f6b0', 12);
    floatText('+' + heal + ' HP', S.hero.x - 18, S.hero.y - 22, '#7bd45e');
    used = true;
  } else if (id === 'overclockIdol') {
    const nearby = [...S.towers, ...S.barriers].filter(o => dist(S.hero.x, S.hero.y, o.x, o.y) <= 160);
    if (!nearby.length) { toast('No nearby defenses to juice up.'); return false; }
    for (const o of nearby) {
      if (o.cool > 0) o.cool = 0;
      o.overclockUntil = now + 6;
    }
    S.mods.overclockUntil = now + 6;
    shockwave(S.hero.x, S.hero.y, '#8edcff', 128, .36);
    shockwave(S.hero.x, S.hero.y, '#f0c96b', 92, .24);
    floatText('OVERCLOCK', S.hero.x - 36, S.hero.y - 22, '#8edcff');
    used = true;
  } else if (id === 'battleFrenzyTotem') {
    S.mods.frenzyUntil = now + 8;
    shockwave(S.hero.x, S.hero.y, '#f0c96b', 116, .3);
    burst(S.hero.x, S.hero.y, '#ff8e45', 18, 'spark', 180);
    floatText('FRENZY', S.hero.x - 24, S.hero.y - 22, '#f0c96b');
    used = true;
  } else if (id === 'goblinCoinPurse') {
    S.mods.coinPurseUntil = now + 15;
    shockwave(S.hero.x, S.hero.y, '#f0c96b', 104, .24);
    burst(S.hero.x, S.hero.y, '#f0c96b', 12, 'spark', 120);
    floatText('GOLD!', S.hero.x - 18, S.hero.y - 22, '#f0c96b');
    used = true;
  } else if (id === 'lastStandBeacon') {
    S.mods.lastStandUntil = now + 8;
    shockwave(S.hero.x, S.hero.y, '#8edcff', 126, .3);
    floatText('BEACON', S.hero.x - 22, S.hero.y - 22, '#8edcff');
    used = true;
  }
  if (!used) return false;
  tr.lastUsed = now;
  ui();
  return true;
}

