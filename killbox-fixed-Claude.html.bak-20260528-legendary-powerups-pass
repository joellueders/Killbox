function copyTextToClipboard(text, okMsg = 'Copied.') {
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(text).then(() => toast(okMsg)).catch(() => fallbackCopyText(text, okMsg));
  } else {
    fallbackCopyText(text, okMsg);
  }
}

function fallbackCopyText(text, okMsg) {
  const ta = document.createElement('textarea');
  ta.value = text;
  ta.setAttribute('readonly', '');
  ta.style.position = 'fixed';
  ta.style.left = '-9999px';
  document.body.appendChild(ta);
  ta.select();
  try { document.execCommand('copy'); toast(okMsg); }
  catch (err) { toast('Copy failed. Select the Harvest Seal manually.'); }
  ta.remove();
}

function offerRestart(reason) {
  if (S.gameOver) return;
  S.gameOver = true; S.paused = true;
  if (S.restarts > 0 && S.waveSnapshot) {
    S.restarts--;
    const word = S.restarts === 1 ? 'life' : 'lives';
    $('start').classList.remove('hidden');
    $('start').classList.add('breachOverlay');
    const card = document.querySelector('#start .card');
    card.classList.remove('deathCard', 'clearCard');
    card.classList.add('breachCard');
    document.querySelector('#start .card').innerHTML =
      `<div class="breachSeal" aria-hidden="true"></div>
       <h1>RIFT BREACHED</h1>
       <div class="breachCopy">
         <div class="breachLine">The enemy overwhelmed your defenses.</div>
         <div class="breachLife">${S.restarts} ${word} remains.</div>
       </div>
       <div class="deathButtons">
         <button id="restartWave" class="primary wide">Restart Wave</button>
       </div>`;
    setTimeout(() => {
      $('restartWave').onclick = () => { document.querySelector('#start').classList.remove('breachOverlay'); document.querySelector('#start .card').classList.remove('breachCard'); document.querySelector('#start .card').classList.remove('deathCard'); document.querySelector('#start .card').classList.remove('clearCard'); $('start').classList.add('hidden'); restoreWaveSnapshot(); };
    }, 0);
  } else {
    const seal = finalHarvestSeal();
    $('start').classList.remove('hidden');
    $('start').classList.remove('breachOverlay');
    const card = document.querySelector('#start .card');
    card.classList.add('deathCard');
    card.classList.remove('breachCard');
    card.innerHTML =
      `<h1>☠ Whoa. You Died. 🔥</h1>
       <p>The torches gutter. The village falls. The harvest takes what remains.</p>
       ${runSummaryHtml()}
       <div class="deathButtons">
         <button id="copyFinalPass" class="primary wide">Copy Password</button>
         <button id="newRun" class="wide">Start New Game</button>
       </div>`;
    setTimeout(() => {
      $('copyFinalPass').onclick = () => copyTextToClipboard(seal, 'Password copied.');
      $('newRun').onclick = () => location.reload();
    }, 0);
  }
}
// ── Harvest composition ──────────────────────────────────────────────
function waveSize(w) {
  if (w <= 5)  return 10 + w * 4;
  if (w <= 10) return 40 + (w - 5) * 4;
  return 60 + (w - 10) * 3;
}

function waveTheme(w) {
  if (w % 3 === 0) return 'climax';
  if (w % 2 === 0) return 'pressure';
  return 'probe';
}

// Seeded PRNG (mulberry32) — deterministic per wave so preview === actual spawn mix
function makeWaveRng(seed) {
  let s = seed | 0;
  return function() {
    s |= 0; s = s + 0x6D2B79F5 | 0;
    let t = Math.imul(s ^ s >>> 15, 1 | s);
    t = t + Math.imul(t ^ t >>> 7, 61 | t) ^ t;
    return ((t ^ t >>> 14) >>> 0) / 4294967296;
  };
}

// Returns counts of each enemy type for wave w
function previewWave(w) {
  const rng = makeWaveRng(w * 1000003 + 7);
  const n = waveSize(w);
  const p = { grunt: 0, runner: 0, slinger: 0, brute: 0, ogre: 0,
               hunter: 0, bomber: 0, shield: 0, healer: 0, siege: 0 };

  // Special roles scale with wave
  // pressure layering to require hero intervention
  p.hunter  = w >= 3  ? Math.max(1, Math.round(n * .05))  : 0;
  p.bomber  = w >= 4  ? Math.max(1, Math.round(n * .06))  : 0;
  p.shield  = w >= 3  ? Math.max(1, Math.round(n * .08))  : 0;
  p.healer  = w >= 4  ? Math.max(1, Math.round(n * .05))  : 0;
  p.siege   = w >= 5  ? Math.max(1, Math.round(n * .04))  : 0;
  p.brute   = w >= 4  ? Math.max(1, Math.round(n * .08))  : 0;
  p.ogre    = w >= 6  ? Math.max(1, Math.round(n * .04))  : 0;
  if (w >= 6 && p.runner < 2) p.runner = 2;

  // Fill remainder with grunts / runners / slingers (deterministic via seeded rng)
  let used = Object.values(p).reduce((a, b) => a + b, 0);
  let remaining = Math.max(0, n - used);

  for (let i = 0; i < remaining; i++) {
    const r = rng();
    if (w > 2 && r < .22) p.slinger++;
    else if (w > 1 && r < .42) p.runner++;
    else p.grunt++;
  }
  if (w >= 4) {
    // pressure layering to require hero intervention
    if (p.hunter && p.runner === 0) p.runner = 1;
    if (p.bomber && p.shield === 0) p.shield = 1;
    if (p.siege && p.grunt === 0) p.grunt = 1;
  }
  p.__theme = waveTheme(w);
  return p;
}

function startWave() {
  // startWave is blocked by upgradeChoice/pendingUpgrade so the next wave cannot skip the modal.
  if (S.hero.spawnState === 'spawning') return toast('Arriving...');
  if (S.gameState === 'upgradeChoice' || S.pendingUpgrade) {
    return toast('Pick a mutagen first.');
  }
  if (!S.started || S.waveActive || S.gameOver) return;
  if (!(S.loadout || []).some(k => !!WEAPONS[k])) return toast('Pick at least one gun. Do not be a coward.');

  S.wave++;
  S.waveStats = {
    wave: S.wave,
    startGold: Math.floor(S.gold),
    startScore: S.score,
    startLives: S.lives,
    startHp: Math.floor(S.hero.hp),
    heroKills: 0,
    towerKills: 0,
    otherKills: 0,
    leaked: 0,
    powerups: 0,
    goldEarned: 0,
    bonusGold: 0,
    interestGold: 0,
  };
  S.phase      = 'combat';
  S.waveActive = true;
  playSfx('waveStart');
  announceWave(`WAVE ${S.wave}: HOLD THE GATE`, 'danger', 1.05);
  S.bossActive = false; S.bossSpawned = false; S.bossIntro = 0;
  S.sel        = null;
  S.selected   = null; // Clear build selection at wave start; combat should not stay in placement mode.
  clearCombatInputState();
  applyTrinketPassives();
  S.hero.flaskCharges = 1;
  $('info').textContent = 'Combat phase: hotbar uses slots 1-0. Weapons equip, buildables place, trinkets trigger.';
  S.queue      = [];

  const p = previewWave(S.wave);
  const theme = p.__theme || waveTheme(S.wave);
  S.waveTheme = theme;
  for (const [type, count] of Object.entries(p))
    for (let i = 0; i < count; i++) S.queue.push(type);

  // Shape the queue by phase to create a readable wave story.
  const tiers = {
    probe:   ['grunt', 'runner', 'slinger'],
    // pressure layering to require hero intervention
    pressure: ['grunt', 'runner', 'shield', 'brute', 'healer', 'slinger'],
    // pressure layering to require hero intervention
    climax:   ['grunt', 'runner', 'shield', 'brute', 'healer', 'slinger', 'hunter', 'bomber', 'siege', 'ogre'],
  }[theme] || ['grunt', 'runner', 'slinger'];
  const grouped = tiers.flatMap(type => S.queue.filter(x => x === type));
  const leftovers = S.queue.filter(x => !tiers.includes(x));
  const rng = makeWaveRng(S.wave * 1000003 + 99991);
  for (let i = grouped.length - 1; i > 0; i--) {
    const j = Math.floor(rng() * (i + 1));
    [grouped[i], grouped[j]] = [grouped[j], grouped[i]];
  }
  S.queue = [...grouped, ...leftovers];

  S.spawnCount = 0;
  S.timer = .35;
  makeWaveSnapshot();

  const summary = Object.entries(p).filter(([k, v]) => v > 0 && !k.startsWith('__')).map(([k, v]) => `${k} ×${v}`).join(', ');
  toast(`${theme === 'probe' ? 'Probe' : theme === 'pressure' ? 'Pressure' : 'Climax'} wave ${S.wave}: ` + summary);
  ui();
}

// ── Enemy spawning ─────────────────────────────────────────────────
function spawn(type) {
  const entry = SPAWN_POINTS[Math.floor(Math.random() * SPAWN_POINTS.length)];
  const path  = spawnPathFor(entry);
  const w     = S.wave;

  // Base stats scale with wave
  let hp  = 50 + w * 32 + Math.pow(w, 1.55) * 11;
  let spd = .84 + w * .024;
  let val = 5, rad = 13, range = 0, shoot = 0, healCool = 0;

  // Per-type modifiers
  switch (type) {
    case 'runner':   hp *= .55; spd *= 1.75; rad = 10; val = 4;  break;
    case 'slinger':  hp *= .70; spd *= .92;  rad = 12; val = 9;  range = 290; shoot = 0.45 + Math.random() * 0.35; break;
    case 'brute':    hp *= 2.4; spd *= .60;  rad = 17; val = 12; break;
    case 'ogre':     hp *= 5.6; spd *= .46;  rad = 23; val = 38; range = 220; shoot = 1.5; break;
    case 'hunter':   val = 75;  rad = 12;    spd *= 1.10; break;
    case 'bomber':   hp *= .50; val = 50;    rad = 12; spd *= 1.90; break;
    case 'shield':   hp *= 1.3; val = 13;    rad = 15; spd *= .76; break;
    case 'healer':   hp *= .68; val = 20;    rad = 12; spd *= .86; healCool = .5; range = 255; shoot = 0.9 + Math.random() * .5; break;
    case 'siege':    hp *= 4.4; val = 30;    rad = 20; spd *= .48; break;
    case 'slimeking':hp *= 9.5; val = 150;   rad = 32; spd *= .34; range = 330; shoot = .4; break;
  }

  // Wild behavior: ~20% of non-special enemies deviate unpredictably
  const canBeWild = !['hunter', 'slimeking', 'siege', 'bomber'].includes(type);
  const wild = canBeWild && Math.random() < .20;
  const off  = (Math.random() - .5) * (wild ? 80 : 24);

  if (!S.seenEnemyThreats[type]) {
    S.seenEnemyThreats[type] = 1;
    threatToast(type);
  }

  let entryNode = path.findIndex(p => p.c === entry.c && p.r === entry.r);
  if (entryNode < 0) entryNode = 0;

  S.enemies.push({
    type, wild, off,
    x: cx(entry.c) - 28 - Math.random() * 24,
    y: cy(entry.r) + (Math.random() - .5) * 16,
    node: entryNode, entry: entry.label, path,
    hp, max: hp, spd: spd * (wild ? 1.12 : 1),
    val: val + (wild ? 2 : 0), rad, range, shoot,
    slow: 0, poison: 0, burn: 0,
    dead: 0, flash: 0, hitPulse: 0,
    healCool,
    wildTimer: .3 + Math.random() * .6,
    wildMode:  'path',
    wildX: 0, wildY: 0, wildBlend: .3, wildProgress: 1.0,
    slimeDrop: .8,  // only used by slimeking
  });
}

function nextSpawnDelay() {
  const groupSize = S.wave < 3 ? 3 : S.wave < 7 ? 4 : 5;
  const withinGroup = S.spawnCount % groupSize !== 0;
  const pressure = Math.min(S.wave, 12);
  if (withinGroup) return Math.max(.34, .58 - pressure * .018);
  const groupsSpawned = S.spawnCount / groupSize;
  const restEvery = S.wave < 5 ? 3 : 4;
  if (groupsSpawned > 0 && groupsSpawned % restEvery === 0) {
    return 5 + ((S.wave * 37 + groupsSpawned * 17) % 6);
  }
  return Math.max(.72, 1.35 - pressure * .035);
}

// ── Damage / kill helpers ─────────────────────────────────────────
function hit(e, amt, tower, byHero = false) {
  if (e.dead) return;
  // Shield bearers resist hero arrows (non-tower hits)
  if (e.type === 'shield' && !tower) amt *= .45;
  e.hp   -= Math.max(1, amt);
  if (e.type !== 'slimeking') e.flash = .08;
  e.hitPulse = Math.max(e.hitPulse || 0, .85);
  if (tower) {
    const d = TOWERS[tower.type];
    if (d.slow)   e.slow  = Math.max(e.slow, d.slow);
    if (d.burn)  { e.burn  = 2.5; e.burnD  = d.burn; }
    if (d.poison){ e.poison = 3.5; e.poisonD = d.poison * (1 + .2 * ((tower.level || 1) - 1)); }
    const fx = tower.type === 'cannon' ? 'explosion'
      : tower.type === 'cauldron' ? 'fire'
      : tower.type === 'frost' ? 'ice'
      : tower.type === 'spire' ? 'lightning'
      : tower.type === 'archer' || tower.type === 'ballista' ? 'arrow'
      : tower.type === 'spikes' || tower.type === 'barrier' || tower.type === 'barrel' || tower.type === 'tar' ? 'thunk'
      : 'arrow';
    impactFx(e.x, e.y, fx);
  } else {
    // Hero shots now add a tiny readable stagger without particle spam.
    if (byHero) {
      if (S.hero.trinketAttackSlow > 0) {
        e.slow = Math.max(e.slow || 0, S.hero.trinketAttackSlow);
      }
      const a = Math.atan2(e.y - S.hero.y, e.x - S.hero.x);
      const push = e.type === 'slimeking' ? 0 : (e.type === 'ogre' || e.type === 'siege' ? 2.2 : 6.2);
      e.x += Math.cos(a) * push;
      e.y += Math.sin(a) * push;
      e.stun = Math.max(e.stun || 0, e.type === 'ogre' || e.type === 'siege' ? .02 : .06);
      e.hitPulse = 1;
      e.heroPressure = Math.min(2.4, (e.heroPressure || 0) + 0.26);
      const fx = S.hero.weapon === 'storm' ? 'lightning'
        : S.hero.weapon === 'freeze' ? 'ice'
        : S.hero.weapon === 'crossbow' ? 'thunk'
        : S.hero.weapon === 'blunderbuss' ? 'explosion'
        : 'arrow';
      impactFx(e.x, e.y, fx);
    }
  }
  if (e.hp <= 0) kill(e, tower, byHero);
}

function heroThreatKillFeedback(e) {
  if (!e || !e.type) return;
  const cues = {
    hunter: { text: 'SAVED', c: '#9fe8ff', fx: '#7ac7ff', sfx: true },
    bomber: { text: 'GOOD CATCH', c: '#ffd07a', fx: '#ff9b32', sfx: true },
    siege: { text: 'THREAT DOWN', c: '#f0c96b', fx: '#d7c8ff', sfx: true },
    healer: { text: 'SAVED', c: '#b9d84f', fx: '#8bcf5a', sfx: false },
    runner: { text: 'LEAK CLOSED', c: '#cfe8ff', fx: '#8edcff', sfx: false },
  };
  const cue = cues[e.type];
  if (!cue) return;
  floatText(cue.text, e.x, e.y - 20, cue.c);
  shockwave(e.x, e.y, cue.fx, Math.max(40, e.rad * 1.4), .24);
  burst(e.x, e.y - 4, cue.fx, 10, 'spark', 180);
  if (cue.sfx) playSfx('threatDown');
}

function kill(e, tower, byHero = false) {
  if (e.dead) return;
  e.dead = true;
  const g = Math.floor(e.val * S.mods.gold * (S.hero.goldMult || 1) * (S.hero.trinketGoldActiveMult || 1) * (byHero ? 1.25 : 1));
  S.gold  += g;
  S.score += 50 + S.wave * 8 + (byHero ? 25 : 0);
  if (S.waveStats) {
    if (byHero) S.waveStats.heroKills++;
    else if (tower) S.waveStats.towerKills++;
    else S.waveStats.otherKills++;
    S.waveStats.goldEarned += g;
  }
  if (S.runStats) {
    if (byHero) S.runStats.heroKills++;
    else if (tower) S.runStats.towerKills++;
    else S.runStats.otherKills++;
    S.runStats.goldEarned += g;
  }
  if (tower) {
    tower.kills = (tower.kills || 0) + 1;
    if (S.sel === tower) showSelected();
  }
  if (byHero) heroThreatKillFeedback(e);
  if (g > 0) floatText('+' + g + 'g', e.x, e.y, '#ffe09c33');
  if (e.type === 'slimeking') {
    playSfx('enemyDeath');
    S.bossActive = false;
    clearSlimeTrail();
    hideBossWarning();
    const activeRing = e.leapState === 'telegraph' && Number.isFinite(e.leapTargetX) && Number.isFinite(e.leapTargetY)
      ? { x: e.leapTargetX, y: e.leapTargetY, r: 32 }
      : null;
    const spawnSafeHealthOrb = (x, y, hp = 999, full = true) => {
      const safeDist = ring => dist(x, y, ring.x, ring.y) > ring.r + 24;
      if (!activeRing || safeDist(activeRing)) {
        dropHealthOrb(x, y, hp, full);
        return true;
      }
      const offsets = [
        [0, -56], [52, -18], [-52, -18], [56, 22], [-56, 22],
        [0, -82], [78, -30], [-78, -30], [86, 34], [-86, 34],
      ];
      for (const [dx, dy] of offsets) {
        const sx = e.x + dx;
        const sy = e.y + dy;
        if (safeDist({ x: sx, y: sy, r: 0 })) {
          dropHealthOrb(sx, sy, hp, full);
          return true;
        }
      }
      dropHealthOrb(e.x, e.y - 88, hp, full);
      return false;
    };
    spawnSafeHealthOrb(e.x, e.y, 999, true);
    toast('The Slime King bursts. Full heal dropped.');
    announceWave('SLIME KING SLAIN', 'boss', 1.45);
    S.clearFlash = Math.max(S.clearFlash || 0, .9);
    impactFx(e.x, e.y, 'slime');
    burst(e.x, e.y - 18, '#d9c44a', 6, 'debris', 90);
    floatText('THE CROWN FALLS', e.x - 54, e.y - 50, '#ffe09c33');
    shake(10, .45);
    ui(); // Boss kill is a milestone — refresh UI immediately
  } else {
    playSfx('enemyDeath');
    dropRandomPowerup(e, byHero);
    burst(e.x, e.y - 4, e.freeze > 0 || e.chill > 0 ? '#dff4ff' : '#f7d38a', 6, 'spark', 90);
    burst(e.x, e.y - 2, '#8a6a43', 4, 'debris', 58);
    shockwave(e.x, e.y, e.freeze > 0 || e.chill > 0 ? '#9fdfff' : '#ffcf6a', e.rad * 1.7, .18);
  }
  boom(e.x, e.y, e.type === 'slimeking' ? '#4fa34f33' : '#b78a4a',
       e.type === 'slimeking' ? 52 : 14);
  // Note: ui() for gold/score updates is handled by the step loop epilogue, not per-kill
}

function hurtHero(dmg) {
  if (S.devInvincible) return;
  if (S.hero.inv > 0) return;
  if ((S.hero.shieldHits || 0) > 0) {
    S.hero.shieldHits--;
    S.hero.inv = .2;
    shockwave(S.hero.x, S.hero.y, '#b285ff', 54, .24);
    boom(S.hero.x, S.hero.y, '#b285ff', 8);
    floatText('SHIELDED', S.hero.x - 24, S.hero.y - 20, '#c9a2ff');
    ui();
    return;
  }
  S.hero.hp -= dmg;
  S.hero.inv  = .45;
  playSfx('hurt');
  boom(S.hero.x, S.hero.y, '#c9674333', 4);
  shake(5, .2);
  if (S.hero.hp <= 0) {
    S.hero.hp = 0;
    offerRestart('RIFT BREACHED');
  }
  ui();
}

function explodeBarrel(b) {
  if (b.dead) return;
  b.dead = true;
  boom(b.x, b.y, '#f08a2533', 35);
  impactFx(b.x, b.y, 'explosion');
  shake(10, .45);
  for (const e of S.enemies) {
    const d = dist(b.x, b.y, e.x, e.y);
    if (d < 150) hit(e, 230 * (1 - d / 170) + 40, null);
  }
  if (dist(b.x, b.y, S.hero.x, S.hero.y) < 120) hurtHero(18);
  floatText('BOOM!', b.x - 22, b.y - 22, '#ffcf3d');
}

// ── Hero step ─────────────────────────────────────────────────────
function heroStep(dt) {
  const h  = S.hero;
  if (h.spawnState === 'spawning') {
    h.spawnLock = Math.max(0, (h.spawnLock || 0) - dt);
    h.inv = Math.max(h.inv || 0, h.spawnLock);
    return;
  }
  const now = performance.now() / 1000;
  const dx = (keys.d ? 1 : 0) - (keys.a ? 1 : 0);
  const dy = (keys.s ? 1 : 0) - (keys.w ? 1 : 0);
  const l  = Math.hypot(dx, dy) || 1;
  let spd  = 210;
  const sprinting = !!(keys.Shift || keys.ShiftLeft || keys.ShiftRight || keys.shift);
  if (sprinting) spd *= 1.75;
  if (S.mods.hasteUntil > now) spd *= 1.5;
  spd *= (h.trinketMoveMult || 1) * (h.trinketMoveActiveMult || 1);
  if ((h.slimeDebuffUntil || 0) > now) spd *= .62;

  // Off-road slow
  const hc = cellAt(h.x, h.y);
  if (!isRoad(hc.c, hc.r)) spd *= .85;
  const mx = dx / l * spd * dt;
  const my = dy / l * spd * dt;
  const tryMove = (nx, ny) => {
    const cc = cellAt(nx, ny);
    return canHeroEnterCell(cc.c, cc.r);
  };
  const nx = clamp(h.x + mx, OX + 16, OX + COLS * G - 16);
  const ny = clamp(h.y + my, OY + 16, OY + ROWS * G - 16);
  if (mx && tryMove(nx, h.y)) h.x = nx;
  if (my && tryMove(h.x, ny)) h.y = ny;

  const inSlime = S.firePatches.some(f => f.slime && dist(h.x, h.y, f.x, f.y) < f.r + 14);
  if (inSlime) h.slimeDebuffUntil = Math.max(h.slimeDebuffUntil || 0, now + 1.55);

  h.inv     -= dt;
  h.cool    -= dt;
  const frenzyMult = S.mods.frenzyUntil > now ? 1.8 : 1;
  h.weaponCd = Math.max(0, (h.weaponCd || 0) - dt * (h.fireRateMult || 1) * (h.trinketFireRateMult || 1) * (h.trinketFireRateActiveMult || 1) * frenzyMult);
  const prevSecondaryCd = h.secondaryCd || 0;
  h.secondaryCd = Math.max(0, (h.secondaryCd || 0) - dt);
  h.shoveCd  = Math.max(0, h.shoveCd  - dt);
  h.weaponRecoil = Math.max(0, (h.weaponRecoil || 0) - dt * 3.5);
  if (h.blunderShieldUntil && h.blunderShieldUntil <= performance.now() / 1000) {
    h.blunderShieldUntil = 0;
    floatText('SHIELD DOWN', h.x - 34, h.y - 24, '#cfe8ff');
  }
  if (prevSecondaryCd > 0 && h.secondaryCd <= 0) playSfx('secondaryReady');
  if (h.charging) h.charge = Math.min(1, h.charge + dt * 0.62);

  if (mouse.down && h.weaponCd <= 0 && S.phase === 'combat' && S.gameState !== 'upgradeChoice' && !S.pendingUpgrade && !h.charging && !S.selected) shootHero();
}

function shootHero() {
  const h = S.hero;
  const w = WEAPONS[h.weapon] || WEAPONS.blunderbuss;
  const m = getMouseWorldPosition();
  const a = Math.atan2(m.y - h.y, m.x - h.x);
  if (w.primaryFire) w.primaryFire(h, a);
}

function weaponSecondaryDown() {
  const h = S.hero;
  if (S.phase !== 'combat') return;
  const w = WEAPONS[h.weapon] || WEAPONS.blunderbuss;
  const m = getMouseWorldPosition();
  const a = Math.atan2(m.y - h.y, m.x - h.x);
  if (h.weapon === 'ranger') {
    if (h.secondaryCd <= 0 && !h.charging) {
      h.charging = true;
      h.charge = 0;
      playSfx('secondaryUsed');
    }
    return;
  }
  const beforeCd = h.secondaryCd;
  const beforeShield = h.blunderShieldUntil || 0;
  if (w.secondaryFire) w.secondaryFire(h, a);
  if ((h.secondaryCd || 0) !== beforeCd || (h.blunderShieldUntil || 0) !== beforeShield) playSfx('secondaryUsed');
}

function weaponSecondaryUp() {
  const h = S.hero;
  if (h.weapon !== 'ranger' || !h.charging) return;
  const m = getMouseWorldPosition();
  const aim = Math.atan2(m.y - h.y, m.x - h.x);
  const charge = Math.max(.15, h.charge || 0);
  const fullCharge = charge >= .9;
  const chargePower = fullCharge ? 1 : charge;
  const speed = 1020;
  const range = 300 + chargePower * 160 + (fullCharge ? 80 : 0);
  const dmg = 30 + h.level * 7 + chargePower * 84 + (fullCharge ? 82 : 0);
  S.heroShots.push({
    x: h.x, y: h.y,
    vx: Math.cos(aim) * speed, vy: Math.sin(aim) * speed,
    dmg, life: range / speed, range, travel: 0, type: 'chargedArrow', weapon: 'ranger', pierce: true,
    hits: fullCharge ? 5 : 2,
    charged: true,
    charge: chargePower,
    fullCharge,
  });
  if (fullCharge) {
    const fxX = h.x + Math.cos(aim) * 50;
    const fxY = h.y + Math.sin(aim) * 50;
    shockwave(fxX, fxY, '#8fd6ff', 122, .42);
    shockwave(fxX, fxY, '#f4cf6f', 82, .32);
    shockwave(fxX, fxY, '#ffffff', 46, .18);
    burst(fxX, fxY, '#e6f8ff', 18, 'spark', 220);
    burst(fxX, fxY, '#ffe08c', 14, 'spark', 180);
    for (const e of S.enemies) {
      if (e.dead) continue;
      const d = dist(h.x, h.y, e.x, e.y);
      if (d > 300) continue;
      const a = Math.atan2(e.y - h.y, e.x - h.x);
      const diff = Math.abs(Math.atan2(Math.sin(a - aim), Math.cos(a - aim)));
      if (diff < .30) {
        e.kx = Math.cos(a) * 380;
        e.ky = Math.sin(a) * 380;
        e.stun = Math.max(e.stun || 0, e.type === 'ogre' || e.type === 'siege' ? .32 : .52);
        if (['ogre', 'siege', 'brute', 'shield'].includes(e.type)) e.heroPressure = Math.min(4, (e.heroPressure || 0) + 1.4);
      }
    }
    shake(4.5, .22);
    playSfx('threatDown');
  } else if (charge > .45) {
    shockwave(h.x + Math.cos(aim) * 46, h.y + Math.sin(aim) * 46, '#8fd6ff', 72, .24);
    burst(h.x + Math.cos(aim) * 46, h.y + Math.sin(aim) * 46, '#bfe7ff', 8, 'spark', 120);
  }
  h.secondaryCd = 0.25;
  h.charging = false;
  h.charge = 0;
}

function useLifeFlask() {
  if ((S.hero.flaskCharges || 0) <= 0) return;
  S.hero.flaskCharges--;
  const heal = Math.floor(S.hero.max * 0.5);
  S.hero.hp = Math.min(S.hero.max, S.hero.hp + heal);
  shockwave(S.hero.x, S.hero.y, '#b9d84f', 86, .35);
  boom(S.hero.x, S.hero.y, '#b9d84f', 12);
  floatText('LIFE FLASK', S.hero.x - 28, S.hero.y - 26, '#b9d84f');
  ui();
}

function useBlunderShield() {
  const h = S.hero;
  if (S.phase !== 'combat' || h.secondaryCd > 0) return;
  const m = getMouseWorldPosition();
  const aim = Math.atan2(m.y - h.y, m.x - h.x);
  const now = performance.now() / 1000;
  const duration = 3 * (h.blunderShieldMult || 1);
  h.blunderShieldUntil = Math.max(h.blunderShieldUntil || 0, now + duration);
  h.secondaryCd = WEAPONS.blunderbuss.secondaryCooldown;
  shockwave(h.x, h.y, '#8fd6ff', 78, .24);
  shockwave(h.x, h.y, '#f4cf6f', 54, .18);
  boom(h.x + Math.cos(aim) * 22, h.y + Math.sin(aim) * 22, '#cfe8ff', 10);
  floatText('SHIELD UP!', h.x - 30, h.y - 30, '#cfe8ff');
  shake(3, .1);
  ui();
}

// ── Tower firing ──────────────────────────────────────────────────
function targetForTower(t) {
  const d  = TOWERS[t.type];
  const rr = d.r * (1 + .08 * (t.level - 1));
  let best = null, bp = -1;
  for (const e of S.enemies) {
    if (!e.dead && dist(t.x, t.y, e.x, e.y) <= rr && e.node > bp) {
      bp = e.node; best = e;
    }
  }
  return best;
}

function towerTick(t, dt) {
  const d = TOWERS[t.type];
  if (towerIsDisabled(t)) return;
  const overclockActive = S.mods.overclockUntil > performance.now() / 1000 && dist(t.x, t.y, S.hero.x, S.hero.y) <= 160;
  const towerSpeed = overclockActive ? 2 : (S.hero.overclockAura && dist(t.x, t.y, S.hero.x, S.hero.y) <= 160 ? 1.1 : 1);
  t.cool -= dt * towerSpeed;

  // Trap towers hit everything in radius
  if (d.trap) {
    if (t.cool > 0) return;
    const dmgMult = 1 + .25 * ((t.level || 1) - 1);
    const trapResetMult = S.mods.trapReset || 1;
    const tarRateMult = S.mods.trapTarRate || 1;
    const trapPushMult = S.mods.trapPush || 1;
    const spikeDmgMult = S.mods.trapSpikeDmg || 1;
    const dir = t.dir || 1;
    const ang = [-Math.PI/2, 0, Math.PI/2, Math.PI][dir];
    const nx = Math.cos(ang), ny = Math.sin(ang);
    let trig = false;
    for (const e of S.enemies) {
      if (e.dead) continue;
      const dx = e.x - t.x, dy = e.y - t.y;
      const distE = Math.hypot(dx, dy);
      if (d.triggerTrap) {
        if (distE > 28) continue;
        hit(e, d.d * dmgMult * spikeDmgMult, t);
        e.stun = Math.max(e.stun || 0, .22);
        e.kx = nx * 130; e.ky = ny * 130;
        t.anim = .32; trig = true;
        continue;
      }
      if (d.directional) {
        const dot = dx * nx + dy * ny;
        const perp = Math.abs(dx * ny - dy * nx);
        if (dot < 0 || dot > (d.coneRange || 120) || perp > (d.coneWidth || .8) * 64) continue;
        const resist = e.type === 'slimeking' ? .12
          : e.type === 'ogre' ? .26
          : e.type === 'siege' ? .22
          : e.type === 'brute' ? .48
          : 1;
        const p = (d.push || d.launch || 180) * resist * trapPushMult;
        e.kx = nx * p; e.ky = ny * p;
        e.stun = Math.max(e.stun || 0, d.spring ? .36 : d.mace ? .24 : .16);
        if (d.spring) e.air = .26;
        hit(e, d.d * dmgMult * (d.triggerTrap ? spikeDmgMult : 1), t);
        trig = true;
      } else if (distE <= d.r) {
        hit(e, d.d * dmgMult, t);
        trig = true;
      }
    }
    if (trig) boom(t.x + nx * 20, t.y + ny * 20, d.fill, d.spring ? 8 : 5);
    t.cool = d.rate * trapResetMult * (S.hero.trapCooldownMult || 1) / towerSpeed;
    t.anim = Math.max(t.anim || 0, d.spring ? .36 : d.directional ? .24 : .18);
    return;
  }

  if (t.cool > 0) return;
  const e = targetForTower(t);
  if (!e) return;

  t.cool = d.rate / (1 + .18 * (t.level - 1)) / towerSpeed;
  t.anim = Math.max(t.anim || 0, t.type === 'cannon' ? .32 : t.type === 'archer' ? .2 : t.type === 'cauldron' ? .28 : .16);

  // Barracks: melee slow + damage, no projectile
  if (t.type === 'barracks') {
    e.slow = Math.max(e.slow, d.slow || .25);
    hit(e, d.d * (1 + .25 * (t.level - 1)) * S.mods.dmg, t);
    boom(e.x, e.y, d.fill, 3);
    return;
  }

  // Lightning Spire: chain bolts
  if (d.chain) {
    let cur = e; const seen = [];
    for (let i = 0; i < d.chain + (t.level || 1) + (S.mods.spireChain || 0); i++) {
      if (!cur || seen.includes(cur)) break;
      seen.push(cur);
      const from = i ? seen[i - 1] : t;
      S.parts.push({ kind: 'bolt', x: from.x, y: from.y, x2: cur.x, y2: cur.y, life: .22, c: d.fill });
      hit(cur, d.d * (1 + .22 * (t.level - 1)) * Math.pow(.78, i) * S.mods.dmg, t);
      impactFx(cur.x, cur.y, 'lightning');
      cur = S.enemies.filter(o => !o.dead && !seen.includes(o) && dist(cur.x, cur.y, o.x, o.y) < 135)
               .sort((a, b) => dist(cur.x, cur.y, a.x, a.y) - dist(cur.x, cur.y, b.x, b.y))[0];
    }
    return;
  }

  // Standard projectile
  S.shots.push({
    x: t.x, y: t.y, tx: e,
    spd: d.splash ? 360 : 540,
    dmg: d.d * (1 + .32 * (t.level - 1)) * S.mods.dmg,
    t, d, life: 2,
  });
}


// ── Player 2 engineer ────────────────────────────────────────────

// AI engineer brain: returns a fake input object each frame
function aiEngineerInput() {
  const e = S.engineer;

  // Find nearest enemy to shoot at
  const nearestEnemy = S.enemies
    .filter(en => !en.dead)
    .sort((a, b) => dist(e.x, e.y, a.x, a.y) - dist(e.x, e.y, b.x, b.y))[0];

  let moveX = 0, moveY = 0;
  let shoot = false;
  let aimX = e.aimX, aimY = e.aimY;

  if (nearestEnemy && S.phase === 'combat') {
    // Engage nearby enemies
    aimX = nearestEnemy.x; aimY = nearestEnemy.y;
    const ed = dist(e.x, e.y, nearestEnemy.x, nearestEnemy.y);
    if (ed > 200) {
      // Close in gently — don't charge into melee
      moveX = nearestEnemy.x - e.x;
      moveY = nearestEnemy.y - e.y;
    }
    if (ed < 340 && e.cool <= 0) shoot = true;
  } else {
    // Idle: drift toward center of map
    const cx_ = OX + COLS * G / 2, cy_ = OY + ROWS * G / 2;
    const cd = dist(e.x, e.y, cx_, cy_);
    if (cd > 80) { moveX = cx_ - e.x; moveY = cy_ - e.y; }
  }

  const ml = Math.hypot(moveX, moveY) || 1;
  return {
    up:    moveY < -10,
    down:  moveY > 10,
    left:  moveX < -10,
    right: moveX > 10,
    shoot,
    volley: false,
    oil: false,
    aimX, aimY,
  };
}

function engineerInput() {
  if (S.net.mode === 'host') return S.net.remoteInput;
  if (S.aiEngineerOwned && S.net.mode === 'solo') return aiEngineerInput();
  const m = getMouseWorldPosition();
  return {
    up: keys.ArrowUp || keys.w,
    down: keys.ArrowDown || keys.s,
    left: keys.ArrowLeft || keys.a,
    right: keys.ArrowRight || keys.d,
    shoot: mouse.down,
    volley: !!keys.q,
    oil: !!keys.e,
    aimX: m.x,
    aimY: m.y,
  };
}

function engineerStep(dt) {
  const e = S.engineer;
  if (!e.active || e.hp <= 0) return;
  const inp = engineerInput();
  e.aimX = inp.aimX || e.aimX;
  e.aimY = inp.aimY || e.aimY;
  const dx = (inp.right ? 1 : 0) - (inp.left ? 1 : 0);
  const dy = (inp.down ? 1 : 0) - (inp.up ? 1 : 0);
  const l = Math.hypot(dx, dy) || 1;
  let spd = 195;
  const ec = cellAt(e.x, e.y);
  if (!isRoad(ec.c, ec.r)) spd *= .85;
  e.x = clamp(e.x + dx / l * spd * dt, OX + 16, OX + COLS * G - 16);
  e.y = clamp(e.y + dy / l * spd * dt, OY + 16, OY + ROWS * G - 16);
  e.cool -= dt; e.inv -= dt;
  e.volleyCd = Math.max(0, (e.volleyCd || 0) - dt);
  e.oilCd = Math.max(0, (e.oilCd || 0) - dt);
  // engineer does not attack in 4.4.0
}

function shootEngineer(e) {
  const a = Math.atan2(e.aimY - e.y, e.aimX - e.x);
  const speed = 820;
  // P2 Arc Rifle: stronger, faster, longer range, and no friendly-fire against towers.
