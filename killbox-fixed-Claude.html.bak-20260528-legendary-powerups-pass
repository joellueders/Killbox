    ctx.fillStyle = '#43150e';
    ctx.beginPath();
    ctx.moveTo(o.x, o.y - 11);
    ctx.lineTo(o.x + 10, o.y - 2);
    ctx.lineTo(o.x + 5, o.y + 11);
    ctx.lineTo(o.x - 5, o.y + 11);
    ctx.lineTo(o.x - 10, o.y - 2);
    ctx.closePath(); ctx.fill();
    ctx.strokeStyle = '#ffd0bf';
    ctx.lineWidth = 2;
    ctx.beginPath(); ctx.moveTo(o.x - 8, o.y - 1); ctx.lineTo(o.x + 8, o.y - 1); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(o.x - 1, o.y - 8); ctx.lineTo(o.x - 1, o.y + 8); ctx.stroke();
  } else if (type === 'haste') {
    ctx.fillStyle = '#173a4a';
    ctx.beginPath();
    ctx.moveTo(o.x + 4, o.y - 11);
    ctx.lineTo(o.x - 10, o.y);
    ctx.lineTo(o.x - 2, o.y);
    ctx.lineTo(o.x - 6, o.y + 11);
    ctx.lineTo(o.x + 10, o.y - 1);
    ctx.lineTo(o.x + 2, o.y - 1);
    ctx.closePath(); ctx.fill();
    ctx.strokeStyle = '#d8f4ff';
    ctx.lineWidth = 2;
    ctx.beginPath(); ctx.moveTo(o.x - 7, o.y - 8); ctx.lineTo(o.x + 7, o.y - 8); ctx.stroke();
  } else if (type === 'freeze') {
    ctx.fillStyle = '#13465e';
    ctx.beginPath();
    ctx.moveTo(o.x, o.y - 12);
    ctx.lineTo(o.x + 8, o.y - 2);
    ctx.lineTo(o.x + 4, o.y + 10);
    ctx.lineTo(o.x - 4, o.y + 10);
    ctx.lineTo(o.x - 8, o.y - 2);
    ctx.closePath(); ctx.fill();
    ctx.strokeStyle = '#e7fbff';
    ctx.lineWidth = 2;
    ctx.beginPath(); ctx.moveTo(o.x - 7, o.y + 1); ctx.lineTo(o.x + 7, o.y + 1); ctx.stroke();
  } else if (type === 'bomb') {
    ctx.fillStyle = '#3b2411';
    ctx.beginPath(); ctx.arc(o.x, o.y + 2, 8, 0, 7); ctx.fill();
    ctx.fillStyle = '#ffb15b';
    ctx.beginPath(); ctx.arc(o.x + 2, o.y - 7, 3, 0, 7); ctx.fill();
    ctx.strokeStyle = '#ffdcb2';
    ctx.lineWidth = 2;
    ctx.beginPath(); ctx.moveTo(o.x + 1, o.y - 11); ctx.lineTo(o.x + 8, o.y - 18); ctx.stroke();
  } else if (type === 'reset') {
    ctx.strokeStyle = '#ead4ff';
    ctx.lineWidth = 4;
    ctx.beginPath(); ctx.arc(o.x, o.y, o.r - 1, 0, 7); ctx.stroke();
    ctx.strokeStyle = '#c78cff';
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.arc(o.x, o.y, o.r - 8, -0.2, Math.PI * 1.25);
    ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(o.x + 6, o.y - 11);
    ctx.lineTo(o.x + 12, o.y - 5);
    ctx.lineTo(o.x + 3, o.y - 4);
    ctx.closePath();
    ctx.fillStyle = '#c78cff';
    ctx.fill();
    ctx.beginPath();
    ctx.moveTo(o.x - 6, o.y + 11);
    ctx.lineTo(o.x - 12, o.y + 5);
    ctx.lineTo(o.x - 3, o.y + 4);
    ctx.closePath();
    ctx.fill();
  } else if (type === 'rift') {
    ctx.strokeStyle = '#cfefff';
    ctx.lineWidth = 3;
    ctx.beginPath(); ctx.arc(o.x, o.y, o.r - 2, 0, 7); ctx.stroke();
    ctx.fillStyle = '#8edcff';
    ctx.beginPath(); ctx.arc(o.x, o.y, 4, 0, 7); ctx.fill();
  } else {
    ctx.fillStyle = '#2f6f2f';
    ctx.fillRect(o.x - 2,          o.y - (o.full ? 12 : 8), 4,          o.full ? 24 : 16);
    ctx.fillRect(o.x - (o.full ? 12 : 8), o.y - 2,          o.full ? 24 : 16, 4);
