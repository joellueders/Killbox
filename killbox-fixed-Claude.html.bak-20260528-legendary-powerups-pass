    ctx.fillStyle = appearance >= 4 ? '#d0da73' : '#dfe04a';
    ctx.beginPath();
    ctx.arc(-14, -22, 7, 0, 7); ctx.arc(5, -20, 8, 0, 7); ctx.arc(20, -6, 6, 0, 7); ctx.arc(-2, 9, 5, 0, 7);
    ctx.fill();
    ctx.fillStyle = '#fff2a8';
    ctx.beginPath(); ctx.arc(-8, 7, 4, 0, 7); ctx.arc(14, 16, 5, 0, 7); ctx.arc(0, -2, 3, 0, 7); ctx.fill();
  }
  if (appearance >= 4) {
    ctx.strokeStyle = '#5f5a4f';
    ctx.lineWidth = 4;
