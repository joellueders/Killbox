  };
  if (Array.isArray(explicit)) {
    for (const k of explicit) {
      const icon = choose(k);
      if (icon) return icon;
    }
  } else {
    const icon = choose(explicit);
    if (icon) return icon;
  }
  const targets = new Set([...(Array.isArray(up.weapons) ? up.weapons : []), ...(Array.isArray(up.items) ? up.items : [])]);
  for (const k of targets) {
    const icon = choose(k);
    if (icon) return icon;
  }
