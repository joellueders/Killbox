function drawFeralRunner(e, base) { drawHumanoidBase(e, base, '#9bb84a'); ctx.strokeStyle='#f07b25'; ctx.lineWidth=4; ctx.beginPath(); ctx.moveTo(-3,-24); ctx.lineTo(3,-34); ctx.lineTo(9,-24); ctx.stroke(); ctx.strokeStyle='#1e1008'; ctx.beginPath(); ctx.moveTo(-e.rad,6); ctx.lineTo(-e.rad-12,16); ctx.moveTo(e.rad,6); ctx.lineTo(e.rad+12,16); ctx.stroke(); }
function drawStoneSlinger(e, base) { drawHumanoidBase(e, '#5d4a74', '#7ea64a'); ctx.strokeStyle='#d6b475'; ctx.lineWidth=3; ctx.beginPath(); ctx.arc(12,-4,14,-1,1); ctx.stroke(); ctx.fillStyle='#9c8c75'; ctx.beginPath(); ctx.arc(24,-4,4,0,7); ctx.fill(); }
function drawButcherBrute(e, base) { drawHumanoidBase(e, '#7a382a', '#c7b58f'); ctx.fillStyle='#b83b2f'; ctx.fillRect(-11,2,22,16); ctx.fillStyle='#3a2a20'; ctx.fillRect(8,-8,16,8); }
function drawGateOgre(e, base) { drawHumanoidBase(e, '#4e3628', '#738564'); ctx.fillStyle='#6a6a6a'; ctx.fillRect(-16,-14,32,10); ctx.fillStyle='#8a6a44'; ctx.fillRect(10,-2,18,8); }
function drawSaboteur(e, base) { drawHumanoidBase(e, '#241717', '#7f9f44'); ctx.fillStyle='#111'; ctx.beginPath(); ctx.moveTo(-10,-7); ctx.lineTo(0,-26); ctx.lineTo(10,-7); ctx.closePath(); ctx.fill(); ctx.fillStyle='#c6413b'; ctx.fillRect(8,5,10,8); }
function drawPowderLunatic(e, base, blink) { drawHumanoidBase(e, '#d0872e', '#a77a2e'); ctx.fillStyle='#8b4424'; ctx.beginPath(); ctx.arc(0,e.rad*.55,e.rad*.55,0,7); ctx.fill(); ctx.strokeStyle=blink?'#ffcf3d':'#c01818'; ctx.lineWidth=4; ctx.beginPath(); ctx.arc(0,0,e.rad+7,0,7); ctx.stroke(); }
