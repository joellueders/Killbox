  const pal = appearance >= 4
    ? { base: '#42503b', tint: '#5d6e56', glow: '#b5dfae', muck: '#1e281b', junk: '#8a7a63' }
    : appearance >= 3
      ? { base: '#d7e03a', tint: '#9aa11b', glow: '#f4ff8d', muck: '#798a1c', junk: '#d7d04f' }
      : appearance >= 2
        ? { base: '#213725', tint: '#476f3d', glow: '#9bdd79', muck: '#13251a', junk: '#8d7d5e' }
        : { base: base, tint: '#3f8a3f', glow: '#b9d84f', muck: '#1c5d28', junk: '#d9c44a' };

  ctx.save();
  ctx.globalCompositeOperation = 'source-over';
  if (e.leapState === 'telegraph') {
    const tele = Math.min(1, e.leapTelegraph / 1.0);
    const tx = Number.isFinite(e.leapTargetX) ? e.leapTargetX : e.x;
    const ty = Number.isFinite(e.leapTargetY) ? e.leapTargetY : e.y;
    ctx.globalAlpha = .25 + (1 - tele) * .4;
    ctx.fillStyle = '#c66bff';
    ctx.beginPath();
    ctx.arc(0, 8, e.rad * 1.7 * visScale, 0, 7);
    ctx.fill();
    ctx.globalAlpha = .9;
    ctx.strokeStyle = '#f1d6ff';
    ctx.lineWidth = 4;
    ctx.beginPath();
    ctx.arc(tx - e.x, ty - e.y, 22, 0, 7);
    ctx.stroke();
    ctx.globalAlpha = .55;
    ctx.strokeStyle = '#f1d6ff';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.arc(tx - e.x, ty - e.y, 32, 0, 7);
    ctx.stroke();
    ctx.globalAlpha = 1;
