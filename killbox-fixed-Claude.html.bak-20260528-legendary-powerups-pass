}

// ── Password save system ──────────────────────────────────────────
function saveObj() {
  return {
    v:  S.version,
    lv: S.levelId || 'field',
    l:  S.lives,
    g:  Math.floor(S.gold),
    w:  S.wave,
    sc: S.score,
    hero: { x: Math.round(S.hero.x), y: Math.round(S.hero.y), hp: Math.round(S.hero.hp), level: S.hero.level },
    tw: S.towers.map(t => {
      const o = { type: t.type, c: t.c, r: t.r, onRoad: t.onRoad, x: Math.round(t.x), y: Math.round(t.y), level: t.level, kills: t.kills, sold: Math.round(t.sold) };
      if (towerDisabledUntil(t) > performance.now() / 1000) o.disabledUntil = towerDisabledUntil(t);
      if (towerHasDurability(t)) { o.hp = Math.round(t.hp); o.max = t.max; }
      return o;
    }),
    ba: S.barriers.map(b => ({ c: b.c, r: b.r, hp: Math.round(b.hp), sold: Math.round(b.sold) })),
    br: S.barrels.map(b  => ({ c: b.c, r: b.r })),
    m:  S.mods,
    ae: S.aiEngineerOwned ? 1 : 0,
    bossAppearance: S.bossAppearance || 0,
    slimeKingAppearances: S.slimeKingAppearances || 0,
  };
}

function crc(str) {
  let h = 2166136261;
  for (let i = 0; i < str.length; i++) { h ^= str.charCodeAt(i); h = Math.imul(h, 16777619); }
  return h >>> 0;
}

const SALT = 'KILLBOX37-DARK-HARVEST-SALT';
function enc(str) {
  let out = '';
  for (let i = 0; i < str.length; i++)
    out += String.fromCharCode(str.charCodeAt(i) ^ SALT.charCodeAt(i % SALT.length) ^ ((i * 37 + 91) & 255));
  return btoa(out).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
}

function dec(s) {
  s = s.trim().replace(/-/g, '+').replace(/_/g, '/');
  while (s.length % 4) s += '=';
  const raw = atob(s); let out = '';
  for (let i = 0; i < raw.length; i++)
    out += String.fromCharCode(raw.charCodeAt(i) ^ SALT.charCodeAt(i % SALT.length) ^ ((i * 37 + 91) & 255));
  return out;
}

function makePass() {
  const json = JSON.stringify(saveObj());
  const pack = JSON.stringify({ p: json, c: crc(json) });
  const code = 'KBOX37.' + enc(pack);
  $('pass').value = code;
  navigator.clipboard && navigator.clipboard.writeText(code).catch(() => {});
  toast('Killbox ' + S.version + ' password created.');
}

function loadPass() {
  try {
    const s = $('pass').value.trim();
    if (!s.startsWith('KBOX37.') && !s.startsWith('KBOX34.') && !s.startsWith('KBOX33.')) throw Error();

    // Support both 3.3 and 3.4 passwords
    const prefix = s.startsWith('KBOX37.') ? 'KBOX37.' : s.startsWith('KBOX34.') ? 'KBOX34.' : 'KBOX33.';
    const pack = JSON.parse(dec(s.slice(prefix.length)));
    if (crc(pack.p) !== pack.c) throw Error();
    const o = JSON.parse(pack.p);
    applyLevel(o.lv || 'field', { silent: true });

    S.lives = o.l; S.gold = o.g; S.wave = o.w; S.score = o.sc;
    S.hero  = { ...S.hero, ...o.hero, cool: 0, inv: 0, dash: 0, dashCd: 0 };
    S.towers   = (o.tw || []).map(t => {
      const tw = towerHasDurability(t) ? ({ ...t, hp: t.hp || t.max, cool: 0 }) : ({ ...t, cool: 0 });
      if (t.disabledUntil) tw.disabledUntil = t.disabledUntil;
      return tw;
    });
    S.barriers = (o.ba || []).map(b => ({ ...b, x: cx(b.c), y: cy(b.r), max: 520 }));
    S.barrels  = (o.br || []).map(b => ({ ...b, x: cx(b.c), y: cy(b.r), hp: 35, rad: 22 }));
    S.mods     = o.m || { gold: 1.14, dmg: 1 };
    S.aiEngineerOwned = !!o.ae;
    S.bossAppearance = o.bossAppearance || 0;
    S.slimeKingAppearances = o.slimeKingAppearances || 0;
    if (S.aiEngineerOwned) { S.engineer.active = true; S.engineer.hp = S.engineer.max; }
    S.enemies = []; S.shots = []; S.heroShots = []; S.enemyShots = [];
    S.parts = []; S.texts = []; S.oilPatches = []; S.firePatches = []; S.healthOrbs = [];
    S.queue = []; S.waveActive = false; S.phase = 'build';
    S.started = true; S.gameOver = false;
    rebuildPath();
    $('start').classList.add('hidden');
    toast('Harvest Seal loaded.');
    ui();
  } catch (e) {
    toast('Invalid Harvest Seal.');
  }
}


// ── Manual-code WebRTC co-op ─────────────────────────────────────
const RTC_CONFIG = { iceServers: [{ urls: 'stun:stun.l.google.com:19302' }] };

function waitIce(pc) {
  return new Promise(resolve => {
    if (pc.iceGatheringState === 'complete') return resolve();
    const done = () => { if (pc.iceGatheringState === 'complete') { pc.removeEventListener('icegatheringstatechange', done); resolve(); } };
    pc.addEventListener('icegatheringstatechange', done);
    setTimeout(resolve, 2600);
  });
}
function packDesc(desc) { return btoa(JSON.stringify(desc)); }
function unpackDesc(code) { return JSON.parse(atob(code.trim())); }
function setMpStatus(msg) { if ($('mpStatus')) $('mpStatus').textContent = msg; }
function wireChannel(dc) {
  S.net.dc = dc;
  dc.onopen = () => {
    S.net.connected = true;
    S.engineer.active = true;
    setMpStatus(S.net.mode === 'host' ? 'Host connected' : 'Guest connected');
    toast('Co-op connected.'); ui();
  };
  dc.onclose = () => {
    S.net.connected = false;
    // In solo, keep engineer active if purchased; otherwise deactivate
    if (!S.aiEngineerOwned) S.engineer.active = false;
    setMpStatus('Disconnected'); toast('Co-op disconnected.'); ui();
  };
  dc.onmessage = ev => handleNetMessage(ev.data);
}
async function createHostCode() {
  try {
    S.net.mode = 'host'; S.engineer.active = true;
    const pc = new RTCPeerConnection(RTC_CONFIG); S.net.pc = pc;
    wireChannel(pc.createDataChannel('killbox40'));
    const offer = await pc.createOffer(); await pc.setLocalDescription(offer); await waitIce(pc);
    $('hostCode').value = packDesc(pc.localDescription);
    setMpStatus('Host code ready'); toast('Send the host code to player 2.'); ui();
  } catch (err) { console.error(err); toast('Host code failed.'); }
}
async function createJoinCode() {
  try {
    S.net.mode = 'guest';
    const pc = new RTCPeerConnection(RTC_CONFIG); S.net.pc = pc;
    pc.ondatachannel = ev => wireChannel(ev.channel);
    await pc.setRemoteDescription(unpackDesc($('hostCode').value));
    const answer = await pc.createAnswer(); await pc.setLocalDescription(answer); await waitIce(pc);
    $('joinCode').value = packDesc(pc.localDescription);
    setMpStatus('Join code ready'); toast('Send the join code back to host.');
  } catch (err) { console.error(err); toast('Join code failed. Check pasted host code.'); }
}
async function acceptJoinCode() {
  try {
    if (!S.net.pc || S.net.mode !== 'host') return toast('Create a host code first.');
    await S.net.pc.setRemoteDescription(unpackDesc($('joinCode').value));
    setMpStatus('Connecting'); toast('Join code accepted.');
  } catch (err) { console.error(err); toast('Accept join failed. Check pasted join code.'); }
}
function copyActiveMpCode() {
  const text = ($('joinCode') && $('joinCode').value) || ($('hostCode') && $('hostCode').value) || '';
  if (!text) return toast('No code to copy.');
  copyTextToClipboard(text, 'Code copied.');
}
function netSend(obj) {
  const dc = S.net.dc;
  if (dc && dc.readyState === 'open') dc.send(JSON.stringify(obj));
}
function handleNetMessage(raw) {
  let msg; try { msg = JSON.parse(raw); } catch { return; }
  if (S.net.mode === 'host' && msg.type === 'input') {
    const prev = S.net.remoteInput || {};
    const inp = msg.input || {};
    if (inp.volley && !prev.volley) useEngineerVolley();
    if (inp.oil && !prev.oil) useEngineerOil();
    S.net.remoteInput = inp;
  } else if (S.net.mode === 'guest' && msg.type === 'state') {
    applySnapshot(msg.state);
  }
}
function makeSnapshot() {
  const m = getMouseWorldPosition();
  return {
    version:S.version, levelId:S.levelId, speed:S.speed, started:S.started, paused:S.paused, gameOver:S.gameOver,
    lives:S.lives, gold:S.gold, wave:S.wave, score:S.score, phase:S.phase, waveActive:S.waveActive,
    mods: { ...S.mods },
    selected:S.selected, hero:S.hero, engineer:S.engineer, towers:S.towers, barriers:S.barriers, barrels:S.barrels,
    enemies:S.enemies, shots:S.shots, heroShots:S.heroShots, enemyShots:S.enemyShots, parts:S.parts, texts:S.texts,
    oilPatches:S.oilPatches, firePatches:S.firePatches.map(({ t, ...patch }) => ({ ...patch })), healthOrbs:S.healthOrbs, waveStats:S.waveStats, runStats:S.runStats, queue:S.queue, timer:S.timer, spawnCount:S.spawnCount, bossActive:S.bossActive,
