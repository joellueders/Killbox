const AUDIO = {
  ctx: null,
  master: null,
  unlocked: false,
  muted: false,
  volume: 0.5,
};
function ensureAudio() {
  if (AUDIO.ctx) return AUDIO.ctx;
  const AC = window.AudioContext || window.webkitAudioContext;
  if (!AC) return null;
  AUDIO.ctx = new AC();
  AUDIO.master = AUDIO.ctx.createGain();
  AUDIO.master.gain.value = 0.5;
  AUDIO.master.connect(AUDIO.ctx.destination);
  return AUDIO.ctx;
}
function unlockAudio() {
  const ctx = ensureAudio();
  if (!ctx) return;
  if (ctx.state === 'suspended') ctx.resume().catch(() => {});
  AUDIO.unlocked = true;
}
function setAudioMuted(on) {
  AUDIO.muted = !!on;
  if (AUDIO.master) AUDIO.master.gain.value = AUDIO.muted ? 0 : AUDIO.volume;
  ui();
}
function setAudioVolume(v) {
  const n = clamp(Number(v) || 0, 0, 1);
  AUDIO.volume = n;
  if (AUDIO.master) AUDIO.master.gain.value = AUDIO.muted ? 0 : AUDIO.volume;
  ui();
}
function playNoise(duration = 0.12, gain = 0.12, tone = 0) {
  const ctx = ensureAudio();
  if (!ctx || AUDIO.muted || !AUDIO.unlocked) return;
  const buffer = ctx.createBuffer(1, Math.max(1, Math.floor(ctx.sampleRate * duration)), ctx.sampleRate);
  const data = buffer.getChannelData(0);
  for (let i = 0; i < data.length; i++) {
    const env = 1 - i / data.length;
    data[i] = (Math.random() * 2 - 1) * env * env * 0.9 + Math.sin(i * tone) * 0.02;
  }
  const src = ctx.createBufferSource();
  src.buffer = buffer;
  const filt = ctx.createBiquadFilter();
  filt.type = 'lowpass';
  filt.frequency.value = 2400;
  const g = ctx.createGain();
  g.gain.setValueAtTime(gain, ctx.currentTime);
  g.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + duration);
  src.connect(filt);
  filt.connect(g);
  g.connect(AUDIO.master);
  src.start();
  src.stop(ctx.currentTime + duration + 0.02);
}
function playTone({ freq = 440, end = freq, type = 'sine', duration = 0.08, gain = 0.12, detune = 0, glide = false }) {
  const ctx = ensureAudio();
  if (!ctx || AUDIO.muted || !AUDIO.unlocked) return;
  const osc = ctx.createOscillator();
  const g = ctx.createGain();
  osc.type = type;
  osc.frequency.setValueAtTime(freq, ctx.currentTime);
  if (glide) osc.frequency.exponentialRampToValueAtTime(Math.max(20, end), ctx.currentTime + duration);
  else if (end !== freq) osc.frequency.setValueAtTime(end, ctx.currentTime + duration * 0.92);
  if (detune) osc.detune.setValueAtTime(detune, ctx.currentTime);
  g.gain.setValueAtTime(gain, ctx.currentTime);
  g.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + duration);
  osc.connect(g);
  g.connect(AUDIO.master);
  osc.start();
  osc.stop(ctx.currentTime + duration + 0.02);
}
function playChime(notes, duration = 0.14, gain = 0.12, type = 'triangle') {
  for (const n of notes) playTone({ freq: n, type, duration, gain });
}
function playSfx(kind) {
  unlockAudio();
  switch (kind) {
    case 'ui':
      playTone({ freq: 880, end: 760, type: 'triangle', duration: .05, gain: .09, glide: true });
