  margin-top: 4px;
  color: #f2dec0;
  font-size: 13px;
  line-height: 1.14;
  font-weight: 700;
}
@keyframes fade { 0%, 75% { opacity: 1; } 100% { opacity: 0; transform: translateY(8px); } }

