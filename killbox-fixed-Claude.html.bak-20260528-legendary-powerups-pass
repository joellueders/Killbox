// ── Slime King (boss) ─────────────────────────────────────────────
function spawnSlimeKing() {
  S.bossActive   = true;
  S.bossSpawned  = true;
  const entry = SPAWN_POINTS[1] || SPAWN_POINTS[0] || { c: GOAL.c, r: GOAL.r };
  const path = spawnPathFor(entry);
  const w     = S.wave;
  const appearance = (S.slimeKingAppearances || 0) + 1;
  S.slimeKingAppearances = appearance;
  S.bossAppearance = appearance;
  const baseBossHp = (50 + w * 32 + Math.pow(w, 1.55) * 11) * 14;
  const appearanceHpMult = Math.pow(1.35, appearance - 1);
  const appearanceSizeMult = Math.pow(1.25, appearance - 1);
  const appearanceSpeedMult = Math.pow(1.12, appearance - 1);
  const appearanceKnockbackResistMult = Math.pow(0.85, appearance - 1);
  const hp    = baseBossHp * appearanceHpMult;
  const spd   = ((.84 + w * .024) * .34) * appearanceSpeedMult;
  S.enemies.push({
    type: 'slimeking', wild: false, off: 0, appearance, sizeScale: appearanceSizeMult,
    x: cx(entry.c) - 42, y: cy(entry.r),
    node: path.findIndex(p => p.c === entry.c && p.r === entry.r) || 0,
    path,
    hp, max: hp, spd, val: 150, rad: 32 * appearanceSizeMult, range: 360 + 20 * (appearance - 1), shoot: .25,
    slow: 0, poison: 0, burn: 0, dead: 0, flash: 0, healCool: 0,
    slimeDrop: .7,
    bossPhase: 1,
    minionTimer: 1.4,
    puddleTimer: 0,
    leapCd: 2,
    leapState: 'idle',
    leapTelegraph: 0,
    leapAir: 0,
    leapDuration: 0.45,
    ringTouchCd: 0,
    leapStartX: 0,
    leapStartY: 0,
    leapTargetX: 0,
    leapTargetY: 0,
    leapMinDist: 180,
    appearanceKnockbackResistMult,
    appearanceSizeMult,
    appearanceSpeedMult,
    appearanceHpMult,
  });
  S.bossIntro = appearance >= 4 ? 2.2 : appearance >= 2 ? 2.0 : 1.35;
  showBossWarning();
  playSfx('bossWarning');
  toast(appearance === 1 ? `THE SLIME KING STIRS (${Math.round(appearanceHpMult * 100)}% HP)` : `THE SLIME KING RETURNS x${appearance}`);
}

function clearSlimeTrail() {
  S.firePatches = (S.firePatches || []).filter(f => !f.slime);
}

function showBossWarning() {
  const el = $('bossWarning');
  if (!el) return;
  el.textContent = S.bossAppearance > 1 ? `⚠ THE SLIME KING RETURNS x${S.bossAppearance} ⚠` : '⚠ THE SLIME KING STIRS ⚠';
  el.classList.add('visible');
}
function hideBossWarning() { $('bossWarning').classList.remove('visible'); }

function slimeKingStep(e, dt) {
  const hpPct = e.hp / e.max;
  const appearance = e.appearance || 1;
  const n = v => Number.isFinite(v) ? v : 0;
  const safeLeapCoord = (v, min, max, fallback) => {
    const x = n(v);
    if (!Number.isFinite(x)) return fallback;
    return clamp(x, min, max);
  };
  // Periodically drop small health orbs
  e.slimeDrop -= dt;
  if (e.slimeDrop <= 0) {
    e.slimeDrop = appearance >= 3 ? .7 + Math.random() * 1.1 : appearance >= 2 ? .8 + Math.random() * 1.3 : .9 + Math.random() * 1.5;
    if (Math.random() < .40)
      dropHealthOrb(e.x + (Math.random() - .5) * 70, e.y + (Math.random() - .5) * 70);
  }

  // Boss phases
  e.minionTimer -= dt;
  e.puddleTimer -= dt;
  e.leapDebug = Math.max(0, (e.leapDebug || 0) - dt);
  const leapCadence = 5;
  const puddleGap = appearance >= 3 ? 0.84 : appearance >= 2 ? 0.98 : 1.18;
  const puddleR = appearance >= 3 ? 58 : appearance >= 2 ? 52 : 46;
  const puddleDps = appearance >= 3 ? 4.4 : appearance >= 2 ? 3.9 : 3.4;
  const splitEnabled = appearance >= 3;
  if (!e.splitIndex) e.splitIndex = 0;
  e.trailBurstCd = Math.max(0, (e.trailBurstCd || 0) - dt);
  e.ringTouchCd = Math.max(0, (e.ringTouchCd || 0) - dt);
  if (e.puddleTimer <= 0) {
    e.puddleTimer = puddleGap + Math.random() * puddleGap;
    S.firePatches.push({ x: e.x + (Math.random() - .5) * 90, y: e.y + (Math.random() - .5) * 70, r: puddleR, life: 9999, maxLife: 9999, dps: puddleDps, t: null, slime: true, bossTrail: true });
    const slimeTrail = S.firePatches.filter(f => f.slime);
    while (slimeTrail.length > 32) {
      const idx = S.firePatches.findIndex(f => f.slime);
      if (idx < 0) break;
      S.firePatches.splice(idx, 1);
      slimeTrail.shift();
    }
    boom(e.x, e.y, '#2e7f3b33', appearance >= 3 ? 7 : 4);
  }
  if (hpPct < .65 && e.minionTimer <= 0) {
    e.minionTimer = hpPct < .32 ? 1.8 : 2.6;
    const kinds = hpPct < .32 ? ['runner', 'bomber'] : ['grunt', 'runner'];
    for (const kind of kinds) spawn(kind);
    toast('The Slime King spawns minions!');
  }
  // Leap slam: telegraph -> airborne -> landing
  e.leapCd = Math.max(0, (e.leapCd || 0) - dt);
  if (e.leapState === 'telegraph') {
    e.leapTelegraph = Math.max(0, (e.leapTelegraph || 0) - dt);
    e.leapDebug = Math.max(e.leapDebug || 0, e.leapTelegraph);
    if (e.leapTelegraph <= 0) {
      e.leapState = 'airborne';
      e.leapAir = 0;
      e.leapDuration = 0.45;
      e.ringTouchCd = 0;
      e.x = e.leapStartX;
      e.y = e.leapStartY;
      floatText('LEAP!', e.x - 14, e.y - e.rad - 58, '#f3d3ff');
      playSfx('bossWarning');
    } else {
      const tx = e.leapTargetX;
      const ty = e.leapTargetY;
      const pulseR = 50 + (1 - Math.min(1, e.leapTelegraph / 1.0)) * 18;
      boom(tx, ty, '#d88cff33', 5);
      shockwave(tx, ty, '#ecd2ff', pulseR, .08);
      e.stun = Math.max(e.stun || 0, .08);
      e.kx = 0; e.ky = 0;
      followPath(e, dt, .12);
      return;
    }
  } else if (e.leapState === 'airborne') {
    e.leapAir += dt;
    const t = Math.min(1, e.leapAir / (e.leapDuration || 0.45));
    const sx = n(e.leapStartX), sy = n(e.leapStartY);
    const tx = n(e.leapTargetX), ty = n(e.leapTargetY);
    if (!Number.isFinite(sx) || !Number.isFinite(sy) || !Number.isFinite(tx) || !Number.isFinite(ty)) {
      e.leapState = 'idle';
      e.leapTarget = null;
      e.leapAir = 0;
      e.leapTelegraph = 0;
      e.leapCd = 5;
      return;
    }
    e.x = clamp(sx + (tx - sx) * t, OX + 16, OX + COLS * G - 16);
    e.y = clamp(sy + (ty - sy) * t, OY + 16, OY + ROWS * G - 16);
    e.leapDebug = 0.45;
    if (t < 1) {
      e.stun = Math.max(e.stun || 0, .05);
      e.kx = 0; e.ky = 0;
      return;
    }
    e.leapState = 'landing';
  }

  if (e.leapState === 'landing') {
    if (!Number.isFinite(e.leapTargetX) || !Number.isFinite(e.leapTargetY)) {
      e.leapState = 'idle';
      e.leapTarget = null;
      e.leapAir = 0;
      e.leapTelegraph = 0;
      e.leapCd = 5;
      return;
    }
    e.x = clamp(e.leapTargetX, OX + 16, OX + COLS * G - 16);
    e.y = clamp(e.leapTargetY, OY + 16, OY + ROWS * G - 16);
    S.firePatches.push({ x: e.x, y: e.y, r: 56 + (appearance >= 3 ? 8 : 0), life: 9999, maxLife: 9999, dps: appearance >= 4 ? 4.5 : appearance >= 3 ? 3.8 : 3.2, t: null, slime: true, bossTrail: true });
    const slimeTrail = S.firePatches.filter(f => f.slime);
    while (slimeTrail.length > 32) {
      const idx = S.firePatches.findIndex(f => f.slime);
      if (idx < 0) break;
      S.firePatches.splice(idx, 1);
      slimeTrail.shift();
    }
    const pulse = dist(e.x, e.y, S.hero.x, S.hero.y) < 140 ? S.hero : null;
    if (pulse) {
      const a = Math.atan2(pulse.y - e.y, pulse.x - e.x);
      const shove = appearance >= 4 ? 28 : 18;
      pulse.x += Math.cos(a) * shove;
      pulse.y += Math.sin(a) * shove;
    }
    if (dist(e.x, e.y, S.hero.x, S.hero.y) < 96) {
      hurtHero((appearance >= 4 ? 18 : appearance >= 3 ? 15 : 12) + Math.floor(S.wave * .45));
    }
    boom(e.x, e.y, '#2e7f3b33', appearance >= 4 ? 18 : 12);
    burst(e.x, e.y, '#7bdf5b', appearance >= 4 ? 22 : 16, 'goo', 180 + (appearance >= 4 ? 60 : 0));
    shockwave(e.x, e.y, '#c6ff8a', appearance >= 4 ? 150 : 110, .34);
    shake(appearance >= 4 ? 9 : 7, .2);
    floatText('SLAM', e.x - 18, e.y - e.rad - 60, '#f3d3ff');
    e.leapState = 'idle';
    e.leapTarget = null;
    e.leapImpactDone = false;
    e.leapHold = false;
    e.puddleTimer = Math.min(e.puddleTimer, .4);
    e.leapCd = 5;
    return;
  }

  if (hpPct > .08 && e.leapState === 'idle' && e.leapCd <= 0) {
    const heroD = dist(e.x, e.y, S.hero.x, S.hero.y);
    const dx = S.hero.x - e.x;
    const dy = S.hero.y - e.y;
    const l = Math.hypot(dx, dy) || 1;
    const travel = Math.max(180, heroD);
    e.leapStartX = e.x;
    e.leapStartY = e.y;
    e.leapTargetX = clamp(e.x + dx / l * travel, OX + 16, OX + COLS * G - 16);
    e.leapTargetY = clamp(e.y + dy / l * travel, OY + 16, OY + ROWS * G - 16);
    if (!Number.isFinite(e.leapStartX) || !Number.isFinite(e.leapStartY) || !Number.isFinite(e.leapTargetX) || !Number.isFinite(e.leapTargetY)) {
      e.leapState = 'idle';
      e.leapTarget = null;
      e.leapCd = 5;
      return;
    }
    e.leapState = 'telegraph';
    e.leapTelegraph = 1.0;
    e.leapDebug = 1.0;
    e.ringTouchCd = 0;
    e.leapCd = 999;
    e.stun = Math.max(e.stun || 0, .12);
    e.kx = 0; e.ky = 0;
    floatText('LEAP CHARGING', e.x - 42, e.y - e.rad - 58, '#d78cff');
    toast('The Slime King leaps!');
  }

  // Bullet storm targets hero, or co-op P2 if closer — never the AI engineer
  const targets = [S.hero];
  if (S.engineer.active && S.engineer.hp > 0 && !S.aiEngineerOwned) targets.push(S.engineer);
  const target = targets
    .filter(p => dist(e.x, e.y, p.x, p.y) < e.range)
    .sort((a, b) => dist(e.x, e.y, a.x, a.y) - dist(e.x, e.y, b.x, b.y))[0];
  if (target) {
    e.shoot -= dt;
    if (e.shoot <= 0) {
      slimeBulletStorm(e, target);
      e.shoot = Math.max(appearance >= 4 ? .5 : appearance >= 3 ? .65 : .75, 1.1 + Math.random() * .5 - .07 * (appearance - 1));
    }
  } else {
    e.shoot = Math.min(e.shoot, .35);
  }

  if (hpPct < .28) {
    e.shoot = Math.max(.2, e.shoot - dt * 1.2);
    e.spd *= 1.0006;
  }

  if (splitEnabled) {
    const splitStages = e.splitStages || [ .75, .5, .25 ];
    while (e.splitIndex < splitStages.length && hpPct <= splitStages[e.splitIndex]) {
      const stage = splitStages[e.splitIndex++];
      const count = stage <= .25 ? 5 : stage <= .5 ? 4 : 3;
      const kinds = stage <= .25 ? ['runner', 'runner', 'grunt', 'grunt', 'slinger'] : stage <= .5 ? ['runner', 'grunt', 'grunt', 'slinger'] : ['grunt', 'runner', 'grunt'];
      const angleBase = Math.random() * Math.PI * 2;
      for (let i = 0; i < Math.min(count, kinds.length); i++) {
        const a = angleBase + (i / Math.max(1, count)) * Math.PI * 2;
        const kind = kinds[i];
        const ex = e.x + Math.cos(a) * (28 + i * 4);
        const ey = e.y + Math.sin(a) * (28 + i * 4);
        const child = spawnEnemyAt(kind, ex, ey, e.path, e.node);
        if (child) {
          child.slow = Math.max(child.slow || 0, .18);
          child.flash = .12;
        }
      }
      toast(stage <= .25 ? 'The Slime King splits wildly!' : stage <= .5 ? 'The Slime King splits!' : 'The Slime King fractures!');
      boom(e.x, e.y, '#b9d84f', 18);
      shockwave(e.x, e.y, '#dff4ff', 72, .26);
      shake(5, .16);
    }
  }

  followPath(e, dt, .78);
}

function slimeBulletStorm(e, target = S.hero) {
  const base  = Math.atan2(target.y - e.y, target.x - e.x);
  const appearance = e.appearance || 1;
  const burstCount = appearance >= 4 ? 3 : appearance >= 3 ? 2 : 1;
  const count = 9 + Math.min(4, appearance - 1);
  for (let b = 0; b < burstCount; b++) {
    const offset = (b - (burstCount - 1) / 2) * .12;
    for (let i = 0; i < count; i++) {
      const spread = (-.55 + i * (1.1 / (count - 1))) + (Math.random() - .5) * .08 + offset;
      const sp     = 145 + Math.random() * 55 + (appearance >= 4 ? 20 : 0);
      S.enemyShots.push({
        x: e.x, y: e.y,
        vx: Math.cos(base + spread) * sp,
        vy: Math.sin(base + spread) * sp,
        life: 2.9, dmg: (7 + S.wave * .35) * (appearance >= 4 ? 1.2 : appearance >= 3 ? 1.1 : 1), slime: true,
      });
    }
  }
  boom(e.x, e.y, '#4fa34f33', appearance >= 4 ? 12 : 8);
  shake(appearance >= 4 ? 5 : 3, .12);
}


// ── Powerups ──────────────────────────────────────────────────────
function dropRandomPowerup(e, byHero = false) {
  if (!S.waveActive || S.phase !== 'combat') return;
  const elite = ['brute', 'ogre', 'hunter', 'bomber', 'shield', 'healer', 'siege'].includes(e.type);
  let chance = .026 + Math.min(.02, S.wave * .0015);
  if (elite) chance += .035;
  if (byHero) chance += .025;
  if (Math.random() > chance) return;

  const healthBias = S.hero.hp < S.hero.max * .4 ? 2.2 : S.hero.hp < S.hero.max * .7 ? 1.4 : 1;
  const trinketReadyBias = Object.values(TRINKETS).some(tr => tr.lastUsed && trinketCooldownRemaining(tr.id) > 12) ? 1.3 : 1;
  const weights = [
    { type: 'health', weight: 24 * healthBias },
    { type: 'gold', weight: 20 },
    { type: 'frenzy', weight: 14 },
    { type: 'haste', weight: 12 },
    { type: 'freeze', weight: 10 },
    { type: 'bomb', weight: 8 },
    { type: 'reset', weight: 6 * trinketReadyBias },
    { type: 'rift', weight: 6 },
  ];
  const total = weights.reduce((n, w) => n + w.weight, 0);
  let roll = Math.random() * total;
  let type = weights[0].type;
  for (const w of weights) {
    roll -= w.weight;
    if (roll <= 0) { type = w.type; break; }
  }
  dropPowerup(e.x + (Math.random() - .5) * 28, e.y + (Math.random() - .5) * 28, type);
}

function dropPowerup(x, y, type = 'health', full = false) {
  const cfg = {
    health: { r: 13, life: 14, hp: Math.max(18, Math.floor(S.hero.max * .45)) },
    heal:   { r: 13, life: 14, hp: Math.max(18, Math.floor(S.hero.max * .45)) },
    gold:   { r: 13, life: 12, gold: 120 + Math.min(130, Math.floor(S.wave * 4 + Math.random() * 50)) },
    frenzy: { r: 13, life: 12, frenzy: 8 },
    haste:  { r: 13, life: 12, haste: 8 },
    freeze: { r: 13, life: 12, freeze: 3.25 },
    bomb:   { r: 14, life: 12, bomb: 300 + S.wave * 6 },
    reset:  { r: 13, life: 12, reset: true },
    rift:   { r: 14, life: 12, rift: 8 },
  }[type] || { r: 12, life: 10 };
  S.healthOrbs.push({ x, y, type, full, ...cfg, r: full ? 20 : cfg.r, life: full ? 9999 : cfg.life });
  boom(x, y, powerupColor(type, full), full ? 18 : 6);
}

function powerupColor(type, full = false) {
  const t = type === 'heal' ? 'health' : type;
  if (full) return '#ffe09c33';
  if (t === 'health') return '#b9d84f';
  if (t === 'gold') return '#f4c24f';
  if (t === 'frenzy') return '#ff6d3a';
  if (t === 'haste') return '#6ad6ff';
  if (t === 'freeze') return '#9fe8ff';
  if (t === 'bomb') return '#ff9b32';
  if (t === 'reset') return '#c78cff';
  if (t === 'rift') return '#8edcff';
  return '#b9d84f';
}

function dropHealthOrb(x, y, hp = 15, full = false) {
  dropPowerup(x, y, 'health', full);
  const o = S.healthOrbs[S.healthOrbs.length - 1];
  o.hp = hp;
}

function playPickupFeedback(type, x, y) {
