function rollMutationChoices(kind = 'weapon') {
  const heroOwned = new Set(S.heroMutations || []);
  const trapOwned = new Set(S.trapMutations || []);
  const pickThree = (pool, allowOwnedFallback = false) => {
    const src = allowOwnedFallback ? [...pool] : pool.filter(Boolean);
    const out = [];
    while (src.length && out.length < 3) out.push(src.splice(Math.floor(Math.random() * src.length), 1)[0]);
    return out;
  };
  if (kind === 'tower') {
    const pool = Object.values(TRAP_UPGRADES).filter(u => !trapOwned.has(u.id));
    const out = pickThree(pool);
    if (out.length) return out;
    return pickThree(Object.values(TRAP_UPGRADES), true);
  }
  const weapon = S.hero.weapon;
  const owned = new Set(S.heroMutations || []);
  const pool = Object.values(HERO_UPGRADES).filter(u => u.weapons.includes(weapon) && !owned.has(u.id));
  const universal = Object.values(HERO_UPGRADES).filter(u => u.weapons.length > 1 && !owned.has(u.id));
  const all = [...new Set([...pool, ...universal])];
  const out = pickThree(all);
  if (out.length) return out;
  const fallback = Object.values(HERO_UPGRADES).filter(u => u.weapons.includes(weapon));
  return pickThree(fallback, true);
}

