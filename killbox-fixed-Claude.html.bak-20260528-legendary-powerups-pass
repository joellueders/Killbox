  }
  if ((h.shieldHits || 0) > 0) {
    ctx.save();
    ctx.strokeStyle = '#b285ff';
    ctx.lineWidth = 4;
    ctx.globalAlpha = .8;
    ctx.beginPath();
    ctx.arc(h.x, h.y, 24 + Math.sin(t * 7) * 1.5, 0, 7);
    ctx.stroke();
    ctx.restore();
  }
  if (!slimeActive && (h._slimeWasActive || 0)) floatText('SLIME OFF', h.x - 24, h.y - 42, '#7cff4f');
  h._slimeWasActive = slimeActive ? 1 : 0;
}

function drawSpawnIntros(t) {
  for (const fx of S.spawningActors) {
    const p = fx.t / (fx.max || 1);
    const x = fx.x, y = fx.y;
    const beamH = 320;
    const topY = y - beamH;
    ctx.save();
    ctx.globalCompositeOperation = 'screen';
    const grad = ctx.createLinearGradient(x, topY, x, y + 26);
    grad.addColorStop(0, 'rgba(150,220,255,0)');
    grad.addColorStop(.18, `rgba(150,220,255,${.58 + (1-p)*.1})`);
    grad.addColorStop(.58, `rgba(255,225,145,${.85 + (1-p)*.08})`);
    grad.addColorStop(1, `rgba(235,250,255,${.95 - p*.15})`);
    ctx.fillStyle = grad;
    ctx.fillRect(x - 30, topY, 60, beamH + 28);
    ctx.fillStyle = `rgba(255,245,220,${.32 + (1-p)*.15})`;
    ctx.fillRect(x - 12, topY, 24, beamH + 28);
    ctx.fillStyle = `rgba(255,255,255,${.26 + (1-p)*.12})`;
    ctx.fillRect(x - 4, topY, 8, beamH + 28);
    ctx.strokeStyle = `rgba(210,245,255,${.75 + (1-p)*.2})`;
    ctx.lineWidth = 3;
    ctx.strokeRect(x - 20, topY + 4, 40, beamH + 16);
    for (let i = 0; i < 8; i++) {
      const a = t * 2 + i * (Math.PI / 4);
      const rr = 12 + i % 2 * 6;
      ctx.fillStyle = i % 2 ? '#9fe8ff' : '#f0d37f';
      ctx.globalAlpha = .9 * (1 - p);
      ctx.beginPath(); ctx.arc(x + Math.cos(a) * rr, y + Math.sin(a) * rr * .55, 2.2, 0, 7); ctx.fill();
    }
    ctx.globalAlpha = .95 * (1 - p);
    ctx.fillStyle = '#e9fbff';
    ctx.beginPath(); ctx.arc(x, y + 10, 18 + (1 - p) * 8, 0, 7); ctx.fill();
    ctx.strokeStyle = '#7ad2ff';
    ctx.lineWidth = 4;
    ctx.beginPath(); ctx.arc(x, y + 8, 32 + (1 - p) * 16, 0, 7); ctx.stroke();
    ctx.fillStyle = `rgba(255,225,145,${.7 + (1-p)*.2})`;
    ctx.beginPath(); ctx.arc(x, y + 12, 10 + (1 - p) * 5, 0, 7); ctx.fill();
    ctx.globalCompositeOperation = 'source-over';
    ctx.restore();
  }
}

function drawHealthOrb(o, t) {
  ctx.save();
  ctx.globalAlpha = o.full ? 1 : Math.max(.25, Math.min(1, o.life / 2));
  const type = o.type || 'health';
  ctx.fillStyle   = powerupColor(type, o.full);
  ctx.strokeStyle = o.full ? '#ffffff' : (type === 'gold' ? '#fff0b8' : type === 'frenzy' ? '#ffd0bf' : type === 'haste' ? '#d8f4ff' : type === 'freeze' ? '#e7fbff' : type === 'bomb' ? '#ffdcb2' : type === 'reset' ? '#ead4ff' : type === 'rift' ? '#cfefff' : '#fff7c2');
  ctx.lineWidth   = o.full ? 4 : 2;
  ctx.beginPath(); ctx.arc(o.x, o.y, o.r + Math.sin(t * (o.full ? 9 : 7)) * (o.full ? 3 : 2), 0, 7);
  ctx.fill(); ctx.stroke();
