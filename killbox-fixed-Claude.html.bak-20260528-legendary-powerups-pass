function chooseMutation(id) {
  // Resolve the modal, clear the upgrade gate, and return to the between-waves state.
  const up = HERO_UPGRADES[id] || TRAP_UPGRADES[id] || BOSS_UPGRADES[id];
  if (!up) return;
  up.apply(S.hero);
  if (S.mutationWaveType === 'tower') S.trapMutations.push(id);
  else S.heroMutations.push(id);
  S.mutationPending = false;
  S.pendingUpgrade = false;
  S.gameState = 'betweenWaves';
  clearCombatInputState();
  $('mutation').classList.add('hidden');
  $('clear').classList.add('hidden');
  toast(`Mutation: ${up.name}`);
}

function finishWave() {
  S.waveActive = false;
  S.phase      = 'build';
  S.hero.hp    = Math.min(S.hero.max, S.hero.hp + 25);
  S.firePatches = (S.firePatches || []).filter(f => !f.slime);
  hideBossWarning();

  const bonus = Math.floor((25 + S.wave * 5 + Math.floor(S.wave * S.wave * 0.4)) * 1.14);

  // Interest on unspent gold: 8% on gold above 60, shown to player
  const interest = S.gold > 60 ? Math.floor((S.gold - 60) * 0.08) : 0;
  S.gold += bonus + interest;
  if (S.waveStats) {
    S.waveStats.bonusGold = bonus;
    S.waveStats.interestGold = interest;
  }
  if (S.runStats) {
    S.runStats.bonusGold += bonus;
    S.runStats.interestGold += interest;
    S.runStats.wavesCleared++;
  }

  const interestNote = interest > 0 ? ` Reserve interest: +${interest}g.` : '';

  const lines = [
    'THE HARVEST HOLDS',
    'THE GATE STILL STANDS',
    'DAWN HAS NOT CLAIMED YOU YET',
    'THE VILLAGE ENDURES',
    'THE KILLBOX IS FED',
  ];
  $('clearTitle').textContent = lines[Math.floor(Math.random() * lines.length)];
  $('clearText').textContent  = `Wave ${S.wave} got mulched. Bonus: +${bonus}g.${interestNote} The next corridor is already snarling.`;
  renderWaveSummary(bonus, interest);
  document.querySelector('#clear .card').classList.add('clearCard');
  S.clearFlash = .7;
  playSfx('waveClear');
  announceWave(`WAVE ${S.wave} CLEARED!`, 'resting', 1.15);
  S.paused = false;
  console.log("FINISH WAVE:", {
    wave: S.wave,
    pendingUpgrade: S.pendingUpgrade,
    mutationPending: S.mutationPending,
    gameState: S.gameState
  });
  showMutationOverlay();
  if (S.aiEngineerOwned) {
    S.aiEngineerOwned = false;
    S.engineer.active = false;
    toast('Engineer bailed. Rehire the coward next wave.');
  }
  toast('The lane survived. Barely.');
  ui();
}

