// ── Build / placement ──────────────────────────────────────────────
function canBuild(px, py) {
  if (S.hero.spawnState === 'spawning') return false;
  if (!S.selected) return false;
  if (!S.started || S.gameOver) return false;
  const { c, r } = getSnappedBuildTile(px, py);
  const d = TOWERS[S.selected];
  if (!d || c < 0 || r < 0 || c >= COLS || r >= ROWS) return false;
  if (!canBuildOnCell(c, r)) return false;
  if (WEAPONS[S.selected] || isTrinketItem(S.selected)) return false;
  if (SPAWN_POINTS.some(sp => sp && c === sp.c && r === sp.r)) return false;
  if ((c === GOAL.c && r === GOAL.r)) return false;
  if (S.selected === 'cauldron' && isRoad(c, r)) return false;
  if (S.selected === 'barrier' || S.selected === 'barrel')
    return isRoad(c, r) && !occupied(c, r);
  if (d.trap) {
    const adjRoad = [[1,0],[-1,0],[0,1],[0,-1]].some(([dc,dr]) => isRoad(c + dc, r + dr));
    if (S.selected === 'spring' || S.selected === 'spikes') {
      return isRoad(c, r) && !occupied(c, r);
    }
    return isRoad(c, r) && !occupied(c, r);
  }
  return !occupied(c, r);
}

function canvasPointFromEvent(e) {
  const rect = canvas.getBoundingClientRect();
  const scaleX = W / rect.width;
  const scaleY = H / rect.height;
  return {
    x: (e.clientX - rect.left) * scaleX,
    y: (e.clientY - rect.top) * scaleY,
  };
}

function place(px, py) {
  if (!S.selected) return;
  const d = TOWERS[S.selected];
  if (!d) return;
  if (WEAPONS[S.selected] || isTrinketItem(S.selected)) return;
  if (!canBuild(px, py)) return;
  const { c, r } = getSnappedBuildTile(px, py);
  if (!S.devUnlimitedGold && S.gold < d.c) return toast('Not enough gold.');

  if (S.selected === 'barrier') {
    const b = { c, r, x: cx(c), y: cy(r), hp: 520, max: 520, sold: d.c * .55 };
    S.barriers.push(b);
    if (!rebuildPath()) { S.barriers.pop(); rebuildPath(); return toast('That would fully block the route.'); }
    spendGold(d.c);
    playSfx('place');
    boom(b.x, b.y, d.fill, 5);

  } else if (S.selected === 'barrel') {
    spendGold(d.c);
    S.barrels.push({ c, r, x: cx(c), y: cy(r), hp: 35, rad: 22, sold: 0 });
    playSfx('place');
    boom(cx(c), cy(r), '#8b4424', 10);

  } else {
    const onRoad = isRoad(c, r);
    const tx     = onRoad ? cx(c) : px;
    const ty     = onRoad ? cy(r) : py;
    const tower  = {
      type: S.selected, c, r, onRoad,
      dir: d.directional ? (S.placeDir || 1) : 1,
      x: tx, y: ty, level: 1, cool: 0, kills: 0,
      sold: d.c * .55,
    };
    if (!isCoreTowerType(S.selected)) {
      const maxHp = 150 + Math.floor(d.c * .7);
      tower.hp = maxHp;
      tower.max = maxHp;
    }
    S.towers.push(tower);
    if (onRoad && !d.trap && !rebuildPath()) {
      S.towers.pop(); rebuildPath();
      return toast('That tower would fully block the route.');
    }
    spendGold(d.c);
    playSfx('place');
    boom(tx, ty, d.fill, 7);
  }
  if (S.phase === 'combat') {
    $('info').textContent = 'Combat build: selected tower stays active for rapid placement.';
  }
  ui();
}

function towerLongDesc(type) {
  const d = TOWERS[type];
  const notes = {
    archer: 'Fast accurate shots. Reliable ranged lane cleanup.',
    ballista: 'Long range bolts. High-damage shots for armored or priority targets.',
    frost: 'Slows enemies. Slows enemies so kill tools can finish them.',
    cauldron: 'Burns chokepoints. Creates persistent fire denial.',
    cannon: 'Area damage. Punishes clustered enemies with explosive fire.',
    barracks: 'Holds the lane. Creates battlefield obstruction and buys time.',
    spire: 'Chain lightning. Lightning arcs through tightly packed enemies.',
    alchemist: 'Poison damage. Applies sustained poison pressure over time.',
    spikes: 'Contact damage. Punishes enemies that commit to the lane.',
    tar: 'Shoves enemies. Throws enemies back into prepared killzones.',
    spring: 'Launches enemies. Violently ejects enemies out of position.',
    mace: 'Sweeps groups. Wide melee swing that batters clustered enemies backward.',
    barrier: 'Blocks roads. Stops movement and reshapes enemy flow.',
    barrel: 'Manual explosion. Shoot to detonate for manual damage.'
