  ctx.globalAlpha = isSlime ? .9 : isIce ? (fullCharge ? 1 : .92) : isChargedRanger ? (fullCharge ? 1 : .85) : s.weapon === 'storm' ? 1 : glow ? 0.9 : 0.7;
