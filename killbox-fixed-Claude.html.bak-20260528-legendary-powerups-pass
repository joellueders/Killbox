      ctx.strokeStyle = '#ffe09c'; ctx.lineWidth = 4;
      ctx.beginPath(); ctx.moveTo(0, -20); ctx.lineTo(0, 11); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(0, -20); ctx.lineTo(-12, -7); ctx.lineTo(12, -7); ctx.closePath(); ctx.fill();
