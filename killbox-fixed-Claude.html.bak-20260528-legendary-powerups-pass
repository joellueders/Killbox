}
function applySnapshot(st) {
  const net = S.net;
  if (st.levelId) applyLevel(st.levelId, { silent: true });
  Object.assign(S, st);
  S.mods = { gold: 1.14, dmg: 1, overclockUntil: 0, frenzyUntil: 0, hasteUntil: 0, coinPurseUntil: 0, lastStandUntil: 0, riftShieldUntil: 0, ...(S.mods || {}) };
  S.net = net;
  S.towers = (S.towers || []).map(t => towerHasDurability(t) ? t : ({ ...t, hp: undefined, max: undefined }));
  S.firePatches = (S.firePatches || []).map(({ t, ...patch }) => ({ ...patch }));
  S.engineer.active = true;
  if (S.started) $('start').classList.add('hidden');
  if (!S.waveActive) $('clear').classList.add('hidden');
  ui();
}
function sendGuestInput(now) {
  if (S.net.mode !== 'guest' || !S.net.connected) return;
  if (now - S.net.lastSend < 33) return;
  S.net.lastSend = now;
  const m = getMouseWorldPosition();
  netSend({ type:'input', input: {
    up: keys.w || keys.ArrowUp,
    down: keys.s || keys.ArrowDown,
    left: keys.a || keys.ArrowLeft,
    right: keys.d || keys.ArrowRight,
    shoot: mouse.down,
    volley: !!keys.q,
    oil: !!keys.e,
    aimX: m.x,
    aimY: m.y,
  }});
}
function sendHostSnapshot(now) {
  if (S.net.mode !== 'host' || !S.net.connected) return;
  if (now - S.net.lastSnapshot < 90) return;
  S.net.lastSnapshot = now;
  netSend({ type:'state', state: makeSnapshot() });
}

// ── Event handlers ─────────────────────────────────────────────────
canvas.onmousemove = e => {
  const pt = canvasPointFromEvent(e);
  mouse.x = pt.x;
  mouse.y = pt.y;
};
canvas.addEventListener('contextmenu', e => e.preventDefault());
document.addEventListener('pointerdown', unlockAudio, { once: true, capture: true });
document.addEventListener('mousedown', unlockAudio, { once: true, capture: true });
document.addEventListener('touchstart', unlockAudio, { once: true, capture: true, passive: true });
document.addEventListener('keydown', unlockAudio, { once: true, capture: true });
document.addEventListener('click', e => { if (e.target.closest('button')) clickSound(); }, true);
function handleCanvasPointerDown(e) {
  const pt = canvasPointFromEvent(e);
  const worldPt = { x: pt.x + CAMERA.x, y: pt.y + CAMERA.y };
  if (e.button === 2) {
    e.preventDefault();
    const px = worldPt.x, py = worldPt.y;
    const overUi = pt.x > W - 375 || !S.started || S.gameOver;
    if (!overUi && S.phase === 'build') {
      const t  = S.towers.find(o => dist(px, py, o.x, o.y) < 24);
      const b  = S.barriers.find(o => dist(px, py, o.x, o.y) < 24);
      const br = S.barrels.find(o => dist(px, py, o.x, o.y) < 24);
      if (t || b || br) {
        sellEntity(t || b || br);
        return;
      }
      if (rotateSelectedDirectionalTrap()) return;
    }
    weaponSecondaryDown();
    return;
  }
  if (e.button === 0) mouse.down = true;
}
function handleCanvasPointerUp(e) {
  if (e.button === 0) mouse.down = false;
  if (e.button === 2) weaponSecondaryUp();
}
canvas.onmousedown = null;
canvas.onmouseup   = null;
canvas.onpointerdown = e => { e.preventDefault(); handleCanvasPointerDown(e); };
canvas.onpointerup   = e => { e.preventDefault(); handleCanvasPointerUp(e); };
document.addEventListener('mouseup', e => { if (e.button === 0) mouse.down = false; if (e.button === 2) weaponSecondaryUp(); });
document.addEventListener('pointerup', e => { if (e.button === 0) mouse.down = false; if (e.button === 2) weaponSecondaryUp(); });
document.addEventListener('pointercancel', () => { mouse.down = false; });
canvas.addEventListener('mouseleave', () => { mouse.down = false; });
window.addEventListener('blur', () => { mouse.down = false; });
document.addEventListener('visibilitychange', () => { if (document.hidden) mouse.down = false; });

canvas.onclick = e => {
  if (!S.started || S.gameOver) return;
  const pt = canvasPointFromEvent(e);
  const px = pt.x + CAMERA.x, py = pt.y + CAMERA.y;
  if (S.phase === 'combat' && !S.selected) { S.sel = null; ui(); return; }
  const t  = S.towers.find(o   => dist(px, py, o.x, o.y) < 24);
  const b  = S.barriers.find(o => dist(px, py, o.x, o.y) < 24);
  const br = S.barrels.find(o  => dist(px, py, o.x, o.y) < 24);
  if (t || b || br) { S.sel = t || b || br; showSelected(); ui(); return; }
  if (S.selected && isBuildableItem(S.selected) && S.net.mode !== 'guest') place(px, py);
};

$('info').onclick    = () => showSelected();
$('upgrade').style.display = 'none';
$('sell').onclick    = sellSelected;
$('newRunBtn').onclick = () => {
  if (confirm('Start a new run? Current progress will be lost.')) location.reload();
};
$('setWaveBtn').onclick = setNextWaveForTesting;

$('hireEngineer').onclick = () => {
  if (S.aiEngineerOwned || S.net.mode !== 'solo') return;
  if (!spendGold(200)) return;
  S.aiEngineerOwned = true;
  S.engineer.active = true;
  S.engineer.hp     = S.engineer.max;
  // Spawn near the hero, offset slightly
  S.engineer.x = clamp(S.hero.x + 30, OX + 16, OX + COLS * G - 16);
  S.engineer.y = clamp(S.hero.y + 20, OY + 16, OY + ROWS * G - 16);
  boom(S.engineer.x, S.engineer.y, '#8edcff', 12);
  toast('Engineer hired for this wave.');
  ui();
};

if ($('flaskHud')) $('flaskHud').onclick = useLifeFlask;
if ($('waveBtn')) $('waveBtn').onclick = startWave;
if ($('pause')) $('pause').onclick   = () => { S.paused = !S.paused; ui(); };
const SPEED_VALUES = [1, 1.5, 2, 3];
function normalizeSpeedValue(v) {
  const n = Number(v) || 1;
  return SPEED_VALUES.includes(n) ? n : 1;
}
function toggleSpeed() {
  S.speed = normalizeSpeedValue(S.speed);
  const i = SPEED_VALUES.indexOf(S.speed);
  S.speed = SPEED_VALUES[(i + 1 + SPEED_VALUES.length) % SPEED_VALUES.length];
  ui();
  toast('Speed ' + S.speed + 'x');
}
if ($('hudSpeedBtn')) $('hudSpeedBtn').onclick = toggleSpeed;
if ($('waveSpeedBtn')) $('waveSpeedBtn').onclick = toggleSpeed;
const toggleMenu = () => {
  S.menuOpen = !S.menuOpen;
  ui();
  setTimeout(resize, 0);
  setTimeout(resize, 260);
};
if ($('menuToggle')) $('menuToggle').onclick = toggleMenu;
$('devToggle').onclick = () => { S.devToolsOpen = !S.devToolsOpen; ui(); };
$('devGoldToggle').onclick = () => { S.devUnlimitedGold = !S.devUnlimitedGold; if (S.devUnlimitedGold) syncDevGold(); ui(); toast(`Infinite Gold ${S.devUnlimitedGold ? 'ON' : 'OFF'}`); };
$('devInvToggle').onclick = () => { S.devInvincible = !S.devInvincible; ui(); toast(`God Mode ${S.devInvincible ? 'ON' : 'OFF'}`); };
$('devInfoToggle').onclick = () => { S.devShowInfo = !S.devShowInfo; ui(); toast(`Debug Overlay ${S.devShowInfo ? 'ON' : 'OFF'}`); };
$('devAudioToggle').onclick = () => { unlockAudio(); setAudioMuted(!AUDIO.muted); toast(`Audio ${AUDIO.muted ? 'OFF' : 'ON'}`); };
$('devVolume').oninput = e => { unlockAudio(); setAudioVolume((Number(e.target.value) || 0) / 100); };
$('devSetGold').onclick = () => {
  const v = Math.max(0, Math.floor(Number($('devGoldValue')?.value || 0)));
  S.gold = v;
  S.devUnlimitedGold = false;
  ui();
  toast(`Gold set to ${v}.`);
};
$('devSetWave').onclick = () => setDevWave($('devWaveValue')?.value || 1);
$('devArenaSelect').onchange = e => { S.devArenaChoice = e.target.value || 'field'; };
$('devLoadArena').onclick = () => switchArena(S.devArenaChoice || $('devArenaSelect')?.value || 'field');
$('startArenaSelect').onchange = e => { LOADOUT_STATE.arenaId = e.target.value || 'field'; updateLoadoutSummary(); };
$('devSpawnBoss').onclick = () => devSpawnSlimeKing();
$('devClearEnemies').onclick = () => devClearEnemies();
$('devKillHero').onclick = () => devKillHero();
$('devHealHero').onclick = () => devHealHero();
$('devResetCd').onclick = () => devResetCooldowns();
$('begin').onclick   = startGameFromLoadout;
$('clearBtn').onclick = () => {
  if (S.mutationPending) return toast('Choose a mutation first.');
  document.querySelector('#clear .card').classList.remove('clearCard');
  $('clear').classList.add('hidden');
  clearCombatInputState();
  S.paused = false; S.phase = 'build'; S.waveActive = false; S.gameState = 'betweenWaves'; ui();
};
$('save').onclick    = makePass;
$('load').onclick    = loadPass;
if ($('loadoutPicker')) {
  $('loadoutPicker').addEventListener('click', e => {
    const card = e.target.closest('[data-k]');
    if (!card || !$('loadoutPicker').contains(card)) return;
    toggleLoadout(card.dataset.k);
  });
  $('loadoutPicker').addEventListener('mouseover', e => {
    const card = e.target.closest('[data-k]');
    if (!card || !$('loadoutPicker').contains(card)) return;
    setLoadoutInspector(card.dataset.k);
  });
  $('loadoutPicker').addEventListener('focusin', e => {
    const card = e.target.closest('[data-k]');
    if (!card || !$('loadoutPicker').contains(card)) return;
    setLoadoutInspector(card.dataset.k);
  });
  $('loadoutPicker').addEventListener('scroll', () => syncLoadoutStickyLabel(), { passive: true });
}
if ($('loadoutTabs')) {
  $('loadoutTabs').addEventListener('click', e => {
    const tab = e.target.closest('[data-loadout-tab]');
    if (!tab || !$('loadoutTabs').contains(tab)) return;
    setLoadoutCategory(tab.dataset.loadoutTab);
  });
}
if ($('loadoutPreviewRail')) {
  $('loadoutPreviewRail').addEventListener('click', e => {
    const slot = e.target.closest('[data-k]');
    if (!slot || !$('loadoutPreviewRail').contains(slot) || !slot.dataset.k) return;
    setLoadoutInspector(slot.dataset.k);
  });
}

function canStartRun() {
  return !!LOADOUT_STATE.selectedIds.length && LOADOUT_STATE.selectedIds.some(k => !!WEAPONS[k]);
}
addEventListener('keydown', e => {
  keys[e.key] = true; keys[e.key.toLowerCase()] = true; keys[e.code] = true;
  if (e.key === '`' || e.code === 'F10') { e.preventDefault(); S.devToolsOpen = !S.devToolsOpen; ui(); return; }
  const tKeys = S.loadout && S.loadout.length ? S.loadout : [];
  if (e.key >= '1' && e.key <= String(LOADOUT_MAX_SLOTS)) {
    const idx = +e.key - 1;
    const pick = tKeys[idx];
    if (pick) {
      if (WEAPONS[pick]) {
        S.hero.weapon = pick;
        S.weapon = pick;
        S.selected = null;
      } else if (isTrinketItem(pick)) {
        useTrinket(pick);
        S.selected = null;
      } else {
        S.selected = pick;
      }
      S.sel = null; ui();
    }
  }
  if (e.code === 'Space') { e.preventDefault(); if (S.net.mode !== 'guest') startWave(); }
  if (e.key.toLowerCase() === 'p') { S.paused = !S.paused; ui(); }
  if (e.key.toLowerCase() === 't') toggleSpeed();
  if (e.key.toLowerCase() === 'c' && S.net.mode !== 'guest') useLifeFlask();
});
addEventListener('keyup', e => { keys[e.key] = false; keys[e.key.toLowerCase()] = false; keys[e.code] = false; });

// ── Main loop ──────────────────────────────────────────────────────
let last = performance.now();

function loop(now) {
  requestAnimationFrame(loop);
  const dt = Math.min((now - last) / 1000, .033);
  last = now;
  if (S.clearFlash > 0) S.clearFlash = Math.max(0, S.clearFlash - dt);
  if (S.net.mode === 'guest') {
    sendGuestInput(now);
    draw(now / 1000);
    return;
  }
  if (S.started && !S.paused && !S.gameOver && $('clear').classList.contains('hidden') && S.gameState !== 'upgradeChoice') {
    step(dt * normalizeSpeedValue(S.speed));
  }
  sendHostSnapshot(now);
  draw(now / 1000);
}

requestAnimationFrame(loop);
preloadEnemySprites();
// Co-op UI disabled in 5.5.1 Waymark.
ui();
renderSetupPickers();
</script>
</body>
