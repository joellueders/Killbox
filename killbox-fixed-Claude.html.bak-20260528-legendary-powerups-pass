      shockwave(x, y, '#f4c24f', 84, .26);
      burst(x, y, '#f4c24f', 14, 'spark', 120);
      break;
    case 'frenzy':
      playSfx('pickupBoost');
      shockwave(x, y, '#ff6d3a', 96, .28);
      burst(x, y, '#ff8e45', 18, 'spark', 160);
      break;
    case 'haste':
      playSfx('pickupBoost');
      shockwave(x, y, '#6ad6ff', 96, .28);
      burst(x, y, '#8edcff', 18, 'spark', 160);
      break;
    case 'freeze':
      playSfx('pickupFreeze');
      shockwave(x, y, '#9fe8ff', 118, .34);
      burst(x, y, '#d8f2ff', 18, 'spark', 180);
      break;
    case 'bomb':
