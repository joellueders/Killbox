  }

  ctx.fillStyle = '#2b120b'; ctx.fillRect(h.x - 24, h.y - 32, 48, 6);
  const hpPct = h.hp / h.max;
  ctx.fillStyle = hpPct > .5 ? '#4f8d3b' : hpPct > .25 ? '#a88d28' : '#c03020';
  ctx.fillRect(h.x - 24, h.y - 32, 48 * hpPct, 6);
  if (slimeActive) {
    ctx.save();
    ctx.globalCompositeOperation = 'screen';
    ctx.globalAlpha = .45;
    ctx.fillStyle = '#7cff4f';
    ctx.beginPath();
    ctx.arc(h.x, h.y, 30 + Math.sin(t * 8) * 1.5, 0, 7);
    ctx.fill();
    ctx.strokeStyle = '#c2ff93';
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.arc(h.x, h.y, 22 + Math.sin(t * 6) * 1.2, 0, 7);
