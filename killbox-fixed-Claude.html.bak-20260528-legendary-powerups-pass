  ctx.globalAlpha = 1;

  if (blunderShieldActive) {
    const pulse = 1 + Math.sin(t * 8) * 0.06;
    ctx.save();
    ctx.globalCompositeOperation = 'screen';
    ctx.strokeStyle = '#9fd9ff';
    ctx.fillStyle = 'rgba(140, 207, 255, 0.12)';
    ctx.lineWidth = 4;
    ctx.beginPath();
    ctx.arc(h.x, h.y, 28 * pulse, 0, 7);
    ctx.fill();
    ctx.stroke();
    ctx.strokeStyle = '#f2d38a';
    ctx.lineWidth = 2;
    ctx.globalAlpha = 0.6;
    ctx.beginPath();
    ctx.arc(h.x, h.y, 20 * pulse, 0, 7);
    ctx.stroke();
    ctx.restore();
  }

  if (h.weapon === 'ranger' && h.charging) {
    const pct = Math.max(0, Math.min(1, h.charge || 0));
